rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // users collection — owner read/write only (shared with 5000-word PWA)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // heroLeaderboard collection — anyone can read, only owner can write
    match /heroLeaderboard/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
