ars.","translation":"澳洲的原住民在數千年間發展出豐富的文化和與土地的精神連結。"}},"3d69442a0118bd9e24625d82fc41f821":{"createdAt":1781565922946,"data":{"sentence":"From a young age, she felt destined to become a doctor and help others in need.","translation":"從年輕時起，她就感覺到自己命中註定要成為一名醫生，幫助有需要的人。"}},"3d83f34c1ae9e405675d5aad7f986d96":{"createdAt":1781566216285,"data":{"sentence":"The violent storm knocked down trees and caused widespread damage throughout the city.","translation":"那場猛烈的暴風雨吹倒了樹木，並對整個城市造成了廣泛的破壞。"}},"3de2d4a05a59a9602f6f82b0ffe68515":{"createdAt":1781516002016,"data":{"sentence":"The mechanic wiped the grease off his hands with an old rag.","translation":"機械師用舊抹布擦去他手上的油脂。"}},"3debf00c3a213d90e89ae28b767bc6c4":{"createdAt":1781452896986,"data":{"sentence":"The store will refund your money if you are not satisfied with your purchase within 30 days.","translation":"如果您在購買後30天內對商品不滿意，商店會退款給您。"}},"3df4db3c9e970b6a31829d32d10b492b":{"createdAt":1781584006122,"data":{"sentence":"The survey asked respondents to indicate their gender as either male, female, or non-binary.","translation":"該調查要求受訪者將其性別標示為男性、女性或非二元性別。"}},"3ecef133781de390b3af3e159592681c":{"createdAt":1781281026053,"data":{"sentence":"The charity received a generous donation from a local businessman to help build a new school.","translation":"慈善機構從一位當地商人那裡收到一筆慷慨的捐獻，用於幫助建造一所新學校。"}},"3ef59883bb05c34387667350da94b987":{"createdAt":1781928002095,"data":{"sentence":"She has been competing in athletics since high school and won several medals in track and field events.","translation":"她從高中開始就參加田徑運動，並在田徑項目中贏得了多枚獎牌。"}},"3f0868ed5ae0e1a2ad2fe132d8c05ef2":{"createdAt":1781767923664,"data":{"sentence":"The strong wind knocked over several trees during the storm.","translation":"暴風雨期間強風吹倒了好幾棵樹。"}},"3f19b61e99844bf7e0507c8054153675":{"createdAt":1781337041101,"data":{"sentence":"The castle's thick stone walls served as an effective defense against enemy attacks.","translation":"城堡厚重的石牆有效地防禦了敵人的攻擊。"}},"3f374a688095ffdaed2d15112892f6a3":{"crea