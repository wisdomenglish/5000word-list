:{"sentence":"The new software update will eliminate the bugs that have been causing problems for users.","translation":"新的軟體更新將消除一直困擾使用者的那些錯誤。"}},"dcb88ae02f0d3d4e3431a205f6407c1a":{"createdAt":1781366166565,"data":{"sentence":"I took the elevator to the tenth floor instead of climbing the stairs.","translation":"我搭電梯上到十樓，而不是爬樓梯。"}},"dd3e8e2e49932e76507d80eeaef0244c":{"createdAt":1781414403168,"data":{"sentence":"The principal decided to suspend the student for two weeks due to his repeated misconduct.","translation":"校長決定因為那名學生的反覆不當行為而停職他兩週。"}},"dd5b638a5c2bc81feed27a6d69c4f801":{"createdAt":1781337582872,"data":{"sentence":"The chemistry students conducted their experiments in the lab after school.","translation":"化學學生們放學後在實驗室進行了他們的實驗。"}},"dd6cfe4decb8db00cb7c5509e710cc4a":{"createdAt":1781278975655,"data":{"sentence":"The family was in great distress after hearing the news of the accident.","translation":"聽到事故的消息後，這個家庭陷入了極大的痛苦之中。"}},"df172860d639cffe3caa7f7d0e76b5cc":{"createdAt":1781325478763,"data":{"sentence":"The impact was so severe that it fractured the bone in three different places.","translation":"撞擊非常嚴重，導致骨頭在三個不同的地方斷裂。"}},"e0ab699ecc18368744dbb1ec4c3a42dc":{"createdAt":1781413374302,"data":{"sentence":"The artist spent months refining her technique to create more elegant and sophisticated paintings.","translation":"這位藝術家花了幾個月的時間來改善她的技巧，以創作更優雅和精緻的繪畫作品。"}},"e140d081937dc12052c5d023b772a3b7":{"createdAt":1781368003991,"data":{"sentence":"The architect could envision a beautiful modern building on that empty lot.","translation":"建築師能夠想像在那塊空地上建造一棟美麗的現代建築。"}},"e29e6860c36a7ce03f19a32d6f3b61c8":{"createdAt":1781368323252,"data":{"sentence":"A bachelor's degree from this university is equivalent to a master's degree from many other institutions.","translation":"這所大學的學士學位相當於許多其他機構的碩士學位。"}},"e447d9f94980adba10e411b2294e151d":{"createdAt":1781325364911,"data":{"sentence":"Let's flip a coin to decide who goes first.","translation":"我們擲硬幣來決定誰先去吧。"}},"e4655ecd19f21b9fe6a03513a4f341a3":{"createdAt":1781368261037,"data":{"sentence":"The gym has state-of-the-art equipment that helps members achieve their fitness goals.","translation":"這家健身房擁有最先進的設備，幫助會員達成他們的健身目標。"}},"e5f6c57d8ad86eec8742b5cef920ae85":{"createdAt":1781278660262,"data":{"sentence":"He tried to deceive his parents by pretending he had finished his homework.","translation":"他假裝已經完成功課，試圖欺騙他的父母。"}},"e69399630744ef7815b5da3a6a1ffcb2":{"createdAt":1781415485410,"data":{"sentence":"She was eligibly qualified for the scholarship because she met all the academic requirements.","translation":"她符合獲得獎學金的資格，因為她滿足了所有的學術要求。"}},"e76892a2876b94561029205e4d774508":{"createdAt":1781276293348,"data":{"sentence":"After failing the exam twice, she felt discouraged and almost gave up on her studies.","translation":"在考試失敗兩次後，她感到沮喪，幾乎要放棄學業。"}},"e8d23010727d7019acb4d3ef28d29c0b":{"createdAt":1781341742901,"data":{"sentence":"With dark clouds gathering overhead and the wind picking up, a storm is imminent.","translation":"隨著烏雲密佈天空和風力增強，暴風雨即將來臨。"}},"ef718141dc1d172d857bddfd04b36226":{"createdAt":1781278777730,"data":{"sentence":"She had a distinguished career as a renowned surgeon, earning respect from colleagues around the world.","translation":"她作為一名著名外科醫生擁有卓越的職業生涯，贏得了世界各地同事的尊敬。"}},"ef852d241a06af4fced420dc0b6e8a27":{"createdAt":1781278701582,"data":{"sentence":"The restaurant has a distinctive style that sets it apart from all the other Italian places in the city.","translation":"這家餐廳有一種獨特的風格，使其在城市中的所有意大利餐廳中脫穎而出。"}},"f108e6e6b208d539ff46328a19a1f2d4":{"createdAt":1781272597662,"data":{"sentence":"The judge decided fairly between the two parties, ensuring that both sides were treated with equal consideration.","translation":"法官在兩方當事人之間做出了公正的裁決，確保雙方都受到平等對待。"}},"f1201abf1a269cb923618f8da7e17ecd":{"createdAt":1781278390894,"data":{"sentence":"The jolly old man laughed heartily as he distributed presents to all the children at Christmas.","translation":"那位快活的老人在聖誕節時開懷大笑，向所有的孩子們分發禮物。"}},"f344c97ffbdd03625d9e32e6ed2a889d":{"createdAt":1781414388474,"data":{"sentence":"She works at the Federal Bureau of Investigation as a criminal analyst.","translation":"她在聯邦調查局擔任犯罪分析師。"}},"f452e8069e735a4c8fbed3aead04fa28":{"createdAt":1781366761256,"data":{"sentence":"The teacher placed great emphasis on the importance of regular practice when learning a new language.","translation":"老師在教導學習新語言時，特別強調定期練習的重要性。"}},"f456da8927e294f9de7397effaf45c2f":{"createdAt":1781337607200,"data":{"sentence":"It was not my fault that the project failed; the deadline was unrealistic from the start.","translation":"專案失敗不是我的過錯；從一開始截止日期就不切實際。"}},"f4e1a40f64dd8a68fae95255f6dc7c27":{"createdAt":1781278836761,"data":{"sentence":"The loud noise from the construction site began to distract me from my work.","translation":"來自建築工地的巨大噪音開始分散我對工作的注意力。"}},"f58cf7269f749e79c913b68d67523224":{"createdAt":1781256766498,"data":{"sentence":"I opened a new bank account to save money for my vacation.","translation":"我開了一個新的銀行帳戶來為我的假期存錢。"}},"f688656af73e379a3339af8f1e91b6e8":{"createdAt":1781280660141,"data":{"sentence":"The company decided to diversify its product line by expanding into new markets and offering services beyond its traditional offerings.","translation":"該公司決定通過擴展到新市場並提供超越其傳統業務範圍的服務來實現產品線的多樣化。"}},"f68d2058d96aeae4fde5445074648ec7":{"createdAt":1781278731967,"data":{"sentence":"The new regulations will deprive workers of their right to negotiate wages.","translation":"新法規將剝奪工人談判工資的權利。"}},"f695d505f470d815d0051f6c378e90ee":{"createdAt":1781367588945,"data":{"sentence":"The movie was so entertaining that the audience laughed throughout the entire film.","translation":"那部電影非常娛樂性十足，觀眾在整部影片中都在笑。"}},"f8bf7d1e556be3a5dac96cd0684c91f5":{"createdAt":1781365931262,"data":{"sentence":"The electric power plant supplies electricity to the entire city.","translation":"這座發電廠為整個城市供應電力。"}},"f967a4cdb114fb5a1326d59f944769cb":{"createdAt":1781368257613,"data":{"sentence":"The new hospital was equipped with state-of-the-art medical technology to better serve patients.","translation":"這家新醫院配備了最先進的醫療技術，以便更好地服務患者。"}},"fa88f2b4008bc3b078a3a6e7c95aab2d":{"createdAt":1781365481487,"data":{"sentence":"His ego was so fragile that he couldn't accept any criticism from his colleagues.","translation":"他的自尊心非常脆弱，以至於他無法接受同事的任何批評。"}},"faf858c4c4d3e9ed9ee4f27e83082b3e":{"createdAt":1781272324991,"data":{"sentence":"Building a new railway line through the mountains is technically feasible, but it would require significant investment and careful planning.","translation":"在山區修建新的鐵路線在技術上是可行的，但需要大量投資和仔細規劃。"}},"fdbacb704381a8ee43fe917a714b74f9":{"createdAt":1781325915034,"data":{"sentence":"After losing her passport at the airport, she made frantic calls to the airline trying to catch her flight.","translation":"在機場遺失護照後，她瘋狂地撥打航空公司的電話，試圖趕上她的班機。"}},"ff312bb0b13a12319821bf824c8de667":{"createdAt":1781278839687,"data":{"sentence":"The constant notifications on her phone became a major distraction while she was trying to study for her exam.","translation":"她手機上不斷的通知成為了她準備考試時的一大心煩意亂。"}}},"file-search-intents":{"Ucc2288bf1bdfa7b6c2414622c0df2ba4":{"expireAt":1776952398298}},"onedrive-auth":{"folders":{"admin":{"driveId":"ED0685DFF9D8666E","itemId":"ED0685DFF9D8666E!44098","name":"Wisdom English 唯思英文","path":"/drives/ED0685DFF9D8666E/root:/Wisdom English 唯思英文","url":"https://1drv.ms/f/c/ed0685dff9d8666e/IgBuZtj534UGIIDtQqwAAAAAAV2J_orqMl9nG5riCaVAVIo?e=JE0eNi"},"shared":{"driveId":"ED0685DFF9D8666E","itemId":"ED0685DFF9D8666E!44100","name":"#團隊事項","path":"/drives/ED0685DFF9D8666E/root:/Wisdom English 唯思英文/#團隊事項","url":"https://1drv.ms/f/c/ed0685dff9d8666e/IgBuZtj534UGIIDtRKwAAAAAAUoMQOQ4c1iafODy-Wz-ISc?e=VLgQDG"}},"refreshToken":"M.C547_BL2.0.U.-Clv0SUBbj5DLJX!57r2*cOod*nmmEuAKV9Fqa0NLVdOGpA82rTiyQx84YcQ8mSdvEM8ynRYbCHDYs24Uwsje92M!olEMHcm0hPNSLo56vNePrAcqA9AW06kr4wr4bSDS94pjgGZa2HNFbJEXFjmV2RHf*9wV4lMh!ZVmWI8s7z1wjV2sAC8dhPVnL*01sJAAKLJgLoeHZMBsmGoakjTAd!K3wceGrn7BavFeea9EgFlnWIkTFF9DKs7cZMLRFfesnmCPyfrMj2UEMS3CCNj0Xzld6jumyk23oBmq5R2ZteHxgUwCfe*0EKDU2pb6Qvz*DvFIKYjOFAIzsWh!vI9mZftUeiRX4S4N73vn9n6A6vvESqqjs25TbLdZxVPkdUPU4Q$$","savedAt":1776994065013},"published":{"article":"The High-Stakes Confrontation: Trump and Iran\nThe geopolitical tension between Donald Trump and Iran remains one of the most volatile issues in modern international relations. To understand the origins of this conflict, we must examine the 2015 Iran Nuclear Deal (JCPOA). While the Obama administration viewed the deal as a diplomatic breakthrough to prevent Iran from developing nuclear weapons, Trump campaigned against it, calling it \"the worst deal ever negotiated.\" He argued that the agreement was fundamentally flawed because it failed to address Iran’s ballistic missile program and its support for various proxy groups across the Middle East.\n\nIn May 2018, the situation reached a critical turning point when Trump officially withdrew the United States from the nuclear deal. This move initiated a strategy known as the \"Maximum Pressure\" campaign. The primary objective was to cripple Iran’s economy through heavy sanctions, specifically targeting their oil exports—the nation's economic lifeline. By cutting off Iran's primary source of revenue, Trump aimed to force the Iranian leadership back to the negotiating table to sign a much stricter, more comprehensive \"grand bargain.\"\n\nThe process of escalation moved rapidly from economic warfare to direct military confrontation. In 2019, tensions spiked after several oil tankers were attacked in the Strait of Hormuz, and Iran shot down a high-tech U.S. surveillance drone. However, the most significant moment occurred in January 2020, when Trump authorized a drone strike that killed the powerful Iranian General Qasem Soleimani in Baghdad. This targeted killing brought both nations to the very brink of a full-scale war. Iran responded by launching ballistic missiles at U.S. bases in Iraq, though both sides eventually stepped back to avoid a total catastrophe.\n\nCurrently, with Trump’s return to office in 2026, the strategy remains focused on strategic containment. While the military threat is always present, Trump’s approach often involves a unique blend of extreme rhetoric and the possibility of high-level diplomacy. He frequently oscillates between threatening \"obliteration\" and expressing a desire to meet with Iranian leaders to resolve the dispute. As the international community watches closely, the world remains uncertain whether this pressure will lead to a new diplomatic breakthrough or an accidental escalation into a regional conflict. The line between deterrence and open war remains incredibly thin.","articleTitle":"The High-Stakes Confrontation: Trump and Iran","data":{"discussion":[{"q":"Do you think economic sanctions are more effective than military action in resolving international conflicts? Why or why not?","zh":"中文提示：比較經濟制裁與軍事行動的效果和後果"},{"q":"How should world leaders balance between showing strength and pursuing diplomatic solutions when dealing with adversaries?","zh":"中文提示：探討領導人在展現強硬與外交之間的平衡"}],"fill":[{"blanks":["Maximum Pressure","oil"],"sentence":"Trump withdrew from the nuclear deal to initiate a strategy called ___ which targeted Iran's ___ exports.","zh_hint":"中文提示：川普的經濟制裁策略"},{"blanks":["Qasem Soleimani","full-scale war"],"sentence":"The killing of General ___ in January 2020 brought both nations to the brink of ___.","zh_hint":"中文提示：2020年的軍事衝突事件"}],"mcq":[{"ans":1,"explain":"中文解題說明：文中指出川普認為協議未處理飛彈計畫和代理人組織問題","opts":["A. Iran violated the agreement's terms","B. The deal didn't address missiles and proxy groups","C. Obama requested the withdrawal","D. Iran refused to negotiate further"],"q":"Why did Trump withdraw from the Iran Nuclear Deal?"},{"ans":1,"explain":"中文解題說明：目標是透過經濟制裁迫使伊朗重回談判桌並簽署更嚴格協議","opts":["A. To start a military war immediately","B. To force Iran to negotiate a stricter deal","C. To support Iran's economy","D. To help Iran export more oil"],"q":"What was the primary goal of the 'Maximum Pressure' campaign?"},{"ans":2,"explain":"中文解題說明：文中描述川普的策略是極端言論與高層外交可能性的結合","opts":["A. Pure military aggression only","B. Complete diplomatic cooperation","C. A mix of threats and diplomatic possibilities","D. Total withdrawal from the region"],"q":"What characterizes Trump's current approach to Iran?"}],"vocab":[{"pos":"adj.","word":"volatile","zh":"不穩定的；易變的"},{"pos":"n.","word":"diplomatic breakthrough","zh":"外交突破"},{"pos":"adj.","word":"fundamentally flawed","zh":"根本上有缺陷的"},{"pos":"v.","word":"cripple","zh":"削弱；使癱瘓"},{"pos":"n.","word":"escalation","zh":"升級；惡化"},{"pos":"n.","word":"brink","zh":"邊緣"},{"pos":"v.","word":"oscillates","zh":"搖擺；振盪"},{"pos":"n.","word":"deterrence","zh":"威懾；遏制"}]},"fillCount":2,"level":"B2","publishedAt":"2026-03-26T18:31:40.453Z"},"quiz-cache":{"abbreviate":{"createdAt":1781268630478,"q":{"answer":1,"explanation":"abbreviate表示縮寫或簡短，使某事變得更簡潔或更短。","options":["extend","abbreviate","reschedule","postpone"],"sentence":"We decided to ______ the meeting because time was running short. We removed all unnecessary discussions and covered only the essential points.","translation":"因為時間不夠，我們決定縮短會議時間。我們刪除了所有不必要的討論，只涵蓋了要點。","word":"abbreviate"}},"abbreviated":{"createdAt":1781351849565,"q":{"answer":2,"explanation":"abbreviated 表示「縮寫的、簡稱的」，與「節省時間和空間」的描述完全相符。","options":["extended","expanded","shortened","lengthened"],"sentence":"The ______ form of 'United States of America' is commonly written as 'USA' in official documents. This shorter version saves time and space while maintaining clarity.","translation":"「美利堅合眾國」的縮寫形式在官方文件中通常寫成「美國」。這個較短的版本節省時間和空間，同時保持清晰。","word":"abbreviated"}},"ability":{"createdAt":1781331945987,"q":{"answer":1,"explanation":"ability 指某人擁有的技能或才能，能夠做好某件事情。","options":["weakness","talent","age","costume"],"sentence":"The young pianist demonstrated remarkable ______ during the concert last night. Her technical skill and emotional control impressed even the most experienced music critics in the audience.","translation":"那位年輕鋼琴家在昨晚的音樂會上展現了非凡的才能。她的技術技巧和情感控制給觀眾中最資深的音樂評論家留下了深刻印象。","word":"ability"}},"able":{"createdAt":1781351849564,"q":{"answer":3,"explanation":"able 表示「有能力的」，與「獲得評委讚賞」的背景相符，說明她具備了必要的能力。","options":["unable","willing","nervous","competent"],"sentence":"After years of training, the young pianist was finally ______ to perform at the international competition. The judges were impressed by her technical skill and musical interpretation.","translation":"經過多年的訓練，年輕鋼琴家終於能夠在國際比賽中表演。評委對她的技術技巧和音樂詮釋印象深刻。","word":"able"}},"aboard":{"createdAt":1781351849566,"q":{"answer":1,"explanation":"aboard 表示「在船、飛機、車上」或「搭上」，與「起飛前的最後安全檢查」相符，說明乘客已經上飛機。","options":["outside","inside","away from","near"],"sentence":"All passengers must be ______ the aircraft at least thirty minutes before departure. The flight attendants will then conduct a final safety check before takeoff.","translation":"所有乘客必須在起飛前至少三十分鐘登上飛機。隨後空服員會在起飛前進行最後的安全檢查。","word":"aboard"}},"abolish":{"createdAt":1781227315831,"q":{"answer":1,"explanation":"abolish 的意思是「廢除、廢止」，指完全消除或終止某項法律、制度或習慣，通常用於正式的政治或法律行為。","options":["strengthen","abolish","amend","enforce"],"sentence":"The government voted to ______ the outdated law that had been in effect for over fifty years. After the new policy took effect, citizens no longer had to follow those old regulations.","translation":"政府投票廢除了已實施超過五十年的過時法律。新政策生效後，市民不再需要遵守那些舊規定。","word":"abolish"}},"aboriginal":{"createdAt":1781360906188,"q":{"answer":1,"explanation":"aboriginal 意思是原住民的或原始的，指最早的本土居民及其文化。","options":["modern","aboriginal","imported","contemporary"],"sentence":"The museum exhibits ______ artifacts and artwork from the native peoples of Australia. These pieces date back thousands of years to the earliest inhabitants.","translation":"博物館展示了澳洲土著民族的原住民文物和藝術作品。這些作品可以追溯到最早居民的數千年前。","word":"aboriginal"}},"aborigine":{"createdAt":1781362281647,"q":{"answer":1,"explanation":"aborigine指的是某地的原始居民，特別是澳大利亞的土著人民。","options":["immigrant","aborigine","settler","visitor"],"sentence":"The ______ of Australia have lived on the continent for thousands of years. Their ancient cultures and traditions date back to the earliest inhabitants of the land.","translation":"澳大利亞的原住民已經在這個大陸上生活了數千年。他們古老的文化和傳統可以追溯到這片土地最早的居民。","word":"aborigine"}},"abortion":{"createdAt":1781351849567,"q":{"answer":2,"explanation":"abortion 表示「墮胎」，與「宗教和倫理信仰」的政治辯論背景相符，這是一個具有爭議性的話題。","options":["education","healthcare","pregnancy","reproduction"],"sentence":"The government's new legislation regarding ______ has sparked heated debate among politicians and citizens. Different groups hold strong views based on their religious and ethical beliefs.","translation":"政府關於墮胎的新立法在政治人物和公民之間引發了激烈的辯論。不同的團體根據他們的宗教和倫理信仰持有強烈的觀點。","word":"abortion"}},"abound":{"createdAt":1781351849565,"q":{"answer":2,"explanation":"abound 表示「大量存在、充滿」，與「公司積極招聘」的線索相符，說明機會非常豐富。","options":["disappear","decrease","flourish","diminish"],"sentence":"Excellent job opportunities ______ in the technology sector these days. Companies are actively hiring and competing to attract talented professionals.","translation":"現今科技行業充滿了優質的工作機會。公司正在積極招聘並競爭以吸引有才華的專業人士。","word":"abound"}},"abroad":{"createdAt":1781275226791,"q":{"answer":0,"explanation":"此處abroad作副詞表示「在國外；到國外」，指離開本國到其他國家","options":["abroad","controversial","breast","feast"],"sentence":"She decided to study ______ in France for a full year to improve her language skills. Living in Paris would give her immersion in the French culture and environment.","translation":"她決定在法國國外生活一整年以提高她的語言技能。住在巴黎將使她沉浸在法國文化和環境中。","word":"abroad"}},"abrupt":{"createdAt":1781360906188,"q":{"answer":1,"explanation":"abrupt 意思是突然的或陡峭的，指沒有預警或漸進過程就立即發生的事情。","options":["gradual","abrupt","smooth","expected"],"sentence":"The train made an ______ stop when the brakes were applied suddenly. Passengers were thrown forward without warning.","translation":"當緊急剎車被啟動時，火車突然停止了。乘客在沒有警告的情況下向前衝去。","word":"abrupt"}},"absent":{"createdAt":1781351849563,"q":{"answer":1,"explanation":"absent 在此表示「不注意的、心不在焉的」，與「沒有注意演講」的線索相符。","options":["present","distracted","bored","quiet"],"sentence":"During the important meeting, Tom appeared to be ______ even though he was sitting at the table. His supervisor noticed he wasn't paying attention to any of the presentations or discussions.","translation":"在重要會議期間，湯姆看起來不在場，儘管他坐在桌子旁。他的主管注意到他沒有注意任何演講或討論。","word":"absent"}},"absolute":{"createdAt":1781351849561,"q":{"answer":1,"explanation":"absolute 表示「完全的、絕對的」，與「需要更多研究」的對比相符，因為絕對陳述會排除進一步研究的需要。","options":["tentative","definitive","temporary","preliminary"],"sentence":"The scientist refused to make an ______ statement about the new discovery without more evidence. She explained that further research would be necessary before confirming anything with certainty.","translation":"科學家拒絕在沒有更多證據的情況下對新發現做出絕對的陳述。她解釋說在以確定性確認任何事情之前需要進一步的研究。","word":"absolute"}},"absorb":{"createdAt":1781360906182,"q":{"answer":1,"explanation":"absorb 意思是吸收或理解，這裡用來描述海綿吸收水分的能力。","options":["release","absorb","pour","spill"],"sentence":"The sponge can ______ large amounts of water. When you squeeze it, all the liquid comes back out.","translation":"海綿可以吸收大量的水。當你擠它時，所有的液體都會流出來。","word":"absorb"}},"absorption":{"createdAt":1781360885490,"q":{"answer":1,"explanation":"absorption在商業中指一個公司被另一個公司吞併或合併，成為更大企業的一部分。","options":["rejection","absorption","separation","division"],"sentence":"The ______ of the smaller company by the larger corporation was completed last year. The two businesses are now operating as a single unified entity.","translation":"較小公司被較大公司的並購去年完成。這兩家業務現在作為一個統一的實體運營。","word":"absorption"}},"abstract":{"createdAt":1781336858156,"q":{"answer":2,"explanation":"abstract 形容詞表示不具體、不以真實物體為基礎，而是基於概念或想象的事物，尤其在藝術中常見。","options":["realistic","concrete","abstract","literal"],"sentence":"The ______ painting confused many visitors at the modern art museum. Without recognizable objects or clear representations, viewers had to use their imagination to interpret its meaning.","translation":"這幅抽象畫在現代藝術博物館中令許多訪客感到困惑。沒有可識別的物體或清晰的表現形式，觀眾必須使用想像力來解釋其意義。","word":"abstract"}},"absurd":{"createdAt":1781351849562,"q":{"answer":1,"explanation":"absurd 表示「荒唐的、不合理的」，與愚人節玩笑的背景完全相符。","options":["reasonable","ridiculous","practical","sensible"],"sentence":"The proposal to ban all bicycles from the city seemed ______ to most citizens. However, the mayor explained it was a joke made during the April Fools' Day announcement.","translation":"禁止所有自行車進入城市的提議對大多數市民來說似乎是荒唐的。不過，市長解釋說這是在愚人節公告期間開的玩笑。","word":"absurd"}},"abuse":{"createdAt":1781351849557,"q":{"answer":1,"explanation":"abuse 作為動詞表示「虐待、濫用、辱罵」，與造成傷害和創傷的背景相符。","options":["praise","mistreat","train","encourage"],"sentence":"The coach was fired for his decision to ______ young athletes during training sessions. The investigation revealed physical harm and emotional trauma inflicted on the team members.","translation":"那位教練因在訓練期間對年輕運動員的虐待而被解僱。調查揭露了對隊員造成的身體傷害和情感創傷。","word":"abuse"}},"accelerated":{"createdAt":1781360906190,"q":{"answer":1,"explanation":"accelerated 意思是加速的或促進的，指速度或進度增加的過程。","options":["standard","accelerated","delayed","normal"],"sentence":"The ______ program allows gifted students to complete their studies faster than usual. These students advance through the curriculum at twice the normal pace.","translation":"加速課程允許天才學生比平常更快地完成他們的學習。這些學生以兩倍的正常速度推進課程。","word":"accelerated"}},"accessible":{"createdAt":1781360906189,"q":{"answer":1,"explanation":"accessible 意思是易接近的或易取得的，指可以方便地到達或使用。","options":["isolated","accessible","restricted","remote"],"sentence":"The new library is very ______ to students with disabilities. The building has ramps, elevators, and specialized facilities for everyone.","translation":"新圖書館對有殘疾的學生非常容易接近。該建築為每個人配備了斜坡、電梯和專業設施。","word":"accessible"}},"accessory":{"createdAt":1781256485494,"q":{"answer":1,"explanation":"accessory指的是附件或配件，用來完善或裝飾主要物品","options":["weapon","accessory","vehicle","ingredient"],"sentence":"The leather belt was the perfect ______ to complete her outfit. It matched well with her jacket and shoes.","translation":"這條皮帶是完成她服裝搭配的完美配件。它與她的夾克和鞋子搭配得很好。","word":"accessory"}},"acclaim":{"createdAt":1781360906190,"q":{"answer":1,"explanation":"acclaim 意思是讚揚或公開的稱譽，指公眾對某人成就的認可和歡迎。","options":["criticism","acclaim","rejection","complaint"],"sentence":"The actor received ______ from critics and audiences for his powerful performance. Newspapers praised his outstanding talent and dedication.","translation":"該演員因其強大的表演而獲得了評論家和觀眾的讚揚。報紙讚揚了他傑出的才華和奉獻精神。","word":"acclaim"}},"accomplish":{"createdAt":1781360906183,"q":{"answer":1,"explanation":"accomplish 意思是完成或達成，強調成功地實現了目標。","options":["attempt","accomplish","ignore","abandon"],"sentence":"She worked hard to ______ her goal of finishing the marathon. By crossing the finish line, she proved her determination.","translation":"她努力工作以完成馬拉松的目標。通過衝過終點線，她證明了她的決心。","word":"accomplish"}},"accomplishment":{"createdAt":1781360885487,"q":{"answer":1,"explanation":"accomplishment指成功完成的事情，通常需要努力和技能，令人感到自豪。","options":["failure","accomplishment","setback","delay"],"sentence":"Graduating from university was a major ______ for her family. It represented years of hard work and dedication to education.","translation":"從大學畢業是她家族的重大成就。這代表了多年來對教育的努力和奉獻。","word":"accomplishment"}},"accountable":{"createdAt":1781360885486,"q":{"answer":1,"explanation":"accountable表示必須對自己的行為或決定承擔責任，並可以被要求解釋或說明。","options":["irresponsible","accountable","unaware","innocent"],"sentence":"The manager is ______ for all the mistakes made by his team members. He must explain to the director why the project failed.","translation":"經理對他的團隊成員所犯的所有錯誤負責。他必須向主管解釋該項目為什麼失敗。","word":"accountable"}},"accountant":{"createdAt":1781360885497,"q":{"answer":1,"explanation":"accountant是指專門從事會計工作的專業人士，負責管理和審計財務記錄。","options":["lawyer","accountant","engineer","designer"],"sentence":"The company hired an experienced ______ to manage their financial records and taxes. She will prepare financial statements and ensure all accounts are balanced correctly.","translation":"公司聘請了一位經驗豐富的會計師來管理他們的財務記錄和稅務。她將準備財務報表並確保所有帳戶平衡正確。","word":"accountant"}},"accurate":{"createdAt":1781360885491,"q":{"answer":1,"explanation":"accurate指信息、測量或預測非常準確，沒有或很少有誤差。","options":["vague","accurate","misleading","approximate"],"sentence":"The weather forecast was ______ and predicted the storm within an hour. The meteorologists had correctly identified the exact time and location of the rainfall.","translation":"天氣預報是準確的，並在一小時內預測了風暴。氣象學家準確地確定了降雨的確切時間和地點。","word":"accurate"}},"accusation":{"createdAt":1781360885493,"q":{"answer":1,"explanation":"accusation指指控某人犯罪或做錯事，通常需要有證據來支持。","options":["praise","accusation","compliment","support"],"sentence":"The ______ against the politician was made by several witnesses who claimed to have evidence. However, the charges were later proven false.","translation":"對政治家的控訴是由幾位聲稱擁有證據的證人提出的。但是，這些指控後來被證明是虛假的。","word":"accusation"}},"accuse":{"createdAt":1781337343696,"q":{"answer":1,"explanation":"accuse意為指控或控告某人犯了某種過錯或罪行。","options":["praise","accuse","invite","assist"],"sentence":"The detective decided to ______ the suspect of stealing the priceless painting from the museum. However, security footage later proved the suspect's innocence.","translation":"偵探決定指控嫌疑人從博物館竊取了無價的畫作。然而，監控錄影後來證明了嫌疑人的清白。","word":"accuse"}},"acidity":{"createdAt":1781417610416,"q":{"answer":2,"explanation":"acidity是指物質所含的酸性或酸度，在飲食中特別指酸味的強度。","options":["sweetness","texture","acidity","aroma"],"sentence":"The ______ of the vinegar made it unsuitable for use in the delicate recipe. The chef needed to dilute it significantly because the sourness would overpower all other flavors.","translation":"醋的酸性使其不適合用於這個精緻的食譜。廚師需要大量稀釋它，因為這種酸味會蓋過所有其他的味道。","word":"acidity"}},"acne":{"createdAt":1781395428239,"q":{"answer":1,"explanation":"acne 是一種皮膚疾病，特徵是出現粉刺、丘疹和黑頭，通常在青春期出現。","options":["eczema","acne","psoriasis","melanoma"],"sentence":"Many teenagers struggle with ______ during puberty due to hormonal changes. This skin condition causes inflamed pimples and blemishes primarily on the face and chest.","translation":"許多青少年在青春期因激素變化而與粉刺作鬥爭。這種皮膚狀況主要在臉部和胸部引起發炎的粉刺和瑕疵。","word":"acne"}},"acquainted":{"createdAt":1781360906184,"q":{"answer":1,"explanation":"acquainted 意思是相識的或熟悉的，表示對某人或某事有基本的了解。","options":["separated","acquainted","confused","estranged"],"sentence":"Before the project started, the team members became ______ with each other. They attended a meeting where they introduced themselves and shared their backgrounds.","translation":"在項目開始前，團隊成員彼此熟悉了。他們參加了一次會議，在會議上相互介紹並分享了他們的背景。","word":"acquainted"}},"acre":{"createdAt":1781256547736,"q":{"answer":1,"explanation":"Acre是一個面積測量單位，常用於測量土地面積，特別是在英美地區。","options":["meter","acre","pound","minute"],"sentence":"The farmer owns 50 ______ of fertile land in the countryside. This vast property provides enough space for growing crops, raising cattle, and maintaining various farm buildings.","translation":"這位農民在鄉間擁有50英畝的肥沃土地。這片廣大的地產提供了足夠的空間來種植作物、飼養牲畜和維護各種農舍。","word":"acre"}},"activist":{"createdAt":1781395428237,"q":{"answer":1,"explanation":"activist 指積極推動社會或政治變革的人，強調主動採取行動。","options":["observer","activist","politician","journalist"],"sentence":"Sarah is a passionate environmental ______ who organizes protests against pollution. She dedicates her time to taking direct action and promoting change in her community.","translation":"莎拉是一位熱情的環境積極分子，她組織抗議污染的遊行活動。她致力於採取直接行動並推動社區的改變。","word":"activist"}},"actual":{"createdAt":1781360906183,"q":{"answer":1,"explanation":"actual 意思是實際的或真實的，指的是真正發生或存在的情況。","options":["projected","actual","assumed","theoretical"],"sentence":"The ______ cost of the project was higher than the estimate. The accountant showed us the real expenses in the final report.","translation":"該項目的實際成本高於估計。會計師在最終報告中向我們展示了真實費用。","word":"actual"}},"adapt":{"createdAt":1781360885490,"q":{"answer":1,"explanation":"adapt指改變或調整某物以適應新的條件或用途，通常涉及修改而非完全改變。","options":["ignored","adapted","rejected","abandoned"],"sentence":"The novel was ______ into a successful film that won several awards. The screenplay captured the essence of the original story while making changes for cinema.","translation":"這部小說被改編成了一部獲得多個獎項的成功電影。劇本抓住了原始故事的精髓，同時為電影做出了改變。","word":"adapt"}},"adjustment":{"createdAt":1781360885490,"q":{"answer":1,"explanation":"adjustment指為了適應新環境或情況而進行的改變或調整，通常需要一段時間。","options":["rejection","adjustment","resistance","refusal"],"sentence":"After moving to a new country, she needed time for ______ to the different culture and lifestyle. Within six months, she had made significant changes to her daily routines.","translation":"搬到新國家後，她需要時間來適應不同的文化和生活方式。在六個月內，她對日常生活做出了重大改變。","word":"adjustment"}},"administer":{"createdAt":1781360885497,"q":{"answer":1,"explanation":"administer指提供或施放藥物、測試或管理某項服務，通常由授權人員進行。","options":["refuse","administer","deny","withhold"],"sentence":"The nurse will ______ the vaccine to all the children at the health center this morning. The medical staff has prepared everything needed for the immunization program.","translation":"護士今早將在衛生中心向所有兒童施打疫苗。醫療人員已為免疫接種計劃準備好了一切所需物品。","word":"administer"}},"administrative":{"createdAt":1781360885488,"q":{"answer":1,"explanation":"administrative與管理和組織相關，特別是涉及辦公室工作和官方程序的工作。","options":["creative","administrative","technical","marketing"],"sentence":"The ______ staff handles all the paperwork and scheduling for the company. They manage office operations, files, and coordinate meetings.","translation":"行政人員處理公司的所有文書工作和日程安排。他們管理辦公室運營、文件並協調會議。","word":"administrative"}},"admiration":{"createdAt":1781360906186,"q":{"answer":1,"explanation":"admiration 意思是欽佩或讚賞，表示對某人的成就或品質的高度評價。","options":["criticism","admiration","jealousy","indifference"],"sentence":"The young athlete earned the ______ of millions of fans worldwide. People respected his dedication and outstanding performance in the sport.","translation":"這位年輕運動員贏得了全球數百萬粉絲的欽佩。人們尊敬他在運動中的奉獻精神和傑出表現。","word":"admiration"}},"admire":{"createdAt":1781360885492,"q":{"answer":1,"explanation":"admire指對某人的品質、成就或行為表達敬佩和讚美之情。","options":["despise","admire","ignore","criticize"],"sentence":"I ______ my grandmother for her courage and wisdom throughout her life. She faced many challenges with grace and dignity.","translation":"我欽佩我祖母在整個人生中的勇氣和智慧。她以優雅和尊嚴面對了許多挑戰。","word":"admire"}},"adoption":{"createdAt":1781360906185,"q":{"answer":1,"explanation":"adoption 意思是採用或接納，表示接受並開始使用或實施某事。","options":["rejection","adoption","avoidance","criticism"],"sentence":"The ______ of new technology improved the company's efficiency. The management team decided to implement the latest software system.","translation":"新技術的採用提高了公司的效率。管理團隊決定實施最新的軟體系統。","word":"adoption"}},"adore":{"createdAt":1781360906186,"q":{"answer":1,"explanation":"adore 意思是熱愛或崇拜，表示非常喜歡和珍視某人或某物。","options":["avoid","adore","ignore","hate"],"sentence":"The children absolutely ______ the theme park and visit it every summer. They cannot wait to ride the roller coasters and enjoy the attractions.","translation":"孩子們非常熱愛主題公園，每年夏天都去參觀。他們迫不及待地想乘坐過山車並享受各種景點。","word":"adore"}},"advantage":{"createdAt":1781360885493,"q":{"answer":1,"explanation":"advantage指比他人更有利的條件或優勢，有助於達成目標。","options":["disadvantage","advantage","liability","burden"],"sentence":"Speaking multiple languages gives her a significant ______ in her career. She can communicate with clients from different countries and access more job opportunities.","translation":"說多種語言在她的職業生涯中給了她顯著的優勢。她可以與來自不同國家的客戶溝通，並獲得更多工作機會。","word":"advantage"}},"adverse":{"createdAt":1781256485491,"q":{"answer":1,"explanation":"adverse表示不利的、有害的或相反的影響","options":["positive","adverse","neutral","minor"],"sentence":"The storm had ______ effects on the harvest. Farmers lost most of their crops due to the heavy rain and strong winds.","translation":"這場暴風雨對收穫產生了不利影響。由於大雨和強風，農民損失了大部分莊稼。","word":"adverse"}},"adviser":{"createdAt":1781360906187,"q":{"answer":1,"explanation":"adviser 意思是顧問，指提供專業意見和指導的人。","options":["student","adviser","customer","employee"],"sentence":"The financial ______ helped the family plan their investments wisely. His expert recommendations saved them thousands of dollars.","translation":"財務顧問幫助家庭明智地規劃他們的投資。他的專家建議為他們節省了數千美元。","word":"adviser"}},"advisory":{"createdAt":1781360906185,"q":{"answer":1,"explanation":"advisory 意思是給予建議的或諮詢性的，用來描述提供指導和意見的角色。","options":["mandatory","advisory","executive","administrative"],"sentence":"The company hired an ______ board to provide guidance on business strategy. These experts met monthly to offer recommendations and feedback.","translation":"公司聘請了一個諮詢委員會來提供商業策略指導。這些專家每月開會提供建議和反饋。","word":"advisory"}},"aesthetic":{"createdAt":1781362281666,"q":{"answer":1,"explanation":"aesthetic與美感、藝術價值相關，強調事物的視覺美感和藝術性。","options":["practical","aesthetic","structural","functional"],"sentence":"The ______ design of the building combines beauty with functionality. The architect paid careful attention to visual appeal and artistic elements.","translation":"這棟建築的美感設計結合了美感和功能性。建築師仔細注意視覺吸引力和藝術元素。","word":"aesthetic"}},"affair":{"createdAt":1781256485493,"q":{"answer":1,"explanation":"affair指的是重要的或引起公眾注意的事件或事情","options":["hobby","affair","game","sport"],"sentence":"The scandal became a major international ______ when the government's corruption was exposed. News outlets worldwide reported on the shocking revelations for months.","translation":"當政府的腐敗行為被揭露時，這個醜聞成為了一樁重大的國際事件。世界各地的新聞媒體數月來都在報導這些令人震驚的揭露。","word":"affair"}},"affiliate":{"createdAt":1781360906192,"q":{"answer":1,"explanation":"affiliate 意思是附屬機構或分支機構，指與更大組織相關聯的較小業務單位。","options":["competitor","affiliate","subsidiary","partner"],"sentence":"The small bookstore is an ______ of the larger national chain. It operates under the same brand name and follows the company's policies.","translation":"這家小書店是更大的全國連鎖店的分支機構。它在相同的品牌名稱下運營並遵循公司的政策。","word":"affiliate"}},"agent":{"createdAt":1781360906189,"q":{"answer":1,"explanation":"agent 意思是代理人或經紀人，指代表他人進行交易或談判的人。","options":["architect","agent","tenant","inspector"],"sentence":"The real estate ______ showed us several houses in the neighborhood. She had years of experience helping buyers find their perfect homes.","translation":"房地產經紀人向我們展示了附近的幾所房屋。她有多年幫助買家找到完美家園的經驗。","word":"agent"}},"aggression":{"createdAt":1781360885489,"q":{"answer":1,"explanation":"aggression指主動的敵對行為或攻擊，通常帶有暴力或對抗的意圖。","options":["cooperation","aggression","friendship","alliance"],"sentence":"The country's ______ toward its neighbor led to military conflict. Troops were sent across the border without warning or declaration of war.","translation":"該國對鄰國的侵略導致了軍事衝突。部隊未經警告或宣戰就被派過邊境。","word":"aggression"}},"agreeable":{"createdAt":1781336858148,"q":{"answer":2,"explanation":"agreeable 形容某事令人愉悅、宜人或令人滿意，通常指天氣、情況或他人的舉止。","options":["terrible","harsh","agreeable","stormy"],"sentence":"The weather was ______ and perfect for the outdoor wedding ceremony. Everyone enjoyed the mild temperature and clear blue sky throughout the entire event.","translation":"天氣令人愉悅且完美適合戶外婚禮儀式。在整個活動中，每個人都享受了溫和的溫度和晴朗的藍天。","word":"agreeable"}},"agreement":{"createdAt":1781360906196,"q":{"answer":1,"explanation":"agreement 意思是同意或協議，表示兩個或更多當事人對某事達成共識。","options":["disagreement","agreement","conflict","dispute"],"sentence":"After hours of negotiation, both parties reached an ______ on the contract terms. They signed the document, confirming their mutual consent.","translation":"經過數小時的談判後，雙方在合同條款上達成了一致。他們簽署了文件，確認了相互同意。","word":"agreement"}},"agriculture":{"createdAt":1781360885496,"q":{"answer":1,"explanation":"agriculture是指農業及相關的耕作和種植活動，是許多國家的主要經濟產業。","options":["manufacturing","agriculture","technology","tourism"],"sentence":"The country's economy heavily depends on ______ as most of the population works in farming. They grow crops like rice, wheat, and corn for both domestic use and export.","translation":"該國經濟主要依靠農業，因為大部分人口從事農業工作。他們種植水稻、小麥和玉米供國內使用和出口。","word":"agriculture"}},"air_conditioned":{"createdAt":1781360906192,"q":{"answer":1,"explanation":"air-conditioned 意思是安裝了空調設備的，指通過人工製冷系統控制室內溫度。","options":["heated","air-conditioned","ventilated","decorated"],"sentence":"The office building is fully ______, making it comfortable during hot summers. Employees can work in a cool environment regardless of the weather outside.","translation":"辦公樓配有完整的空調設備，在炎熱的夏天使其舒適。無論外面天氣如何，員工都可以在涼爽的環境中工作。","word":"air-conditioned"}},"aircraft":{"createdAt":1781360885498,"q":{"answer":1,"explanation":"aircraft是指所有能夠飛行的運輸工具，包括飛機、直升機等，用於運輸人員和貨物。","options":["boat","aircraft","train","car"],"sentence":"The ______ took off from the runway at exactly 8 AM and headed toward its destination. Hundreds of passengers were on board the commercial flight.","translation":"飛機在上午8點整從跑道起飛，前往目的地。商業航班上有數百名乘客。","word":"aircraft"}},"alert":{"createdAt":1781395428238,"q":{"answer":1,"explanation":"alert 作為動詞表示提醒或警告某人注意潛在的危險或重要信息。","options":["ignore","alert","confuse","discourage"],"sentence":"The security system will ______ the guards immediately if any suspicious activity is detected. They must stay vigilant and ready to respond within seconds.","translation":"如果偵測到任何可疑活動，安全系統將立即警告警衛。他們必須保持警覺，準備在幾秒內做出反應。","word":"alert"}},"alienate":{"createdAt":1781395428240,"q":{"answer":1,"explanation":"alienate 表示使某人感到被孤立、不被接納或與他人產生距離和敵對感。","options":["attract","alienate","motivate","reward"],"sentence":"The company's unpopular decision to raise prices will likely ______ many loyal customers. Those long-time supporters now feel unvalued and may switch to competitors.","translation":"公司提高價格的不受歡迎決定可能會使許多忠實客戶疏遠。那些長期支持者現在感到被低估，可能會轉向競爭對手。","word":"alienate"}},"alienated":{"createdAt":1781360885486,"q":{"answer":1,"explanation":"alienated表示被隔絕或與他人產生隔閡，導致關係破裂或感到被排斥。","options":["connected","alienated","devoted","attached"],"sentence":"After the argument, John felt ______ from his best friend. They didn't speak for months and grew distant from each other.","translation":"爭執後，約翰感到與他最好的朋友疏遠了。他們好幾個月沒有說話，彼此漸漸變得陌生。","word":"alienated"}},"alliance":{"createdAt":1781256547735,"q":{"answer":1,"explanation":"Alliance表示兩個或多個國家、組織或人之間的聯盟或合作關係，通常是為了達成共同目標。","options":["competition","alliance","dispute","separation"],"sentence":"The two countries formed a strong ______ to face their common enemies. This partnership allowed them to combine their military forces and resources.","translation":"兩個國家形成了一個強大的聯盟來面對他們的共同敵人。這種夥伴關係使他們能夠合併他們的軍事力量和資源。","word":"alliance"}},"ally":{"createdAt":1781360885494,"q":{"answer":1,"explanation":"ally指在戰爭、政治或商業中與自己站在同一邊的國家或人，提供支持與合作。","options":["enemy","ally","rival","competitor"],"sentence":"During the war, France was Britain's most important ______ in the fight against the enemy. The two nations worked together and supported each other militarily.","translation":"戰爭期間，法國是英國在對抗敵人中最重要的盟友。兩個國家一起工作並在軍事上相互支持。","word":"ally"}},"alternate":{"createdAt":1781311922066,"q":{"answer":1,"explanation":"alternate 表示兩個或多個事物輪流出現或交替進行。","options":["compete","alternate","rest","sprint"],"sentence":"In the relay race, runners must ______ positions every 400 meters to give each teammate a turn. The coach organized the schedule so that person A runs, then person B, then person A again.","translation":"在接力賽中，跑步者必須每400公尺交替位置以讓每個隊友輪流參賽。教練安排時間表使得甲先跑，然後乙跑，接著甲再跑。","word":"alternate"}},"altitude":{"createdAt":1781360906189,"q":{"answer":1,"explanation":"altitude 意思是高度或海拔，指物體或地點相對於海平面的垂直距離。","options":["speed","altitude","direction","distance"],"sentence":"As the airplane climbed higher, the ______ increased and the outside temperature dropped. The pilot reported they had reached 35,000 feet.","translation":"當飛機攀升得更高時，高度增加了，外部溫度下降了。飛行員報告他們已經達到了35,000英尺。","word":"altitude"}},"aluminium":{"createdAt":1781360906184,"q":{"answer":1,"explanation":"aluminium 是輕金屬，具有良好的可回收性，廣泛應用於工業。","options":["Iron","Aluminium","Gold","Copper"],"sentence":"This lightweight metal can be recycled many times. ______ is commonly used in beverage cans and aircraft parts.","translation":"這種輕金屬可以多次回收。鋁通常用於飲料罐和飛機零件。","word":"aluminium"}},"ambassador":{"createdAt":1781360906185,"q":{"answer":1,"explanation":"ambassador 意思是大使或使節，是由政府派遣的官方代表。","options":["journalist","ambassador","tourist","athlete"],"sentence":"The ______ represented her country at the international conference. She had been appointed by the government to serve as their official delegate.","translation":"大使在國際會議上代表她的國家。她被政府任命為官方代表。","word":"ambassador"}},"ambiguous":{"createdAt":1781360885495,"q":{"answer":1,"explanation":"ambiguous指表達不清楚或可能有多種解釋的，容易造成誤解。","options":["clear","ambiguous","detailed","explicit"],"sentence":"The instructions were ______ and left many team members confused about what they should do. Several different interpretations of the requirements were possible.","translation":"這些指示模糊不清，讓許多團隊成員困惑於他們應該做什麼。對要求有幾種不同的解釋是可能的。","word":"ambiguous"}},"ambitious":{"createdAt":1781360885486,"q":{"answer":1,"explanation":"ambitious指擁有強烈的慾望和決心去達成偉大或困難的目標。","options":["lazy","ambitious","modest","indifferent"],"sentence":"She is an ______ young entrepreneur who wants to build a global business empire. By age thirty, she aims to expand her company to fifty countries.","translation":"她是一位有雄心的年輕企業家，想要建立一個全球商業帝國。到三十歲時，她的目標是將公司擴展到五十個國家。","word":"ambitious"}},"analogy":{"createdAt":1781360885487,"q":{"answer":1,"explanation":"analogy是通過比較兩個不同事物之間的相似之處來解釋或理解某個概念的方法。","options":["definition","analogy","fact","summary"],"sentence":"The teacher used an ______ to help students understand the concept. She compared the heart to a pump that moves water through pipes, just as it moves blood through the body.","translation":"老師用類比幫助學生理解這個概念。她將心臟比作一個通過管道泵送水的泵，就像它通過身體泵送血液一樣。","word":"analogy"}},"analytical":{"createdAt":1781360885494,"q":{"answer":1,"explanation":"analytical指擅長分析和檢查信息，通過邏輯思維來解決問題的能力。","options":["emotional","analytical","impulsive","careless"],"sentence":"As an ______ person, she carefully examines all the data before making a decision. She breaks down complex problems into smaller parts to understand them better.","translation":"作為一個善於分析的人，她在做決定前仔細檢查所有數據。她將複雜的問題分解成更小的部分以更好地理解它們。","word":"analytical"}},"ancestor":{"createdAt":1781360885485,"q":{"answer":1,"explanation":"祖先指的是過去的世代成員，通常是指父母、祖父母或更早之前的家族成員。","options":["descendant","ancestor","relative","contemporary"],"sentence":"My ______ came to this country over 200 years ago. He was my great-great-grandfather who settled here during the colonial period.","translation":"我的祖先在200多年前來到這個國家。他是我在殖民地時期定居在這裡的曾曾祖父。","word":"ancestor"}},"animated":{"createdAt":1781360906190,"q":{"answer":1,"explanation":"animated 意思是有生命的或充滿活力的，在電影中通常指用動畫技術製作的影片。","options":["documentary","animated","live-action","educational"],"sentence":"The children watched the ______ movie with excitement and laughter. The colorful characters and fun story kept them entertained for two hours.","translation":"孩子們興高采烈地觀看了這部動畫電影。彩色角色和有趣的故事使他們娛樂了兩個小時。","word":"animated"}},"announce":{"createdAt":1781360906186,"q":{"answer":1,"explanation":"announce 意思是宣佈或公開表達，將信息傳達給大眾。","options":["conceal","announce","whisper","ignore"],"sentence":"The principal will ______ the exam results at the assembly tomorrow. Everyone will hear the official declaration during the school gathering.","translation":"校長將在明天的集會上宣佈考試結果。每個人都將在學校集會期間聽到官方聲明。","word":"announce"}},"antibiotic":{"createdAt":1781360885492,"q":{"answer":1,"explanation":"antibiotic是一種藥物，能夠殺死或阻止細菌的生長，用於治療細菌感染。","options":["vitamin","antibiotic","painkiller","vaccine"],"sentence":"The doctor prescribed an ______ to treat the bacterial infection. The medication killed the harmful bacteria and allowed the patient to recover.","translation":"醫生開了一種抗生素來治療細菌感染。該藥物殺死了有害細菌，使患者得以恢復。","word":"antibiotic"}},"anxious":{"createdAt":1781331945985,"q":{"answer":2,"explanation":"anxious 表示對即將發生或未知的事情感到擔心或緊張，常伴隨不安的行為。","options":["excited","bored","anxious","confused"],"sentence":"Sarah felt ______ as she waited for her exam results to be announced. She couldn't sleep the night before and kept checking her phone every few minutes.","translation":"莎拉在等待考試成績宣布時感到焦慮。她前一晚無法入睡，每隔幾分鐘就檢查一次手機。","word":"anxious"}},"anxiously":{"createdAt":1781274836864,"q":{"answer":2,"explanation":"anxiously是副詞，表示以焦慮、擔心或緊張的態度做某事，通常伴隨著不安的情緒。","options":["calmly","happily","anxiously","excitedly"],"sentence":"She waited ______ by the phone for news about her exam results. Her heart pounded and she couldn't sit still because she was worried about what she would learn.","translation":"她焦慮地在電話旁等待關於考試成績的消息。她的心猛烈地跳動，因為擔心結果而無法靜坐。","word":"anxiously"}},"apart":{"createdAt":1781323901185,"q":{"answer":2,"explanation":"apart在此表示「相距」或「分開」，用來描述兩人之間的地理距離。","options":["together","close","apart","nearby"],"sentence":"The two friends live ______ and only see each other during summer vacation. They are separated by several hundred miles of distance.","translation":"這兩個朋友相距很遠，只在暑假期間見面。他們被數百英里的距離隔開。","word":"apart"}},"apologize":{"createdAt":1781360906184,"q":{"answer":1,"explanation":"apologize 意思是道歉，表示為自己的錯誤或冒犯表示遺憾。","options":["explain","apologize","deny","justify"],"sentence":"He had to ______ for arriving late to the meeting. His manager accepted his sincere words of regret.","translation":"他必須為遲到的會議道歉。他的經理接受了他誠摯的遺憾之詞。","word":"apologize"}},"apparent":{"createdAt":1781360885489,"q":{"answer":1,"explanation":"apparent指明顯可見或容易被注意到的，不需要深入探究就能理解。","options":["hidden","apparent","uncertain","questionable"],"sentence":"It was ______ that the student had not studied for the exam. He could not answer even the most basic questions.","translation":"很明顯該學生沒有為考試準備。他甚至無法回答最基本的問題。","word":"apparent"}},"apparently":{"createdAt":1781360906187,"q":{"answer":1,"explanation":"apparently 意思是顯然地，表示根據表面跡象或傳聞而看起來是這樣的情況。","options":["Certainly","Apparently","Deliberately","Intentionally"],"sentence":"______, the meeting was cancelled due to the weather, though no official announcement was made. People found out from rumors and social media posts.","translation":"顯然地，會議因天氣原因被取消了，儘管沒有官方公告。人們從謠言和社交媒體帖子中了解到。","word":"apparently"}},"appeal":{"createdAt":1781362281728,"q":{"answer":1,"explanation":"appeal表示懇求或呼籲，也可指吸引力，在此句中表示懇求他人幫助。","options":["announcement","appeal","complaint","question"],"sentence":"The charity organization made an ______ for donations to help disaster victims. They urged the public to contribute financially to aid relief efforts.","translation":"慈善組織呼籲捐款以幫助災難受害者。他們敦促公眾貢獻資金以支持救災努力。","word":"appeal"}},"appealing":{"createdAt":1781360906187,"q":{"answer":1,"explanation":"appealing 意思是迷人的或吸引人的，指能引起人們興趣和好感的事物。","options":["boring","appealing","confusing","ugly"],"sentence":"The restaurant's new menu design is very ______, attracting many more customers than before. The colorful presentation of dishes caught everyone's attention.","translation":"餐廳的新菜單設計非常迷人，吸引了比以前多得多的顧客。菜肴的彩色呈現引起了每個人的注意。","word":"appealing"}},"applicant":{"createdAt":1781360906186,"q":{"answer":1,"explanation":"applicant 意思是申請人，指申請職位或入學機會的人。","options":["employer","applicant","customer","supervisor"],"sentence":"Each ______ submitted a resume and cover letter for the job position. The human resources department reviewed all twenty candidates' materials.","translation":"每位申請人都為該工作職位提交了履歷和求職信。人力資源部審查了所有二十位候選人的材料。","word":"applicant"}},"application":{"createdAt":1781345237582,"q":{"answer":1,"explanation":"application作名詞表示「申請」，指為了獲得某物或進入某機構而提交的正式請求。","options":["rejection","application","certificate","acceptance"],"sentence":"She submitted her college ______ before the deadline in January. The form included her test scores, personal essay, and letters of recommendation.","translation":"她在1月的截止日期前提交了大學申請。該表格包括她的考試成績、個人文章和推薦信。","word":"application"}},"apron":{"createdAt":1781336858145,"q":{"answer":1,"explanation":"apron 是穿在身體前面用來保護衣服的服裝，通常在廚房或進行髒亂工作時穿著。","options":["hat","apron","uniform","glove"],"sentence":"The chef wore a white ______ to protect his clothes while cooking. He tied it around his waist before starting to prepare the elaborate meal.","translation":"廚師穿著白色圍裙以在烹飪時保護他的衣服。他在開始準備這頓豐盛的食物之前在腰部繫上了它。","word":"apron"}},"archive":{"createdAt":1781401361945,"q":{"answer":2,"explanation":"archive作為動詞表示將文件或資料妥善存檔和保存，以便日後查閱和研究。","options":["destroy","display","archive","distribute"],"sentence":"The library decided to ______ all the old newspapers and historical documents in a climate-controlled vault. These materials will be preserved and organized digitally so future researchers can access them safely.","translation":"圖書館決定將所有舊報紙和歷史文件存檔到一個氣候控制的保險庫中。這些材料將被保存和數位化組織，以便未來的研究人員能夠安全地訪問它們。","word":"archive"}},"arena":{"createdAt":1781311983482,"q":{"answer":1,"explanation":"arena 表示競爭或活動的場所，這裡指政治競爭的場域。","options":["timer","arena","syndrome","offshore"],"sentence":"The political ______ has become increasingly competitive in recent years. Candidates from both parties are actively campaigning in this space where major decisions are made.","translation":"近年來政治舞臺變得越來越競爭激烈。來自兩黨的候選人在這個做出重大決定的場所中積極進行競選活動。","word":"arena"}},"argument":{"createdAt":1781274836865,"q":{"answer":2,"explanation":"argument表示兩個或多個人之間的爭論或不同意見的交換，通常涉及對立的立場。","options":["agreement","discussion","argument","conversation"],"sentence":"The two neighbors had a heated ______ about whose fence was on whose property. They presented different pieces of evidence to support their conflicting claims.","translation":"兩個鄰居就誰的籬笆在誰的地產上發生了激烈的爭論。他們提出了不同的證據來支持他們相互衝突的主張。","word":"argument"}},"army":{"createdAt":1781274836865,"q":{"answer":2,"explanation":"army指國家的陸軍部隊，是由大量士兵組成的軍事組織，負責陸地防禦。","options":["navy","police","army","guard"],"sentence":"The ______ was deployed to the border region to strengthen national security. Thousands of soldiers were stationed there to protect the country's territorial integrity.","translation":"陸軍被派遣到邊境地區以加強國家安全。數千名士兵駐紮在那裡以保護國家的領土完整。","word":"army"}},"assert":{"createdAt":1781417610419,"q":{"answer":2,"explanation":"assert是指堅定地聲稱或斷言某事為真，通常帶有信心和把握。","options":["doubt","deny","assert","question"],"sentence":"The witness chose to ______ that she had seen the suspect leaving the building at midnight. Multiple security cameras confirmed her account with video evidence.","translation":"證人聲稱她看到嫌疑人在午夜時離開大樓。多台監控攝像機用視頻證據確認了她的說法。","word":"assert"}},"attachment":{"createdAt":1781395428240,"q":{"answer":1,"explanation":"attachment 在電子郵件中指附加的文件或文檔，需要單獨下載或打開。","options":["signature","attachment","header","footer"],"sentence":"The email included an important ______ that contained the contract details. You need to download this file to review all the terms and conditions.","translation":"這封電子郵件包含了一個重要的附件，其中包含合約詳情。您需要下載此文件以查看所有條款和條件。","word":"attachment"}},"attain":{"createdAt":1781272410989,"q":{"answer":2,"explanation":"attain表示通過努力達到、獲得或實現某個目標或位置。","options":["abandon","forget","attain","ignore"],"sentence":"She worked hard for ten years to ______ her dream of becoming a doctor. Her determination and perseverance finally paid off when she completed her medical degree.","translation":"她努力了十年才達成了成為醫生的夢想。當她完成醫學學位時，她的決心和毅力終於得到了回報。","word":"attain"}},"attempt":{"createdAt":1781336858154,"q":{"answer":2,"explanation":"attempt 作為動詞或名詞，表示試圖做某事或進行某項嘗試，即使可能不會成功。","options":["completion","escape","attempt","decision"],"sentence":"The mountaineers made a final ______ to reach the peak before winter storms arrived. Despite their efforts, severe weather forced them to turn back just 200 meters from the summit.","translation":"登山者在冬季風暴到來之前做了最後一次試圖到達山峰的嘗試。儘管他們做出了努力，嚴酷的天氣迫使他們在距離頂峰僅200米的地方折返。","word":"attempt"}},"attentive":{"createdAt":1781414438954,"q":{"answer":2,"explanation":"attentive表示留心、注意周圍事物或對他人體貼關懷的態度","options":["careless","rude","attentive","sleepy"],"sentence":"The nurse was ______ to her patient's needs throughout the night. She responded immediately whenever he called for help or showed discomfort.","translation":"護士整夜都注意著她患者的需求。每當他呼救或表現出不適時，她立即做出反應。","word":"attentive"}},"authentic":{"createdAt":1781274836867,"q":{"answer":2,"explanation":"authentic形容詞表示真實的、可信的、非假冒的，特別是指已被證實或經過驗證的真品。","options":["fake","damaged","authentic","modern"],"sentence":"The museum displayed an ______ painting that was created by the famous artist in the 18th century. Experts had verified its genuineness through detailed analysis and historical documentation.","translation":"博物館展示了一幅由18世紀著名藝術家創作的真跡。專家透過詳細分析和歷史文獻驗證了其真實性。","word":"authentic"}},"availability":{"createdAt":1781257238302,"q":{"answer":1,"explanation":"availability指某物是否可得、可獲取或能被使用的狀況。","options":["price","availability","quality","location"],"sentence":"The ______ of concert tickets determined whether fans could attend the show. Since only 100 seats remained and 500 people wanted to buy them, most disappointed fans went home empty-handed.","translation":"演唱會門票的可得性決定了粉絲是否能參加演出。由於只有100個座位剩餘，而500人想購票，大多數失望的粉絲空手而歸。","word":"availability"}},"average":{"createdAt":1781311983487,"q":{"answer":2,"explanation":"average 表示多個數值的平均值或典型的、中等的水平。","options":["presidential","evolution","average","expressive"],"sentence":"The ______ temperature for this region in July is around 28 degrees Celsius. This figure represents the typical weather conditions most people experience during that summer month.","translation":"這個地區七月的平均溫度約為攝氏28度。這個數字代表了大多數人在那個夏月經歷的典型天氣狀況。","word":"average"}},"aviation":{"createdAt":1781272410995,"q":{"answer":2,"explanation":"aviation指的是航空學、航空工業或飛行術，涉及飛機、飛行和空中運輸的各個方面。","options":["agriculture","architecture","aviation","archaeology"],"sentence":"My brother studied ______ in college and now works as a pilot for an international airline. His degree included courses in aircraft design, aerodynamics, and flight operations.","translation":"我的哥哥在大學裡學習航空學，現在在一家國際航空公司當飛行員。他的學位包括飛機設計、空氣動力學和飛行操作的課程。","word":"aviation"}},"award":{"createdAt":1781256547739,"q":{"answer":1,"explanation":"Award作為動詞表示正式授予或頒發獎品、獎金或榮譽給某人。","options":["withdraw","award","deny","delay"],"sentence":"The university will ______ scholarships to the top ten students based on their academic achievements. The recipients will be announced at the graduation ceremony next month.","translation":"大學將根據學生的學術成就將獎學金頒發給前十名學生。獲獎者將在下個月的畢業典禮上宣佈。","word":"award"}},"aware":{"createdAt":1781256547738,"q":{"answer":1,"explanation":"Aware表示知道、意識到或認識到某事物的存在或事實。","options":["ignorant","aware","uncertain","careless"],"sentence":"She was ______ of the dangers associated with traveling alone in unfamiliar places. Therefore, she always informed her family of her location and carried safety devices with her.","translation":"她知道獨自在陌生地方旅行的危險。因此，她總是將她的位置告知家人，並隨身攜帶安全裝置。","word":"aware"}},"awesome":{"createdAt":1781256485495,"q":{"answer":2,"explanation":"awesome表示令人驚嘆的、非常棒的或令人印象深刻的","options":["boring","terrible","awesome","confusing"],"sentence":"The concert was absolutely ______ and the crowd was amazed by the stunning performance. Everyone left the venue feeling impressed and energized.","translation":"這場音樂會棒極了，觀眾對這場精彩的表演嘆為觀止。每個人都帶著欽佩和充滿活力的感覺離開了場地。","word":"awesome"}},"awful":{"createdAt":1781256485492,"q":{"answer":2,"explanation":"awful表示非常糟糕的、令人不快的或令人厭惡的","options":["delicious","fresh","awful","creative"],"sentence":"The food at the restaurant was absolutely ______ and we could barely eat it. Our entire dining experience was a complete disappointment.","translation":"餐廳的食物糟透了，我們幾乎吃不下去。我們整個用餐體驗都非常令人失望。","word":"awful"}},"banquet":{"createdAt":1781336858151,"q":{"answer":2,"explanation":"banquet 是指一場正式的、豪華的宴會，通常為特殊場合舉辦，有多道菜餚和許多賓客。","options":["fight","breakfast","banquet","interview"],"sentence":"The ______ lasted for three hours with multiple courses and fine wines. The president's speech at the end congratulated all the distinguished guests for their contributions.","translation":"這場宴會持續了三個小時，包括多道菜餚和美酒。總統在結束時的演講祝賀了所有尊貴賓客的貢獻。","word":"banquet"}},"beam":{"createdAt":1781359980248,"q":{"answer":1,"explanation":"beam作為名詞指光線、光束或光柱；特指一條直線的、集中的光線或粒子流。","options":["shadow","beam","reflection","filter"],"sentence":"A ______ of sunlight streamed through the window and illuminated the entire room. The golden light created a beautiful pattern on the wooden floor.","translation":"一束陽光透過窗戶射進來，照亮了整個房間。金色的光線在木地板上創造了美麗的圖案。","word":"beam"}},"bearing":{"createdAt":1781257238305,"q":{"answer":1,"explanation":"bearing指人的舉止、風度或姿態，反映了一個人的行為表現和氣質。","options":["weight","bearing","costume","voice"],"sentence":"The elderly gentleman's dignified ______ impressed everyone in the room. His posture was straight, his movements were graceful, and he spoke with confidence and respect.","translation":"這位年邁紳士的高尚舉止給房間裡的每個人都留下了深刻印象。他的姿態筆直，動作優雅，說話時充滿信心和尊重。","word":"bearing"}},"beneath":{"createdAt":1781336858149,"q":{"answer":2,"explanation":"beneath 是介詞，表示在某物的下方或下面，通常帶有被覆蓋或隱藏的含義。","options":["above","beside","beneath","within"],"sentence":"The ancient ruins lay ______ the surface of the desert sand. Archaeologists used special equipment to excavate the buried structures from deep underground.","translation":"古代遺跡位於沙漠沙子表面的下方。考古學家使用特殊設備從地下深處挖掘埋藏的結構。","word":"beneath"}},"besiege":{"createdAt":1781417610416,"q":{"answer":2,"explanation":"besiege可以指用大量的事物圍困或騷擾某人，使其受到困擾。","options":["praise","ignore","besiege","motivate"],"sentence":"Complaints from customers continued to ______ the company's management every single day. The overwhelming volume of grievances made it impossible for executives to focus on other business matters.","translation":"顧客的投訴每天都在不斷地煩擾公司的管理層。大量的抱怨使主管們無法專注於其他業務事項。","word":"besiege"}},"beyond":{"createdAt":1781362281656,"q":{"answer":1,"explanation":"beyond表示在...更遠處或超越某個限度。","options":["within","beyond","beside","along"],"sentence":"The mountain range extends far ______ what we can see from this valley. The peaks continue for hundreds of kilometers into the distance.","translation":"山脈延伸到我們從這個山谷看不到的地方。這些山峰繼續向遠處延伸數百公里。","word":"beyond"}},"biscuit":{"createdAt":1781257238303,"q":{"answer":1,"explanation":"biscuit指一種烘焙的、通常是酥脆的麵粉製食品，可以甜也可以鹹。","options":["sandwich","biscuit","soup","salad"],"sentence":"For breakfast, Tom enjoyed a warm ______ with butter and jam. He ate the crispy, golden-brown pastry in just two bites.","translation":"早餐時，湯姆享用了一塊塗有黃油和果醬的溫暖餅乾。他兩口就吃完了這個酥脆的金黃色烘焙食品。","word":"biscuit"}},"blend":{"createdAt":1781272410984,"q":{"answer":1,"explanation":"blend是指將不同的物質或成分混合在一起，使其成為一個整體。","options":["separate","blend","bake","measure"],"sentence":"The chef will ______ the flour, eggs, and milk to create the cake batter. After stirring for several minutes, all ingredients become a smooth, uniform mixture.","translation":"廚師將麵粉、雞蛋和牛奶混合在一起製作蛋糕麵糊。攪拌幾分鐘後，所有材料變成光滑均勻的混合物。","word":"blend"}},"bless":{"createdAt":1781274836867,"q":{"answer":2,"explanation":"bless作為動詞表示祝福或祈求神聖力量保佑某人或某物，通常在宗教或正式場合使用。","options":["curse","name","bless","baptize"],"sentence":"The priest came to ______ the newborn baby during the religious ceremony. He made the sign of the cross and spoke sacred words to invoke divine protection.","translation":"牧師在宗教儀式中來祝福新生兒。他畫了十字聖號並說出神聖的話語來祈求神聖的保護。","word":"bless"}},"board":{"createdAt":1781256485490,"q":{"answer":1,"explanation":"board在此指的是公司的董事會，由董事組成的管理機構","options":["schedule","board","office","meeting"],"sentence":"The company's ______ met to discuss the quarterly financial results. The directors and executives reviewed all major decisions made during the past three months.","translation":"公司的董事會召開會議討論季度財務成果。董事和高管們審查了過去三個月做出的所有重大決定。","word":"board"}},"bold":{"createdAt":1781414884514,"q":{"answer":2,"explanation":"bold在排版中指字體粗的、粗體的，透過增加字體粗細來使文字更加醒目。","options":["itchy","bright","bold","soft"],"sentence":"The designer made the title ______ so it would stand out on the page. She increased the font weight to make sure readers would notice it immediately.","translation":"設計師把標題設成粗體，這樣它就會在頁面上突出來。她增加了字體的粗細，確保讀者會立即注意到它。","word":"bold"}},"braid":{"createdAt":1781363994347,"q":{"answer":1,"explanation":"braid作為動詞表示將線、髮絲等編織在一起，形成交叉的裝飾圖案或辮子。","options":["tear","weave","cut","stitch"],"sentence":"She used colorful thread to ______ a decorative border around the edge of the quilt. The intricate woven pattern added elegance to the handmade blanket.","translation":"她用彩色線條在棉被邊緣編織裝飾邊框。這複雜的編織圖案為手工製作的毛毯增添了優雅氣質。","word":"braid"}},"breast":{"createdAt":1781275226787,"q":{"answer":0,"explanation":"此處breast作動詞表示「挺胸面對；勇敢地迎向」","options":["breast","dump","fume","include"],"sentence":"The soldier decided to ______ the enemy and charge forward despite the danger. His courage inspired all those fighting beside him.","translation":"那位士兵決定挺胸面對敵人並向前衝鋒，儘管危險重重。他的勇氣激勵了所有與他並肩作戰的人。","word":"breast"}},"buckle":{"createdAt":1781272410990,"q":{"answer":2,"explanation":"buckle作為動詞表示用扣環或搭扣將某物固定或扣上，特別是在安全帶、皮帶等情況下。","options":["unbuckle","break","buckle","unfasten"],"sentence":"Please ______ your seatbelt before the airplane takes off for safety. The flight attendant reminds all passengers to fasten their restraints properly.","translation":"飛機起飛前，請扣好你的安全帶以保証安全。空服員提醒所有乘客正確地繫好他們的約束帶。","word":"buckle"}},"bulge":{"createdAt":1781256547739,"q":{"answer":1,"explanation":"Bulge表示膨脹、凸起或向外推起，通常是因為內部裝有太多東西。","options":["shrink","bulge","flatten","divide"],"sentence":"The backpack began to ______ as the student packed more and more books inside. By the time she zipped it closed, the fabric was stretched to its limits.","translation":"當學生在背包裡裝入越來越多的書籍時，背包開始膨脹。當她拉上拉鍊時，布料已經延伸到極限。","word":"bulge"}},"bulletin":{"createdAt":1781256547738,"q":{"answer":1,"explanation":"Bulletin是指電視或電臺突然插播的新聞快報或機構發佈的簡報和公告。","options":["advertisement","bulletin","documentary","commercial"],"sentence":"The emergency ______ interrupted the regular television program to announce the severe weather warning. Viewers learned that a powerful storm was approaching their region within the next few hours.","translation":"緊急新聞快報中斷了常規電視節目，宣布了嚴重天氣警告。觀眾得知一場強大的風暴將在接下來的幾小時內逼近他們的地區。","word":"bulletin"}},"bump":{"createdAt":1781362281667,"q":{"answer":1,"explanation":"bump表示碰撞或撞擊，通常帶有一定的力度並可能導致疼痛。","options":["touch","bump","pass","lean"],"sentence":"She ______ her head on the low doorway as she entered the room. A painful impact left a small bruise on her forehead.","translation":"當她進入房間時，她的頭碰到了低門框。一次痛苦的碰撞在她的額頭上留下了一個小瘀傷。","word":"bump"}},"bureau":{"createdAt":1781362281654,"q":{"answer":1,"explanation":"bureau是指政府部門或辦公機構，如局、處、署等。","options":["office","bureau","store","factory"],"sentence":"She works at the environmental protection ______ handling pollution cases. The government agency is responsible for enforcing environmental regulations across the region.","translation":"她在環保局工作，處理污染案件。這個政府機構負責在該地區執行環境法規。","word":"bureau"}},"butcher":{"createdAt":1781417610418,"q":{"answer":1,"explanation":"butcher是指屠夫或肉商，販賣肉類食品的商人。","options":["tailor","butcher","gardener","carpenter"],"sentence":"The local ______ offered the finest quality meat in the neighborhood for over forty years. His shop was known for its fresh cuts and expert knowledge of different animal parts.","translation":"這位當地肉商在鄰近地區提供最優質的肉類已超過四十年。他的店以新鮮的肉品切割和對不同動物部位的專業知識而聞名。","word":"butcher"}},"cabinet":{"createdAt":1781343050499,"q":{"answer":2,"explanation":"cabinet 在此指政府內閣，由內閣部長組成，負責政策制定和領導各部門。","options":["furniture","kitchen","cabinet","room"],"sentence":"The President's ______ consists of important ministers who advise on major policy decisions. These officials head various government departments.","translation":"總統的內閣由重要的部長組成，他們就重大政策決定提供建議。這些官員領導著各個政府部門。","word":"cabinet"}},"canyon":{"createdAt":1781343050501,"q":{"answer":2,"explanation":"canyon 是指由河流侵蝕而成的深谷或峽谷，具有陡峭的岩壁。","options":["mountain","forest","canyon","desert"],"sentence":"Tourists flock to the famous ______ in Arizona to hike along its steep walls and river. The massive geological formation took millions of years to form.","translation":"遊客蜂擁到亞利桑那州著名的峽谷，沿著陡峭的岩壁和河流徒步旅行。這個龐大的地質構造花了數百萬年才形成。","word":"canyon"}},"capitalism":{"createdAt":1781256485491,"q":{"answer":2,"explanation":"capitalism是一種經濟制度，強調私有財產權和市場競爭","options":["socialism","feudalism","capitalism","monarchy"],"sentence":"The country's economy is based on ______, where private individuals and businesses own the means of production. Citizens are free to buy, sell, and compete in the marketplace without heavy government control.","translation":"這個國家的經濟以資本主義為基礎，由私人和企業擁有生產資料。公民可以自由地在市場上買賣和競爭，不受政府過度控制。","word":"capitalism"}},"captivate":{"createdAt":1781256547737,"q":{"answer":1,"explanation":"Captivate表示強烈吸引某人的注意力和興趣，使其深深著迷。","options":["bore","captivate","educate","frighten"],"sentence":"The magician's extraordinary performance managed to ______ the entire audience for two hours. From the opening trick to the final illusion, every moment held their complete attention and wonder.","translation":"魔術師的非凡表演設法使整個觀眾著迷了兩個小時。從開場戲法到最後的幻象，每一刻都吸引了他們的完全注意力和驚嘆。","word":"captivate"}},"carpenter":{"createdAt":1781362281665,"q":{"answer":1,"explanation":"carpenter指的是從事木工工作的工人，製造或修理木製結構和物品。","options":["plumber","carpenter","electrician","mason"],"sentence":"The ______ carefully measured and cut the wood for the new deck. His skilled hands shaped each piece into the perfect size and fit.","translation":"木匠仔細測量並為新甲板切割木材。他熟練的手將每一塊木料塑造成完美的尺寸和配合。","word":"carpenter"}},"carriage":{"createdAt":1781256485494,"q":{"answer":2,"explanation":"carriage是指四輪馬車或火車車廂，用於運載乘客","options":["airplane","bicycle","carriage","submarine"],"sentence":"The luxurious ______ was pulled by four white horses through the royal procession. Passengers sat in the decorated wooden compartment as crowds watched the ceremonial parade.","translation":"這輛豪華的四輪馬車由四匹白馬拉著通過皇家遊行隊伍。乘客坐在裝飾華麗的木製車廂內，眾人觀看了這場儀式性遊行。","word":"carriage"}},"cassette":{"createdAt":1781256485493,"q":{"answer":1,"explanation":"cassette是指盒式錄音帶或錄影帶，通常用於儲存音樂或視頻","options":["mirror","cassette","book","lamp"],"sentence":"She found an old ______ in her mother's attic from the 1980s. The magnetic tape inside contained recordings of family conversations from decades ago.","translation":"她在母親的閣樓裡發現了一個來自1980年代的舊盒式錄音帶。裡面的磁帶包含了幾十年前的家庭對話錄音。","word":"cassette"}},"caught":{"createdAt":1781345746906,"q":{"answer":1,"explanation":"caught 是 catch 的過去式，在此指「染上」疾病，表示受感染。","options":["threw","caught","threw away","dropped"],"sentence":"The child ______ a terrible cold while playing outside in the rain. Within two days, he developed a fever and had to stay home from school.","translation":"孩子在雨中外面玩耍時染上了嚴重的感冒。兩天內，他發燒了，不得不待在家裡不去上學。","word":"caught"}},"ceiling":{"createdAt":1781274836863,"q":{"answer":1,"explanation":"ceiling在此context表示上限或最高限制，特別是指款項或價格不能超越的界限。","options":["foundation","ceiling","floor","wall"],"sentence":"The government announced a price ______ to prevent inflation from getting worse. No business was allowed to charge more than the maximum amount established by law.","translation":"政府宣布了價格上限以防止通貨膨脹惡化。法律規定沒有企業被允許收取超過最高金額。","word":"ceiling"}},"certification":{"createdAt":1781336858147,"q":{"answer":1,"explanation":"certification 是正式的證明文件，表示某人已達到特定的標準或完成了特定的要求。","options":["complaint","certification","rejection","rumor"],"sentence":"She earned a ______ from the university after completing the professional development program. The document proved that she had successfully passed all required examinations and met every standard.","translation":"她在完成專業發展課程後從大學獲得了證明書。這份文件證明她已成功通過所有必修考試並達到了每項標準。","word":"certification"}},"chant":{"createdAt":1781256547738,"q":{"answer":1,"explanation":"Chant表示以節奏或重複的方式大聲說出或吟唱某些詞語或短語。","options":["whisper","chant","write","forget"],"sentence":"The crowd began to ______ the team's name repeatedly during the championship game. The rhythmic repetition of \"Go Tigers!\" echoed throughout the entire stadium.","translation":"在冠軍賽期間，群眾開始反覆吟唱球隊的名字。「加油老虎隊！」的有節奏重複聲音迴盪在整個體育場。","word":"chant"}},"charm":{"createdAt":1781256547737,"q":{"answer":1,"explanation":"Charm作為動詞表示以某種吸引人的方式使某人感到愉悅或著迷。","options":["repel","charm","confuse","annoy"],"sentence":"Her warm smile and genuine kindness seemed to ______ everyone she met. People found themselves drawn to her presence and eager to spend time with her.","translation":"她溫暖的微笑和真摯的善良似乎使她遇見的每個人都著迷。人們發現自己被她的存在所吸引，渴望與她相處。","word":"charm"}},"chef":{"createdAt":1781343050502,"q":{"answer":2,"explanation":"chef 指專業廚師或廚師長，負責菜肴的設計、準備和烹飪。","options":["waiter","accountant","chef","manager"],"sentence":"The renowned ______ at the five-star restaurant creates innovative dishes every night. His culinary training and creativity have earned him multiple awards.","translation":"這家五星級餐廳著名的廚師每晚都創作創新菜肴。他的烹飪培訓和創意為他贏得了多個獎項。","word":"chef"}},"chill":{"createdAt":1781323901188,"q":{"answer":2,"explanation":"chill意為「使變冷」或「使冷卻」，在此指降低飲料的溫度。","options":["heat","warm","chill","ferment"],"sentence":"Please ______ the champagne in the freezer before the guests arrive. We need the bottles to be ice-cold for the celebration tonight.","translation":"請在客人到達前在冰箱裡冷卻香檳。我們需要這些瓶子冰冷以供今晚的慶祝活動。","word":"chill"}},"chirp":{"createdAt":1781414884519,"q":{"answer":1,"explanation":"chirp指小鳥或昆蟲發出的尖聲尖氣的叫聲，通常是短促而重複的。","options":["roar","chirp","whisper","thunder"],"sentence":"Every morning, the small birds would ______ outside my window to greet the sunrise. Their high-pitched sounds created a cheerful melody that woke me up naturally.","translation":"每個早晨，小鳥都會在我的窗外嘰嘰喳喳地叫來迎接日出。他們尖銳的聲音創造了一首歡樂的旋律，自然地喚醒了我。","word":"chirp"}},"chronological":{"createdAt":1781257238299,"q":{"answer":1,"explanation":"chronological指按照時間先後順序排列的，適合用來描述事件的時間順序。","options":["random","chronological","alphabetical","thematic"],"sentence":"The history textbook presents events in ______ order. Students can easily understand how one event led to the next by following the timeline from 1900 to 2020.","translation":"歷史教科書按時間順序呈現事件。學生可以通過遵循從1900年到2020年的時間線，輕鬆理解一個事件如何導致下一個事件。","word":"chronological"}},"cigarette":{"createdAt":1781343050492,"q":{"answer":1,"explanation":"cigarette 是指紙煙，通常指香煙製品，醫生警告的就是吸煙對肺部的傷害。","options":["alcohol","cigarette","coffee","candy"],"sentence":"He quit smoking ______ last year because of health concerns. His doctor warned him that each stick he smoked was damaging his lungs.","translation":"他去年戒掉了香煙，因為擔心健康。他的醫生警告他說，他抽的每一根都在傷害他的肺。","word":"cigarette"}},"civil":{"createdAt":1781272410990,"q":{"answer":2,"explanation":"civil作為形容詞指的是民事的、市民的，特別是在法律方面指不涉及刑事犯罪的民間糾紛。","options":["military","criminal","civil","martial"],"sentence":"The ______ court handles disputes between two private citizens about property rights. This type of case is different from criminal cases, which involve breaking the law.","translation":"民事法庭處理兩個私人公民之間關於財產權的爭議。這類案件與涉及違反法律的刑事案件不同。","word":"civil"}},"civilization":{"createdAt":1781332009067,"q":{"answer":1,"explanation":"civilization 指的是具有特定文化、制度和社會結構的人類社會","options":["animals","civilization","weather","mountains"],"sentence":"Ancient Egypt was one of the most advanced ______ in human history. This society developed writing, architecture, and complex government systems thousands of years ago.","translation":"古埃及是人類歷史上最先進的文明之一。這個社會在幾千年前就發展出了文字、建築和複雜的政府體系。","word":"civilization"}},"civilized":{"createdAt":1781332009080,"q":{"answer":1,"explanation":"civilized 是形容詞，表示文明的、開化的，用於形容有教養和禮貌的行為","options":["barbaric","civilized","chaotic","hostile"],"sentence":"The discussion remained calm and ______ despite the disagreement between the parties. Both sides presented their arguments respectfully without resorting to insults or aggression.","translation":"儘管雙方之間有分歧，討論仍然保持冷靜和文明。雙方都尊重地陳述了他們的論點，沒有訴諸辱罵或侵略。","word":"civilized"}},"clap":{"createdAt":1781323901186,"q":{"answer":1,"explanation":"clap意為「鼓掌」或「拍手」，用來表達對表演者的欣賞和認可。","options":["boo","clap","whistle","shout"],"sentence":"When the performance ended, the entire audience stood up to ______ enthusiastically. The thunderous applause lasted for several minutes as a sign of appreciation.","translation":"當表演結束時，整個觀眾都站起來熱烈鼓掌。雷鳴般的掌聲持續了幾分鐘，表示讚賞。","word":"clap"}},"clarify":{"createdAt":1781337343697,"q":{"answer":1,"explanation":"clarify意為澄清、闡明或使事情變得清楚明白。","options":["obscure","clarify","ignore","complicate"],"sentence":"The spokesperson held a press conference to ______ the confusing statements made by the government earlier. The journalist's persistent questions forced him to provide specific and detailed explanations.","translation":"發言人舉行新聞發布會澄清政府早前做出的令人困惑的聲明。記者持續的提問迫使他提供具體和詳細的解釋。","word":"clarify"}},"client":{"createdAt":1781343050500,"q":{"answer":2,"explanation":"client 指律師、顧問等服務提供者的客戶或委託人，他們需要專業服務。","options":["employees","competitors","client","strangers"],"sentence":"The law firm has many satisfied ______ who return for legal advice year after year. These individuals and companies trust the firm with their most sensitive matters.","translation":"這家律師事務所有許多滿意的客戶，他們多年來一直回來尋求法律建議。這些個人和公司信任該公司處理他們最敏感的事務。","word":"client"}},"clone":{"createdAt":1781311685832,"q":{"answer":1,"explanation":"clone是指通過複製遺傳物質而製造出來的完全相同的個體或物品，強調了遺傳學上的相同性。","options":["mutation","replica","species","hybrid"],"sentence":"The scientist created a ______ of the original sheep by copying its DNA. This genetic duplicate was identical to the animal it came from.","translation":"科學家通過複製其DNA為原始綿羊製造了一個複製品。這個遺傳學上的相同個體與它來自的動物完全一致。","word":"clone"}},"closure":{"createdAt":1781274482554,"q":{"answer":2,"explanation":"closure在心理上指達到解脫或寬慰的狀態，通常涉及接納和放下過去。","options":["excitement","anger","closure","confusion"],"sentence":"After years of therapy, she finally found ______ regarding her painful childhood memories. The peace and acceptance she gained allowed her to move forward with her life.","translation":"經過多年的治療，她終於對痛苦的童年記憶獲得了寬慰。她獲得的平靜和接納使她能夠繼續前進。","word":"closure"}},"clue":{"createdAt":1781362281667,"q":{"answer":1,"explanation":"clue表示線索或提示，幫助找到答案或解決問題。","options":["witness","clue","suspect","weapon"],"sentence":"The detective found an important ______ at the crime scene. This piece of evidence helped solve the mysterious case.","translation":"偵探在犯罪現場發現了重要的線索。這條證據幫助破解了神秘案件。","word":"clue"}},"cluster":{"createdAt":1781257238301,"q":{"answer":1,"explanation":"cluster指緊密聚集在一起的一群或一簇東西，特別是指物理上相連的物體。","options":["single","cluster","line","row"],"sentence":"A ______ of grapes hung from the vineyard vine. The farmer carefully harvested the tightly-grouped bunches together because they were all attached at the same point.","translation":"一串葡萄從葡萄園的藤蔓上掛下來。農民小心地將這些緊密分組的葡萄束一起收穫，因為它們都附著在同一個地方。","word":"cluster"}},"clutter":{"createdAt":1781274482560,"q":{"answer":1,"explanation":"clutter指亂堆或塞滿東西，導致空間變得雜亂無序。","options":["organize","clutter","clean","decorate"],"sentence":"She decided to ______ her living room with too many decorations and furniture. The space became so cramped and disorganized that guests could barely move around.","translation":"她決定用太多裝飾品和家具堆滿客廳。這個空間變得如此擁擠和混亂，以至於客人幾乎無法走動。","word":"clutter"}},"coach":{"createdAt":1781272410986,"q":{"answer":1,"explanation":"coach指的是教練，專門指導和訓練運動員或學生提高他們的技能和表現。","options":["referee","coach","athlete","spectator"],"sentence":"The basketball ______ teaches his players new strategies and techniques every week. Without his guidance and training sessions, the team would not have won the championship.","translation":"籃球教練每週教導他的球員新的戰術和技巧。沒有他的指導和訓練課程，這支隊伍就不會贏得冠軍。","word":"coach"}},"coastal":{"createdAt":1781274482553,"q":{"answer":1,"explanation":"coastal指靠近海岸或與海岸相關的地方，通常有沙灘和海洋活動。","options":["mountain","coastal","desert","forest"],"sentence":"The ______ town attracted thousands of tourists every summer. Visitors enjoyed swimming in the ocean and walking along sandy beaches.","translation":"那個海邊小鎮每年夏天吸引數千名遊客。遊客享受在海洋中游泳和沿著沙灘散步。","word":"coastal"}},"collaboration":{"createdAt":1781417610415,"q":{"answer":1,"explanation":"collaboration是指多個人或團體為了共同目標而一起合作、協力工作。","options":["competition","collaboration","isolation","conflict"],"sentence":"The successful project was the result of ______ between the three departments. Without teamwork and shared goals, the departments would have failed to achieve their objectives.","translation":"這個成功的專案是三個部門之間協作的結果。沒有團隊合作和共同目標，這些部門將無法實現他們的目標。","word":"collaboration"}},"collect":{"createdAt":1781274836866,"q":{"answer":2,"explanation":"collect作為動詞表示把分散的東西聚集在一起或收集，通常指有系統地聚集多個物品。","options":["distribute","lose","collect","grade"],"sentence":"The teacher asked all students to ______ their homework assignments before the end of class. She walked around the room and gathered papers from each desk one by one.","translation":"老師要求所有學生在下課前交出他們的作業。她在教室裡走動，逐張地從每張課桌上收集論文。","word":"collect"}},"colonist":{"createdAt":1781363994345,"q":{"answer":1,"explanation":"colonist指的是前往他人土地上建立殖民地的人，他們在新領土上定居並建立社區。","options":["explorer","settler","merchant","king"],"sentence":"The early ______ established settlements in the New World during the 17th century. These pioneers built homes, farms, and communities far from their native countries.","translation":"早期的殖民者在17世紀在新大陸建立了定居點。這些先驅在遠離祖國的地方建造了家園、農場和社區。","word":"colonist"}},"colony":{"createdAt":1781345237580,"q":{"answer":1,"explanation":"colony指受主權國家統治的領土或殖民地，特別是在海外建立的定居點。","options":["empire","colony","nation","kingdom"],"sentence":"The British ______ in North America included Virginia, Massachusetts, and Georgia. These settlements were established along the eastern coast during the 17th and 18th centuries.","translation":"北美的英國殖民地包括維吉尼亞州、麻薩諸塞州和喬治亞州。這些定居點是在17和18世紀沿著東海岸建立的。","word":"colony"}},"columnist":{"createdAt":1781257238300,"q":{"answer":1,"explanation":"columnist是指定期為報紙或雜誌撰寫專欄文章的人。","options":["editor","columnist","printer","photographer"],"sentence":"Sarah works as a ______ for the newspaper, writing articles about current events. Every Monday, her opinion piece appears on page five of the publication.","translation":"莎拉在報紙上擔任專欄作家，撰寫關於時事的文章。每週一，她的評論文章都會出現在該出版物的第五頁。","word":"columnist"}},"combination":{"createdAt":1781402539337,"q":{"answer":1,"explanation":"combination 指多個元素或數字的特定排列方式，合在一起產生特定的結果。","options":["lock","combination","password","key"],"sentence":"The safe requires a ______ of numbers to open. You must enter them in the correct sequence, starting with 7-15-23.","translation":"這個保險箱需要一個號碼組合才能打開。你必須按正確的順序輸入它們，從7-15-23開始。","word":"combination"}},"commentator":{"createdAt":1781274482558,"q":{"answer":2,"explanation":"commentator指在廣播或電視上進行實況評論和分析的人，通常提供專業見解。","options":["player","coach","commentator","fan"],"sentence":"The sports ______ provided live analysis of the football match. His expert insights and real-time observations helped viewers understand the strategy and tactics being used.","translation":"體育評論員對足球比賽進行現場分析。他的專業見解和實時評論幫助觀眾理解所使用的戰略和戰術。","word":"commentator"}},"commerce":{"createdAt":1781343050502,"q":{"answer":2,"explanation":"commerce 指商業貿易和商業活動，涉及商品的買賣和交換。","options":["agriculture","art","commerce","sports"],"sentence":"International ______ between countries has grown significantly due to improved transportation. Businesses now export and import goods across continents daily.","translation":"由於運輸改善，國家間的貿易顯著增長。企業現在每天都在跨洲出口和進口商品。","word":"commerce"}},"commit":{"createdAt":1781401803895,"q":{"answer":1,"explanation":"commit在這裡表示「犯（罪）」，指實施或進行一個不法行為。","options":["dedicate","perpetrate","promise","invest"],"sentence":"The criminal decided to ______ a serious robbery at the bank. Police found evidence that he had planned this illegal act for several months in advance.","translation":"那個罪犯決定在銀行犯下一樁嚴重的搶劫罪。警察發現他提前幾個月就計畫好了這個非法行為。","word":"commit"}},"commonwealth":{"createdAt":1781343050503,"q":{"answer":2,"explanation":"commonwealth 指由多個國家或地區組成的政治聯合體，成員國之間有共同的政治和經濟聯繫。","options":["kingdom","empire","commonwealth","republic"],"sentence":"Australia is a ______ with a parliamentary system that includes Britain's monarch as head of state. Its member nations cooperate on various political and economic issues.","translation":"澳大利亞是一個國家聯合體，採用議會制，英國君主為國家元首。其成員國在各種政治和經濟問題上合作。","word":"commonwealth"}},"communicative":{"createdAt":1781343050498,"q":{"answer":2,"explanation":"communicative 指樂於交流、健談的，與經常發言和分享想法的行為相符。","options":["shy","quiet","communicative","reserved"],"sentence":"Sarah is very ______ in meetings and always shares her ideas freely. She speaks up constantly and encourages others to participate in discussions.","translation":"莎拉在會議中很健談，總是自由地分享她的想法。她經常發言，並鼓勵他人參與討論。","word":"communicative"}},"communism":{"createdAt":1781343050497,"q":{"answer":2,"explanation":"communism 是一種政治和經濟制度，馬克思和列寧都是共產主義的倡導者。","options":["democracy","capitalism","communism","monarchy"],"sentence":"The Soviet Union was founded on the principles of ______ and collective ownership. Marx and Lenin were key figures in promoting this ideology.","translation":"蘇聯是建立在共產主義和集體所有制的原則基礎上的。馬克思和列寧是推行這一意識形態的關鍵人物。","word":"communism"}},"communist":{"createdAt":1781395428236,"q":{"answer":1,"explanation":"communist 作為形容詞或名詞，指與共產主義或共產黨相關的人或思想體系。","options":["democratic","communist","capitalist","monarchist"],"sentence":"During the Cold War, many countries feared the spread of ______ ideology from the Soviet Union. The government implemented policies specifically to prevent this political system from gaining influence.","translation":"冷戰期間，許多國家害怕蘇聯共產主義意識形態的傳播。政府實施了具體政策來阻止這一政治制度的影響力增長。","word":"communist"}},"commuter":{"createdAt":1781332009082,"q":{"answer":1,"explanation":"commuter 是名詞，指的是定期往返於家庭和工作場所之間的人","options":["tourist","commuter","driver","pedestrian"],"sentence":"The ______ took the same train every morning to get to work in the city. He had been following this routine for over five years.","translation":"這位通勤者每天早上都乘坐同一列火車去城市工作。他已經遵循這一慣例超過五年。","word":"commuter"}},"company":{"createdAt":1781359980249,"q":{"answer":2,"explanation":"company作為名詞有陪伴、同伴的意思；指與他人在一起的伴隨或相處的狀態。","options":["absence","rivalry","company","service"],"sentence":"She enjoyed the ______ of her grandmother during the long winter evenings. They spent hours together playing cards and sharing stories from the past.","translation":"她喜歡在漫長的冬夜陪伴祖母。他們花了好幾個小時一起打牌和分享過去的故事。","word":"company"}},"compassionate":{"createdAt":1781332009072,"q":{"answer":1,"explanation":"compassionate 意為有同情心的、富有同情的，表示對他人的痛苦和困難有深刻的同情","options":["cruel","compassionate","impatient","rude"],"sentence":"The ______ doctor spent extra time with each patient, listening to their concerns. She genuinely cared about their well-being and treated everyone with kindness and respect.","translation":"有同情心的醫生為每位患者花費了額外的時間，聆聽他們的關切。她真心關心他們的福祉，用善良和尊重對待每個人。","word":"compassionate"}},"compel":{"createdAt":1781402154554,"q":{"answer":0,"explanation":"compel表示強迫或迫使某人做某事，在這裡指法律強制公司採取特定行動。","options":["compel","suspect","lottery","hijack"],"sentence":"The new law will ______ all companies to reduce their plastic waste by 30%. Failure to comply with this regulation will result in substantial fines and penalties.","translation":"新法律將強迫所有公司將塑料廢物減少30%。不遵守此規定將導致巨額罰款和處罰。","word":"compel"}},"competence":{"createdAt":1781332009079,"q":{"answer":1,"explanation":"competence 是名詞，表示能力或勝任能力，指做好某事所需的技能","options":["incompetence","competence","weakness","inexperience"],"sentence":"The manager demonstrated her ______ by successfully leading the complex project to completion. Her team members trusted her judgment and relied on her expertise.","translation":"經理通過成功領導複雜項目完成來展示她的能力。她的團隊成員信任她的判斷並依賴她的專業知識。","word":"competence"}},"competent":{"createdAt":1781272410987,"q":{"answer":2,"explanation":"competent表示具有能力、勝任的、能幹的，用來形容一個人在某方面具有足夠的技能和知識。","options":["lazy","incompetent","competent","dishonest"],"sentence":"The software developer proved to be ______ at solving complex programming problems. His manager decided to promote him because of his excellent skills and reliability.","translation":"這位軟體開發人員證明了他在解決複雜程式設計問題方面很能幹。他的經理因為他的優秀技能和可靠性而決定提拔他。","word":"competent"}},"complementary":{"createdAt":1781274482564,"q":{"answer":2,"explanation":"complementary指能夠補充、完善或相互配合的事物，共同創造更完整的整體。","options":["opposite","identical","complementary","competing"],"sentence":"The two artists created ______ pieces that worked beautifully together in the exhibition. When displayed side by side, they enhanced and completed each other's visual narrative.","translation":"這兩位藝術家創作了在展覽中配合得很好的互補作品。當它們並排展示時，它們互相強化並完成彼此的視覺敘事。","word":"complementary"}},"complexion":{"createdAt":1781323901186,"q":{"answer":1,"explanation":"complexion意為「膚色」，在此指人皮膚的顏色和質地。","options":["personality","complexion","attitude","expression"],"sentence":"She has a naturally beautiful ______ that glows even without makeup. The healthy pink and tan tones in her skin are inherited from her Mediterranean ancestry.","translation":"她天生擁有美麗的膚色，即使不化妝也閃閃發光。她皮膚上健康的粉紅色和棕褐色調是從她的地中海血統遺傳而來的。","word":"complexion"}},"compliance":{"createdAt":1781274482560,"q":{"answer":2,"explanation":"compliance指遵守規則、法律或要求的行為，表示順從和配合。","options":["violation","resistance","compliance","defiance"],"sentence":"The company's strict ______ with environmental regulations impressed the government inspectors. They followed every rule and submitted all required documentation on time.","translation":"公司嚴格遵守環境法規給政府檢查員留下深刻印象。他們遵循每項規則並按時提交所有必需的文件。","word":"compliance"}},"comply":{"createdAt":1781332009078,"q":{"answer":1,"explanation":"comply 意為順從或遵守，表示按照規則或要求行動","options":["ignore","comply","break","violate"],"sentence":"All employees must ______ with the company's safety regulations without exception. The workplace has strict rules that everyone is required to follow.","translation":"所有員工都必須順從公司的安全規定，毫無例外。工作場所有所有人都必須遵守的嚴格規則。","word":"comply"}},"compromise":{"createdAt":1781343050504,"q":{"answer":2,"explanation":"compromise 指雙方各退一步、互相讓步達成的協議，通常各方都需要放棄部分要求。","options":["victory","defeat","compromise","agreement"],"sentence":"After hours of negotiation, both parties reached a ______ that satisfied neither side completely. Each side had to give up some of their original demands to reach an agreement.","translation":"經過數小時的談判，雙方達成了妥協，都不完全滿意。雙方都不得不放棄他們最初的一些要求才能達成協議。","word":"compromise"}},"compute":{"createdAt":1781332009078,"q":{"answer":1,"explanation":"compute 意為用機器或計算方法來計算或算出","options":["estimate","compute","guess","ignore"],"sentence":"The accountant used specialized software to ______ the company's annual financial statements. The calculations were complex and required precision to ensure accuracy.","translation":"會計師使用專門的軟件計算公司的年度財務報表。這些計算很複雜，需要精確確保準確性。","word":"compute"}},"conceal":{"createdAt":1781311685838,"q":{"answer":1,"explanation":"conceal意為隱藏或掩蓋，通常指故意將某物藏起來以避免被發現。","options":["display","hide","analyze","transport"],"sentence":"The criminal tried to ______ the evidence by burying it in the forest. However, the investigators discovered it buried under the old oak tree.","translation":"犯人試圖通過將證據埋在森林裡來隱藏它。然而，調查人員發現它被埋在老橡樹下。","word":"conceal"}},"conceive":{"createdAt":1781323901178,"q":{"answer":1,"explanation":"conceive意為「構思」或「想像」，在此指科學家想出並發展了一個新的治療方案。","options":["abandon","conceive","dismiss","reject"],"sentence":"The scientist was able to ______ a revolutionary new treatment for the disease. After years of research and collaboration, her team finally brought this groundbreaking idea to life.","translation":"科學家能夠構思一種革命性的疾病新療法。經過多年的研究和合作，她的團隊終於將這個突破性的想法付諸實現。","word":"conceive"}},"concentrate":{"createdAt":1781332009077,"q":{"answer":1,"explanation":"concentrate 意為集中或集結，通常用於指集中注意力或將心力聚集在一件事上","options":["relax","concentrate","quit","sleep"],"sentence":"The student needed to ______ on her studies to improve her grades. With fewer distractions and dedicated study time, her academic performance improved significantly.","translation":"學生需要集中精力學習以提高成績。減少干擾和投入專門的學習時間後，她的學習成績明顯改善。","word":"concentrate"}},"confess":{"createdAt":1781274482556,"q":{"answer":1,"explanation":"confess指坦白承認錯誤或犯罪，通常涉及詳細說明事實。","options":["deny","confess","ignore","question"],"sentence":"The suspect decided to ______ his guilt to the police officer. He admitted to committing the crime and provided a detailed account of what happened.","translation":"嫌疑人決定向警官承認他的罪行。他承認犯了罪並提供了發生情況的詳細說明。","word":"confess"}},"confession":{"createdAt":1781272410988,"q":{"answer":2,"explanation":"confession指的是主動坦白或供認自己的錯誤、罪行等，通常是向當局或他人承認自己做了什麼。","options":["denial","promise","confession","complaint"],"sentence":"The suspect made a ______ to the police, admitting that he had stolen the diamond. His testimony was the key evidence that solved the case.","translation":"嫌疑人向警察坦白承認了他偷了鑽石。他的證詞是破案的關鍵證據。","word":"confession"}},"confidential":{"createdAt":1781337343695,"q":{"answer":2,"explanation":"confidential意為機密的、秘密的，用於形容需要保護的敏感資訊。","options":["public","famous","confidential","broken"],"sentence":"The company kept the new product design ______ to prevent competitors from stealing the idea. Only the executive team had access to the blueprints and specifications.","translation":"公司將新產品設計保密，以防止競爭對手竊取想法。只有執行團隊能夠獲得藍圖和規格說明書。","word":"confidential"}},"confusing":{"createdAt":1781332009081,"q":{"answer":1,"explanation":"confusing 是形容詞，表示使人困惑的、令人感到不明白的","options":["clear","confusing","simple","helpful"],"sentence":"The instruction manual was quite ______ with unclear diagrams and poorly written explanations. Customers had difficulty assembling the product and complained about the lack of clarity.","translation":"說明書非常令人困惑，圖表不清楚，解釋寫得很差。客戶在組裝產品時遇到困難，並抱怨缺乏清晰性。","word":"confusing"}},"consequently":{"createdAt":1781332009074,"q":{"answer":1,"explanation":"consequently 是副詞，表示結果或因此，用於說明某事是另一事件的結果","options":["however","consequently","although","meanwhile"],"sentence":"The storm caused severe damage to the power lines; ______, thousands of people lost electricity. The outage lasted for three days until repairs were completed.","translation":"暴風雨對電力線造成了嚴重損壞；因而，數千人失去了電力。停電持續了三天，直到維修完成。","word":"consequently"}},"considerate":{"createdAt":1781337343698,"q":{"answer":2,"explanation":"considerate意為體貼的、周到的或關心他人感受的。","options":["rude","selfish","considerate","lazy"],"sentence":"James is a very ______ friend who always remembers everyone's birthdays and asks about their problems. He shows genuine concern for others' feelings and well-being in every interaction.","translation":"詹姆斯是一位非常體貼的朋友，他總是記得每個人的生日並關心他們的問題。他在每次互動中都表現出對他人感受和福祉的真誠關心。","word":"considerate"}},"contemplation":{"createdAt":1781362281660,"q":{"answer":1,"explanation":"contemplation表示深思或沉思，指認真思考某事的過程。","options":["action","contemplation","movement","celebration"],"sentence":"After hours of ______, she finally made a decision about her career change. She had carefully thought through all the options and consequences.","translation":"經過數小時的沉思，她終於做出了關於職業改變的決定。她已經仔細考慮了所有的選項和後果。","word":"contemplation"}},"contradict":{"createdAt":1781336858152,"q":{"answer":2,"explanation":"contradict 動詞表示說出相反或相衝突的陳述，使某事變得不可信或互相衝突。","options":["supports","validates","contradicts","confirms"],"sentence":"His statement ______ what he had said the previous day. When confronted with the evidence, he could not explain the inconsistency in his accounts.","translation":"他的陳述與他前一天說過的話相矛盾。當面對證據時，他無法解釋他敘述中的不一致之處。","word":"contradict"}},"controversial":{"createdAt":1781275226789,"q":{"answer":0,"explanation":"此處controversial作形容詞表示「有爭議的；引起爭議的」","options":["controversial","breast","digestion","abroad"],"sentence":"The politician's ______ speech sparked heated debates in newspapers and social media. People on both sides couldn't agree on whether his statements were right or wrong.","translation":"這位政治家的有爭議的演講在報紙和社群媒體上引發了激烈辯論。雙方的人都對他的言論是否正確無法達成共識。","word":"controversial"}},"convention":{"createdAt":1781414884518,"q":{"answer":0,"explanation":"convention在這裡指大型會議或集會，是業界人士聚集交流的正式活動。","options":["convention","schedule","performance","dream"],"sentence":"The annual film ______ attracted thousands of directors and producers from around the world. Attendees gathered to discuss new trends and network with industry professionals.","translation":"年度電影大會吸引了來自世界各地的數千名導演和製作人。與會者聚集在一起討論新趨勢並與行業專業人士建立聯繫。","word":"convention"}},"conversion":{"createdAt":1781274482562,"q":{"answer":2,"explanation":"conversion指將某物從一種形式或用途轉變為另一種形式或用途。","options":["destruction","construction","conversion","collection"],"sentence":"The old warehouse underwent a dramatic ______ into a modern art gallery. The transformation took two years to complete and created a stunning cultural venue for the community.","translation":"舊倉庫經歷了戲劇性的轉變，變成了現代美術館。這次改造花了兩年才完成，為社區創造了一個令人驚嘆的文化場所。","word":"conversion"}},"corporate":{"createdAt":1781311685837,"q":{"answer":2,"explanation":"corporate指的是整個公司或組織層面的決策與規則，適用於所有成員，而非個人或特定地區的。","options":["individual","regional","official","personal"],"sentence":"The ______ policy was decided by the board of directors at the company meeting. All employees across every department must follow these rules without exception.","translation":"公司政策由董事會在公司會議上決定。所有部門的每個員工都必須遵守這些規則，沒有例外。","word":"corporate"}},"costume":{"createdAt":1781332009070,"q":{"answer":1,"explanation":"costume 指的是為舞台表演或角色扮演設計的戲服或服裝","options":["weapon","costume","script","microphone"],"sentence":"The actress wore an elaborate ______ for the historical drama production. The wardrobe department spent weeks creating the period-appropriate clothing and accessories.","translation":"女演員為這部歷史劇製作穿著了精美的戲服。服裝部門花了數周時間創作符合時代的衣服和配飾。","word":"costume"}},"counsel":{"createdAt":1781256444516,"q":{"answer":1,"explanation":"counsel作動詞表示提供建議或勸告，通常由有經驗的人對他人提出專業意見。","options":["inspect","counsel","criticize","assign"],"sentence":"The career advisor will ______ students on which university programs best match their interests. She has helped hundreds of graduates find fulfilling career paths over her twenty years of experience.","translation":"職業顧問將就哪些大學課程最符合學生的興趣向他們提出建議。在她二十年的職業生涯中，她已幫助數百名畢業生找到了令人滿意的職業道路。","word":"counsel"}},"creation":{"createdAt":1781268630487,"q":{"answer":1,"explanation":"creation指的是創造或創作，是指某人製作或創作的東西。","options":["destruction","creation","collection","exhibition"],"sentence":"The artist was very proud of her latest ______ which took her six months to complete. The sculpture was a masterpiece of modern art.","translation":"藝術家為她耗時六個月完成的最新作品感到非常自豪。這件雕塑是現代藝術的傑作。","word":"creation"}},"creative":{"createdAt":1781268630476,"q":{"answer":2,"explanation":"creative指的是具有創造力或創意的，能夠想出新的、原創的想法或解決方案。","options":["logical","practical","creative","analytical"],"sentence":"Sarah has a very ______ mind that allows her to solve problems in unique ways. She often finds novel solutions that others would never think of.","translation":"莎拉有一個非常有創造力的頭腦，使她能夠以獨特的方式解決問題。她經常找到其他人永遠不會想到的新穎解決方案。","word":"creative"}},"crippled":{"createdAt":1781417610421,"q":{"answer":2,"explanation":"crippled是指身體殘廢或受傷，導致行動困難或喪失某些功能。","options":["wealthy","intelligent","crippled","tall"],"sentence":"The ______ knight struggled to walk up the stone staircase despite his determination. His leg injury from the battle prevented him from moving quickly or without pain.","translation":"這位殘廢的騎士儘管決心十足，仍然難以上石階。他在戰鬥中的腿部傷害阻止了他快速移動或無痛移動。","word":"crippled"}},"criticize":{"createdAt":1781283344040,"q":{"answer":1,"explanation":"criticize意為指出缺點或不足之處；當與「指出具體錯誤」和「提供改進建議」搭配時，表示進行建設性的評論。","options":["praise","criticize","ignore","summarize"],"sentence":"The teacher decided to ______ the student's essay for its numerous grammatical errors. She pointed out specific mistakes and offered constructive suggestions for improvement.","translation":"老師決定批評學生的論文因為它有許多文法錯誤。她指出具體的錯誤並提供改進建議。","word":"criticize"}},"crowd":{"createdAt":1781274836864,"q":{"answer":0,"explanation":"crowd作為名詞表示聚集在一起的大量人群，通常表現出擁擠和混亂的狀態。","options":["crowd","line","team","parade"],"sentence":"A large ______ gathered outside the concert venue before the gates opened. Thousands of excited fans pushed and shoved to get the best positions for the show.","translation":"在演唱會場地大門打開前，一大群人聚集在外面。數千名興奮的粉絲互相推擠以獲得最佳位置看演出。","word":"crowd"}},"cruise":{"createdAt":1781268630483,"q":{"answer":1,"explanation":"cruise指的是乘船遊覽，通常是一次休閒的海上旅行，船會停靠多個港口。","options":["flight","cruise","safari","expedition"],"sentence":"They booked a Caribbean ______ for their honeymoon. The ship would stop at five different tropical islands over two weeks.","translation":"他們為蜜月預訂了一次加勒比海遊輪之旅。這艘船將在兩周內停靠五個不同的熱帶島嶼。","word":"cruise"}},"crystal":{"createdAt":1781256444507,"q":{"answer":1,"explanation":"crystal在此指手錶或鐘錶的玻璃蓋，既透明又具有保護作用。","options":["leather","crystal","metal","fabric"],"sentence":"The antique pocket watch had a protective ______ covering its face. Without this transparent shield, the delicate hands inside would be exposed to dust and damage.","translation":"古董懷錶的錶面有一層保護性的水晶玻璃。沒有這層透明的保護罩，裡面的精緻指針會暴露在灰塵和損害中。","word":"crystal"}},"cuisine":{"createdAt":1781362281726,"q":{"answer":1,"explanation":"cuisine指的是烹飪或烹調風格，特別是某個地區或國家的特色菜餚。","options":["music","cuisine","art","fashion"],"sentence":"The restaurant specializes in Thai ______ with authentic recipes. The chefs use traditional cooking methods and genuine ingredients from Thailand.","translation":"這家餐廳專門提供泰國烹飪，採用正宗食譜。廚師使用傳統的烹飪方法和來自泰國的真正食材。","word":"cuisine"}},"curfew":{"createdAt":1781364476360,"q":{"answer":1,"explanation":"Curfew是指政府為了維持秩序或安全而規定的在特定時間後禁止人們外出的法令。","options":["holiday","curfew","festival","meeting"],"sentence":"During the emergency, the government imposed a strict ______ that required all residents to stay indoors after 8 PM. Police patrolled the streets to ensure compliance with this mandatory time restriction.","translation":"在緊急狀況期間，政府實施了嚴格的宵禁，要求所有居民必須在晚上8點後待在室內。警察在街上巡邏，以確保遵守這項強制性的時間限制。","word":"curfew"}},"custom":{"createdAt":1781336858149,"q":{"answer":2,"explanation":"custom 指的是在特定文化或社會中代代相傳的習慣或傳統做法。","options":["law","accident","custom","mistake"],"sentence":"In Japan, it is a ______ to remove your shoes before entering someone's home. This tradition has been practiced for centuries and is still widely respected today.","translation":"在日本，進入他人家中前脫掉鞋子是一個習俗。這個傳統已經被實踐了幾個世紀，今天仍然得到廣泛尊重。","word":"custom"}},"dazzle":{"createdAt":1781275226789,"q":{"answer":2,"explanation":"此處dazzle作動詞表示「使感到刺眼；使目眩」","options":["dump","breast","dazzle","stroke"],"sentence":"The fireworks display continued to ______ the audience with brilliant colors and unexpected explosions. Their eyes were overwhelmed by the stunning brightness of each burst.","translation":"煙火表演繼續以炫目的色彩和意想不到的爆炸使觀眾眼花繚亂。每一次爆發的驚人亮度都讓他們的眼睛感到刺眼。","word":"dazzle"}},"deal":{"createdAt":1781395310166,"q":{"answer":2,"explanation":"deal 作為動詞表示應付、處理某種情況或問題。","options":["ignore","avoid","deal","celebrate"],"sentence":"The manager had to ______ with three customer complaints before lunch. She handled each issue professionally and resolved them all within an hour.","translation":"經理必須在午餐前應付三個客戶投訴。她專業地處理了每個問題並在一小時內全部解決。","word":"deal"}},"deceit":{"createdAt":1781283344055,"q":{"answer":1,"explanation":"deceit意為欺騙、詐欺；與「虛假宣傳」和「調查揭露真相」搭配，表示故意誤導他人的行為。","options":["honesty","deceit","compliance","transparency"],"sentence":"The company was involved in ______ when it falsely advertised that its products were environmentally friendly. Investigations revealed that the manufacturing process actually produced significant pollution.","translation":"該公司因虛假宣傳其產品環保而涉及欺騙。調查顯示製造過程實際上產生了大量污染。","word":"deceit"}},"decorate":{"createdAt":1781395310168,"q":{"answer":1,"explanation":"decorate 表示為空間或物品進行美化或點綴以使其更加吸引人。","options":["demolish","decorate","abandon","damage"],"sentence":"The team decided to ______ the office for the holiday party with colorful balloons and lights. By evening, the plain gray walls had been transformed into a festive wonderland.","translation":"團隊決定用彩色氣球和燈光為假日派對裝飾辦公室。到了晚上，樸素的灰色牆壁已經變成了一個節日樂園。","word":"decorate"}},"decrease":{"createdAt":1781362281654,"q":{"answer":1,"explanation":"decrease表示減少或降低，通常用於數量、程度或強度的下降。","options":["increase","decrease","stabilize","fluctuate"],"sentence":"The company's profits will ______ if they don't reduce operational costs. The financial reports show fewer sales this quarter compared to last year.","translation":"如果公司不降低運營成本，利潤將會減少。財務報告顯示本季度的銷售額少於去年。","word":"decrease"}},"defect":{"createdAt":1781395310155,"q":{"answer":1,"explanation":"defect 指物品或系統中的問題或不完美之處，這裡用於描述需要修復的故障。","options":["strength","defect","feature","benefit"],"sentence":"The manufacturer discovered a ______ in the product that could affect safety. Engineers immediately recalled all units to fix this flaw before it reached consumers.","translation":"製造商發現產品中的缺陷可能會影響安全。工程師立即召回所有單位，在缺陷到達消費者之前進行修復。","word":"defect"}},"define":{"createdAt":1781395310172,"q":{"answer":1,"explanation":"define 表示給予清晰的定義或詳細說明某個詞語、概念或事物的確切含義。","options":["erase","define","illustrate","memorize"],"sentence":"The teacher asked students to ______ the term 'photosynthesis' in their own words during the exam. Each student had to provide a clear explanation of what the process means and how it works.","translation":"老師要求學生在考試中用自己的話定義「光合作用」這一術語。每個學生都必須清楚地解釋該過程的含義及其工作方式。","word":"define"}},"definitely":{"createdAt":1781283344047,"q":{"answer":1,"explanation":"definitely意為確實地、肯定地；與「已經註冊和預訂」的事實搭配，表示非常確定的態度。","options":["might","definitely","probably","possibly"],"sentence":"I will ______ attend the conference next month without any doubt. I have already registered and booked my hotel room.","translation":"我絕對會參加下個月的會議，毫無疑問。我已經註冊並預訂了酒店房間。","word":"definitely"}},"degree":{"createdAt":1781395310169,"q":{"answer":2,"explanation":"degree 表示溫度、程度或強度的度量單位，這裡指溫度的測量值。","options":["color","sound","degree","texture"],"sentence":"The heat in the desert reached an extreme ______ of 50 degrees Celsius during the afternoon. Residents stayed indoors to avoid the dangerous temperature.","translation":"沙漠中的高溫在下午達到了極端的50攝氏度。居民們呆在室內以避免危險的溫度。","word":"degree"}},"deliberate":{"createdAt":1781401803898,"q":{"answer":1,"explanation":"deliberate作形容詞表示「經過深思熟慮的」，強調在做出決定或回答前經過充分考慮。","options":["hasty","thoughtful","automatic","confused"],"sentence":"The student gave a ______ answer to the difficult question during the exam. She paused for a moment, thought carefully, and then spoke with confidence and precision.","translation":"那個學生在考試中對難題給出了經過深思熟慮的答案。她停頓了一下，仔細思考，然後自信而準確地說話。","word":"deliberate"}},"demonstrate":{"createdAt":1781283344054,"q":{"answer":1,"explanation":"demonstrate意為示範、展示；與「培訓會」和「員工看到實際操作」搭配，表示向他人展示如何使用或操作某物。","options":["criticize","demonstrate","estimate","document"],"sentence":"The engineer will ______ how the new software system works during the company training session tomorrow. All employees will have the opportunity to see the features in action and ask questions.","translation":"工程師將在明天的公司培訓會上示範新軟體系統的工作方式。所有員工將有機會看到實際操作並提出問題。","word":"demonstrate"}},"deny":{"createdAt":1781332009068,"q":{"answer":1,"explanation":"deny 意為否認或拒絕承認某事，尤其是在面對指控時","options":["admit","deny","ignore","celebrate"],"sentence":"The suspect continued to ______ all accusations of theft during the interrogation. However, security cameras had recorded him taking the items from the store.","translation":"嫌疑人在審訊中繼續否認所有的盜竊指控。然而，安全攝像頭錄下了他從商店拿走這些物品的過程。","word":"deny"}},"deplete":{"createdAt":1781395310167,"q":{"answer":2,"explanation":"deplete 表示大量減少或耗盡資源，使其變得稀少。","options":["increase","replenish","deplete","multiply"],"sentence":"Excessive fishing has begun to ______ the ocean's fish populations at an alarming rate. Scientists warn that if this continues, many species may disappear entirely within decades.","translation":"過度捕撈已開始以驚人的速度耗盡海洋的魚類資源。科學家警告，如果這種情況繼續下去，許多物種可能在幾十年內完全消失。","word":"deplete"}},"deposit":{"createdAt":1781395310163,"q":{"answer":1,"explanation":"deposit 作為名詞表示存入銀行的錢款或作為動詞表示將錢存入銀行。","options":["withdrawal","deposit","loan","mortgage"],"sentence":"She made a ______ at the bank to save money for her future. The teller accepted her $500 payment and credited it to her savings account.","translation":"她在銀行進行存款以為未來儲蓄。出納員接受了她的500美元付款並將其計入她的儲蓄賬戶。","word":"deposit"}},"depression":{"createdAt":1781283344048,"q":{"answer":1,"explanation":"depression意為心理沮喪或精神疾病（憂鬱症）；與「處方藥物」和「心理治療」搭配，表示需要醫療介入的精神狀況。","options":["anxiety","depression","stress","tiredness"],"sentence":"Sarah has been suffering from ______ for over a year and finds it difficult to enjoy activities she once loved. Her therapist has prescribed medication and recommended regular counseling sessions.","translation":"莎拉一年多來一直遭受抑鬱症的困擾，發現很難享受她曾經喜愛的活動。她的治療師開了藥物處方並建議定期諮詢。","word":"depression"}},"derive":{"createdAt":1781362281655,"q":{"answer":1,"explanation":"derive表示源自或得自某處，指事物的起源或來源。","options":["create","derive","invent","form"],"sentence":"The word 'democracy' is ______ from Greek words meaning 'people' and 'rule'. Scholars trace its origins back to ancient Greece.","translation":"'民主'這個詞源自希臘語，意思是'人民'和'統治'。學者將其起源追溯到古希臘。","word":"derive"}},"desirable":{"createdAt":1781283344051,"q":{"answer":1,"explanation":"desirable意為渴望獲得的、令人想要的；與「願意支付更高房租」搭配，表示高度受歡迎和珍視的特性。","options":["rare","desirable","problematic","unavailable"],"sentence":"Living near public transportation is a ______ feature for many urban professionals. Those who commute daily are willing to pay higher rent for this convenience.","translation":"住在公共交通附近對許多都市專業人士來說是一個渴望獲得的特點。每天通勤的人願意為這種便利支付更高的房租。","word":"desirable"}},"destruction":{"createdAt":1781345564013,"q":{"answer":1,"explanation":"destruction 是指大規模的破壞或毀滅，常用來描述戰爭、自然災害或重大災難造成的損害。","options":["creation","destruction","construction","production"],"sentence":"The hurricane caused massive ______ to the coastal city. Buildings were flattened, roads were torn apart, and thousands of people lost their homes.","translation":"颶風對沿海城市造成了大規模的毀滅。建築物被夷為平地，道路被摧毀，數千人失去了家園。","word":"destruction"}},"detect":{"createdAt":1781395310165,"q":{"answer":1,"explanation":"detect 表示發現、察覺到原本未被發現的事物，通常指通過工具或感官識別。","options":["ignore","detect","welcome","announce"],"sentence":"The security system failed to ______ the intruder until he was already inside the building. The alarm should have alerted guards the moment someone attempted to enter.","translation":"安全系統未能在入侵者進入建築物時發現他。警報應該在有人試圖進入的那一刻提醒警衛。","word":"detect"}},"detective":{"createdAt":1781274482547,"q":{"answer":1,"explanation":"detective指從事調查犯罪案件的執法人員，必須蒐集證據並破案。","options":["actor","detective","reporter","teacher"],"sentence":"The ______ spent months investigating the mysterious disappearance. She gathered evidence, interviewed witnesses, and finally solved the case.","translation":"那位偵探花了數月時間調查神秘失蹤案。她蒐集證據、詢問證人，最終破案了。","word":"detective"}},"develop":{"createdAt":1781395310168,"q":{"answer":2,"explanation":"develop 表示逐步創造、改進或使某事物成長並達到成熟的狀態。","options":["destroy","abandon","develop","ignore"],"sentence":"The startup spent two years to ______ a revolutionary new smartphone application. The finished product received excellent reviews from technology critics and millions of downloads.","translation":"該初創公司花費兩年時間開發了一種革命性的新智慧手機應用程式。完成的產品獲得了科技評論家的好評和數百萬次下載。","word":"develop"}},"diagnose":{"createdAt":1781283344046,"q":{"answer":1,"explanation":"diagnose意為確定或識別疾病；後面提到「檢查結果後確定」，表示通過檢驗得出診斷結論。","options":["cure","diagnose","prevent","treat"],"sentence":"The doctor ran several tests to ______ the patient's mysterious illness. After examining the blood work and imaging results, she determined it was a thyroid disorder.","translation":"醫生進行了幾項檢查來診斷患者神秘的疾病。檢查血液檢驗和影像檢查結果後，她確定這是甲狀腺疾病。","word":"diagnose"}},"digestion":{"createdAt":1781275226788,"q":{"answer":2,"explanation":"此處digestion指「消化」的過程，特別是食物在胃中的處理","options":["feast","stroke","digestion","dazzle"],"sentence":"After eating a large meal, his ______ was slow and uncomfortable. He felt bloated for hours because his stomach needed more time to process the food.","translation":"吃完一頓大餐後，他的消化很慢且不舒服。他感到腹脹持續數小時，因為他的胃需要更多時間來消化食物。","word":"digestion"}},"dip":{"createdAt":1781311922070,"q":{"answer":1,"explanation":"dip 表示短暫地將某物浸入液體中，通常是為了檢查或品嚐。","options":["drop","dip","throw","push"],"sentence":"Before eating the hot soup, I decided to ______ my spoon into it to test the temperature. The liquid was too hot, so I waited a few more minutes before starting my meal.","translation":"在吃熱湯之前，我決定把湯匙浸入其中來測試溫度。液體太熱了，所以我等了幾分鐘才開始用餐。","word":"dip"}},"discrimination":{"createdAt":1781256444519,"q":{"answer":1,"explanation":"discrimination在此指辨別力或區分能力，用於做出精明和公正的判斷。","options":["bias","discrimination","preference","favoritism"],"sentence":"The selection committee showed excellent ______ in choosing the scholarship winner by carefully evaluating each applicant's academic achievements and personal qualities. Their thoughtful assessment ensured the most deserving student received the award.","translation":"評選委員會在選擇獎學金得主時表現出卓越的辨別力，仔細評估了每位申請人的學術成就和個人素質。他們深思熟慮的評估確保了最值得的學生獲得了獎項。","word":"discrimination"}},"disposable":{"createdAt":1781283344049,"q":{"answer":1,"explanation":"disposable意為可拋棄的、用完即丟的；與「減少洗碗時間」和「環境廢棄物問題」搭配，表示一次性使用的產品。","options":["ceramic","disposable","glass","metal"],"sentence":"The restaurant switched to ______ cups to reduce the time spent washing dishes after service. However, this decision raised concerns about environmental waste.","translation":"餐廳改用用完即丟的杯子來減少服務後洗碗的時間。然而，這個決定引起了對環境廢棄物的擔憂。","word":"disposable"}},"disposables":{"createdAt":1781403377827,"q":{"answer":1,"explanation":"disposables 指的是可以拋棄或一次性使用的物品，通常用於描述餐具、包裝等日常消費品。","options":["permanent dishes","disposables","decorations","supplies"],"sentence":"The restaurant switched to ______ to reduce their environmental impact. They now use paper plates and plastic utensils that can be thrown away after each meal.","translation":"這家餐廳改用一次性用品來減少環境影響。他們現在使用紙盤和塑膠餐具，這些在每頓飯後都可以丟棄。","word":"disposables"}},"disposal":{"createdAt":1781283344053,"q":{"answer":1,"explanation":"disposal意為處置、處理；與「環保法規」和「安全移除」搭配，表示按照規定處理有害物質的過程。","options":["storage","disposal","production","inventory"],"sentence":"The hazardous waste requires proper ______ according to environmental regulations and safety standards. The company hired a specialized firm to handle the removal process safely.","translation":"根據環保法規和安全標準，危險廢棄物需要妥善處理。公司聘請了一家專業公司來安全地處理移除過程。","word":"disposal"}},"distinct":{"createdAt":1781272410979,"q":{"answer":1,"explanation":"distinct表示清楚可見的、易於辨別的，用來形容事物之間明顯的區別。","options":["similar","distinct","expensive","ancient"],"sentence":"The two paintings have ______ styles that make them easy to tell apart. Even a child can recognize the differences between them immediately.","translation":"這兩幅畫有明顯不同的風格，使人們很容易區分它們。即使是小孩也能立即認出它們之間的差異。","word":"distinct"}},"disturb":{"createdAt":1781283344049,"q":{"answer":1,"explanation":"disturb意為妨礙或打擾；與「保持音量低」和「輕輕移動」搭配，表示避免任何可能影響睡眠的動作。","options":["comfort","disturb","feed","bathe"],"sentence":"Please do not ______ the sleeping baby as she needs rest to recover from her fever. Keep the volume low and move quietly around the house.","translation":"請不要打擾睡著的寶寶，因為她需要休息來從發燒中恢復。保持音量低並在屋子裡輕輕移動。","word":"disturb"}},"disturbance":{"createdAt":1781362281723,"q":{"answer":1,"explanation":"disturbance表示打擾或干擾，指破壞安寧或正常秩序的行為。","options":["joy","disturbance","pleasure","comfort"],"sentence":"The loud noise from the construction site caused ______ to the neighbors. Residents complained about the constant interruption to their peace.","translation":"建築工地的噪音對鄰居造成了打擾。居民抱怨他們的寧靜受到了持續的干擾。","word":"disturbance"}},"diversify":{"createdAt":1781417610417,"q":{"answer":2,"explanation":"diversify是指使事物變得多樣化或涉足多個不同的領域以降低風險。","options":["consolidate","simplify","diversify","reduce"],"sentence":"The company decided to ______ its product line by entering new markets. Instead of relying solely on electronics, they began producing clothing, furniture, and household goods.","translation":"公司決定通過進入新市場來使其產品線多樣化。他們不再只依賴電子產品，而是開始生產衣服、家具和家用商品。","word":"diversify"}},"divide":{"createdAt":1781362281729,"q":{"answer":1,"explanation":"divide表示分開或分裂，指因為不同的意見或利益而導致分離或衝突。","options":["unite","divide","strengthen","develop"],"sentence":"The controversial issue will ______ the community into different groups. Citizens have strong opposing opinions about the proposed development project.","translation":"這個有爭議的問題將使社區分成不同的團體。市民對提議的發展項目有著強烈的相反意見。","word":"divide"}},"drown":{"createdAt":1781345564015,"q":{"answer":1,"explanation":"drown 表示在水中溺水身亡或被水淹沒，通常描述危險或致命的水上事故。","options":["float","drown","swim","paddle"],"sentence":"The man began to ______ in the deep ocean as the waves pulled him under. Lifeguards immediately dove in and rescued him before it was too late.","translation":"當海浪把他拖入水下時，這名男子開始在深海中溺水。救生員立即跳入水中，在為時已晚之前救了他。","word":"drown"}},"drowsy":{"createdAt":1781310338174,"q":{"answer":1,"explanation":"drowsy 表示困倦、昏昏欲睡的狀態，通常是因為疲勞或缺乏睡眠。","options":["alert","drowsy","energetic","anxious"],"sentence":"After working the night shift, the security guard felt increasingly ______ as morning approached. He struggled to keep his eyes open and had difficulty concentrating on his duties.","translation":"在上完夜班後，隨著早晨的臨近，保安感到越來越昏昏欲睡。他很難睜開眼睛，在執行職務時難以集中注意力。","word":"drowsy"}},"drunk":{"createdAt":1781362281651,"q":{"answer":1,"explanation":"drunk是drink的過去分詞，表示已經喝下去，也可作形容詞表示醉酒的狀態。","options":["eaten","drunk","spent","bought"],"sentence":"He had ______ too much wine at the party and could barely stand. His stumbling walk and slurred speech made it clear he was intoxicated.","translation":"他在派對上喝了太多葡萄酒，幾乎站不住。他踉蹌的步態和含糊的言語清楚地表明他醉了。","word":"drunk"}},"dubious":{"createdAt":1781359980245,"q":{"answer":1,"explanation":"dubious指令人懷疑、可疑或值得懷疑的；表示對某事的真實性或可信度持懷疑態度。","options":["reliable","dubious","popular","expensive"],"sentence":"The ______ claim that the product could cure all diseases within days raised serious concerns among health officials. Independent testing found no scientific support for these extraordinary promises.","translation":"該產品能在幾天內治癒所有疾病的可疑說法引起了衛生官員的嚴重關注。獨立測試發現這些非凡承諾沒有科學支持。","word":"dubious"}},"dump":{"createdAt":1781275226790,"q":{"answer":2,"explanation":"此處dump作動詞表示「傾倒；丟棄」，指將廢棄物放在特定地點","options":["stroke","dazzle","dump","feast"],"sentence":"The construction company had to ______ tons of waste material at the designated site. The environmental regulations required them to dispose of it properly and legally.","translation":"建築公司必須在指定地點傾倒數噸的廢料。環保法規要求他們合法地妥善處理它。","word":"dump"}},"empirical":{"createdAt":1781359980239,"q":{"answer":1,"explanation":"empirical指基於實驗觀察和實際數據而非理論的；強調通過親身經驗或實驗驗證的方式獲得的知識。","options":["theoretical","empirical","hypothetical","abstract"],"sentence":"The scientist's ______ evidence was based on carefully controlled experiments and measurements. She collected data over five years rather than relying on theories or assumptions.","translation":"科學家的經驗證據是基於仔細控制的實驗和測量。她用了五年時間蒐集資料，而不是依賴理論或假設。","word":"empirical"}},"enlighten":{"createdAt":1781323901187,"q":{"answer":2,"explanation":"enlighten意為「啟迪」或「開導」，表示通過提供信息和知識來消除他人的誤解。","options":["confuse","mislead","enlighten","deceive"],"sentence":"The teacher's lecture helped ______ students about the true causes of climate change. By presenting scientific evidence and data, she cleared up many misconceptions they had held.","translation":"老師的講座幫助開導學生了解氣候變化的真正原因。通過呈現科學證據和數據，她消除了他們持有的許多誤解。","word":"enlighten"}},"ensure":{"createdAt":1781362281665,"q":{"answer":1,"explanation":"ensure表示擔保或確保某事肯定會發生，強調保證和確定性。","options":["ignore","ensure","question","dispute"],"sentence":"The safety inspectors will ______ that the building meets all building codes. They conduct thorough checks before issuing approval certificates.","translation":"安全檢查員將確保建築物符合所有建築法規。他們在頒發批准證書前進行徹底檢查。","word":"ensure"}},"enthusiasm":{"createdAt":1781274836862,"q":{"answer":1,"explanation":"enthusiasm表示對某事的熱心和熱忱，特別是指積極且充滿能量的態度。","options":["laziness","enthusiasm","confusion","criticism"],"sentence":"The team played with great ______ throughout the entire championship match. Their energy and positive attitude inspired everyone in the stadium to cheer loudly.","translation":"這支隊伍在整個錦標賽比賽中以極大的熱心參賽。他們的能量和積極態度激勵了體育館裡的每個人大聲歡呼。","word":"enthusiasm"}},"epidemic":{"createdAt":1781256485489,"q":{"answer":1,"explanation":"epidemic指的是在特定地區或時期內迅速傳播的疾病或流行性疾病","options":["celebration","epidemic","mystery","scandal"],"sentence":"The ______ spread rapidly through the city, affecting thousands of residents. Health officials declared a state of emergency because the infectious disease was out of control.","translation":"這場傳染病迅速蔓延到整個城市，影響了數千名居民。衛生官員宣布進入緊急狀態，因為這種傳染性疾病已失控。","word":"epidemic"}},"equivalent":{"createdAt":1781402539338,"q":{"answer":1,"explanation":"equivalent 表示在價值、意義或功能上相等或相當，雖然形式可能不同。","options":["superior","equivalent","inferior","identical"],"sentence":"A passing grade of 60% is ______ to a D mark on the letter scale. Both represent the minimum acceptable performance level.","translation":"60%的及格分數相當於字母等級中的D分。兩者都代表最低可接受的表現水平。","word":"equivalent"}},"escape":{"createdAt":1781332009068,"q":{"answer":1,"explanation":"escape 意為逃跑或逃脫某個地方或情況","options":["enter","escape","sleep","work"],"sentence":"The prisoners planned to ______ from the maximum-security facility by tunneling under the fence. They successfully fled and were not recaptured for several months.","translation":"囚犯計畫通過在圍欄下挖隧道來逃跑。他們成功逃脫，並在幾個月內沒有被重新逮捕。","word":"escape"}},"estimate":{"createdAt":1781331945989,"q":{"answer":2,"explanation":"estimate 指根據可用信息進行合理的估計或預算，通常涉及計算或評價。","options":["ignore","guess","estimate","remember"],"sentence":"The contractor asked me to ______ how much money I would need for home renovations. Based on the materials, labor costs, and the scope of work described, he predicted the project would cost around thirty thousand dollars.","translation":"承包商要求我估計進行房屋翻新需要多少錢。根據所述的材料、勞動力成本和工作範圍，他預測該項目將花費大約三萬美元。","word":"estimate"}},"eta":{"createdAt":1781228443753,"q":{"answer":2,"explanation":"Eta是希臘字母表中的第七個字母，在物理學中常用來代表效率、黏度等物理量。","options":["zeta","theta","eta","iota"],"sentence":"The seventh letter of the Greek alphabet is ______. Students learning about efficiency and viscosity in physics class regularly encounter this symbol in their textbooks.","translation":"希臘字母表中的第七個字母是______。學生在物理課堂上學習效率和黏度時，經常在教科書中遇到這個符號。","word":"eta"}},"ethical":{"createdAt":1781256444518,"q":{"answer":1,"explanation":"ethical指符合道德和倫理原則的，強調正直和誠實的行為標準。","options":["strict","ethical","marketing","financial"],"sentence":"The company's ______ standards require all employees to report conflicts of interest immediately. This policy ensures that business decisions are made with integrity and transparency.","translation":"公司的道德標準要求所有員工立即報告利益衝突。該政策確保業務決策以誠信和透明度進行。","word":"ethical"}},"evidence":{"createdAt":1781331945968,"q":{"answer":0,"explanation":"evidence 指能夠證明事實或支持主張的具體證據或證詞，通常在法律或調查情境中使用。","options":["proof","opinion","rumor","suspicion"],"sentence":"The detective presented ______ in court to prove the suspect was guilty. The photographs, fingerprints, and witness statements she showed the jury were all crucial to building her case.","translation":"偵探在法庭上出示證據以證明嫌疑人有罪。她向陪審團展示的照片、指紋和證人陳述都對建立她的案件至關重要。","word":"evidence"}},"evil":{"createdAt":1781345564015,"q":{"answer":2,"explanation":"evil 是形容詞，表示道德上邪惡、不道德或傷害他人的，常用來描述令人厭惡的人或行為。","options":["kind","generous","evil","peaceful"],"sentence":"The ______ dictator ruled his country with fear and violence for thirty years. His regime was responsible for torturing and murdering countless innocent citizens.","translation":"這位邪惡的獨裁者用恐懼和暴力統治他的國家三十年。他的政權對無數無辜公民進行了刑求和謀殺。","word":"evil"}},"evolution":{"createdAt":1781311983487,"q":{"answer":2,"explanation":"evolution 指逐漸的發展、進展或演化過程，通常涉及長期的改變。","options":["timer","syndrome","evolution","arena"],"sentence":"The ______ of technology has transformed how people communicate over the past century. From telegrams to smartphones, each innovation built upon the previous generation's achievements.","translation":"在過去的一個世紀裡，科技的發展改變了人們的溝通方式。從電報到智能手機，每項創新都建立在前一代的成就之上。","word":"evolution"}},"excerpt":{"createdAt":1781332009071,"q":{"answer":1,"explanation":"excerpt 指的是從書籍、文章或演講中摘取的一部分內容","options":["preface","excerpt","epilogue","outline"],"sentence":"The teacher showed the class an ______ from the novel to illustrate the author's writing style. The passage was only a few pages long but demonstrated the key themes of the book.","translation":"老師向班級展示了小說中的摘錄以說明作者的寫作風格。這段文章只有幾頁，但展示了該書的關鍵主題。","word":"excerpt"}},"exclusive":{"createdAt":1781362281664,"q":{"answer":1,"explanation":"exclusive表示排外的或獨家的，只限於特定的人或團體。","options":["public","exclusive","open","general"],"sentence":"This ______ club membership is only available to wealthy individuals. Regular people cannot join regardless of their interest in membership.","translation":"這個排外俱樂部會員只對富人開放。無論普通人多麼有興趣，他們都無法加入。","word":"exclusive"}},"exert":{"createdAt":1781323901188,"q":{"answer":1,"explanation":"exert意為「運用」或「施加」，在此指使用權力或影響力來達成目標。","options":["lose","exert","ignore","abandon"],"sentence":"The manager decided to ______ her influence over the board members to approve the new project. Through her persuasion and political connections, she successfully pushed the proposal forward.","translation":"經理決定運用她對董事會成員的影響力來批准新項目。通過她的勸說和政治關係，她成功推動了該提案。","word":"exert"}},"expertise":{"createdAt":1781414438960,"q":{"answer":1,"explanation":"expertise指在特定領域中獲得的深厚知識、技能和專業能力","options":["luck","expertise","interest","theory"],"sentence":"The company hired a consultant with ______ in digital marketing strategy. His twenty years of experience and proven track record made him the perfect choice for leading the campaign.","translation":"公司聘請了一位擁有數位行銷策略專長的顧問。他二十年的經驗和成熟的業績使他成為領導這項活動的完美人選。","word":"expertise"}},"explore":{"createdAt":1781332009069,"q":{"answer":1,"explanation":"explore 意為探測或探險，通常用於對未知地區的調查和研究","options":["avoid","explore","close","ignore"],"sentence":"The research team decided to ______ the newly discovered cave system in the mountains. They spent weeks mapping out all the tunnels and studying the geological formations inside.","translation":"研究小組決定探測山區新發現的洞穴系統。他們花了數周時間繪製所有隧道並研究內部的地質構造。","word":"explore"}},"expressive":{"createdAt":1781311983486,"q":{"answer":2,"explanation":"expressive 表示能夠表達感情或想法的，富有表現力和感染力的。","options":["average","offshore","expressive","evolution"],"sentence":"The dancer's ______ movements captivated the entire audience during the performance. Her body language conveyed deep emotion and artistic intention without speaking a single word.","translation":"舞者在表演中富有表現力的動作迷住了整個觀眾。她的肢體語言在沒有說一句話的情況下傳達了深層的情感和藝術意圖。","word":"expressive"}},"facility":{"createdAt":1781417610422,"q":{"answer":2,"explanation":"facility是指為特定目的而建造的設備、機構或場所，通常配備必要的工具和資源。","options":["library","dormitory","facility","cafeteria"],"sentence":"The university invested millions of dollars in building a state-of-the-art research ______ for its chemistry department. Scientists now had access to the latest equipment and technology needed for advanced experiments.","translation":"大學投入數百萬美元為化學系建造最先進的研究設施。科學家們現在可以使用進行先進實驗所需的最新設備和技術。","word":"facility"}},"fantastic":{"createdAt":1781332009065,"q":{"answer":1,"explanation":"fantastic 意為極好的、非常令人滿意的，通常用來表達對某事物的高度讚美","options":["terrible","fantastic","boring","average"],"sentence":"The movie was absolutely ______ and exceeded all my expectations. Critics praised it as one of the best films of the year.","translation":"那部電影絕對是極好的，超越了我所有的期望。評論家稱讚它是今年最好的電影之一。","word":"fantastic"}},"feast":{"createdAt":1781275226788,"q":{"answer":1,"explanation":"此處feast指「盛宴；筵席」，指隆重而豐盛的聚餐活動","options":["digestion","feast","fume","abroad"],"sentence":"The royal ______ included dozens of dishes, entertainment, and guests from across the kingdom. Everyone celebrated and enjoyed the lavish spread of food and festivities.","translation":"皇家盛宴包括數十道菜餚、娛樂表演和來自整個王國的賓客。每個人都慶祝並享受了這場豐盛的食物和慶典。","word":"feast"}},"flake":{"createdAt":1781268630465,"q":{"answer":1,"explanation":"flake指的是薄片或單個的小片，特別是指雪花或其他細小物質的單個單位。","options":["sheet","flake","layer","blanket"],"sentence":"A ______ of snow fell gently on the windowpane. Each individual crystal was visible before it melted into the glass.","translation":"一片雪花輕輕地落在窗戶玻璃上。每個單獨的冰晶在融化到玻璃中之前都是可見的。","word":"flake"}},"fossil":{"createdAt":1781311922073,"q":{"answer":1,"explanation":"fossil 是指遠古生物的遺骨或遺跡經過地質作用保存在岩石中形成的。","options":["bone","fossil","skeleton","artifact"],"sentence":"The museum displayed a 200-million-year-old ______ of a prehistoric dinosaur in the main exhibition hall. Scientists carefully studied the preserved remains to learn about ancient life on Earth.","translation":"博物館在主展廳展示了一個2億年前的史前恐龍化石。科學家仔細研究了這些保存下來的遺骸，以了解地球上的古代生命。","word":"fossil"}},"fume":{"createdAt":1781275226788,"q":{"answer":2,"explanation":"此處fume作動詞表示「發怒；生悶氣」，通常指內心的不滿","options":["dazzle","include","fume","breast"],"sentence":"She began to ______ when she discovered her coworker had taken credit for her project. Her anger only grew as she realized the unfairness of the situation.","translation":"當她發現同事竊取她的項目成果時，她開始生悶氣。當她意識到這種不公平時，她的憤怒更加增長。","word":"fume"}},"functional":{"createdAt":1781323901183,"q":{"answer":2,"explanation":"functional意為「正常工作的」或「實用的」，在此指電腦的所有功能都能正常運作。","options":["broken","obsolete","functional","decorative"],"sentence":"Although the old computer looks worn, it remains completely ______. Every program runs smoothly and all hardware components respond normally.","translation":"雖然這台舊電腦看起來磨損了，但它仍然完全正常工作。每個程序運行順暢，所有硬件組件都反應正常。","word":"functional"}},"gather":{"createdAt":1781402539338,"q":{"answer":1,"explanation":"gather 作動詞表示收集、聚集或整合來自不同來源的信息或物品。","options":["ignore","gather","create","lose"],"sentence":"The volunteers will ______ information about the problem from community members. They plan to conduct surveys and interviews over the next month.","translation":"志願者將從社區成員那裡收集關於該問題的信息。他們計畫在下個月進行調查和訪談。","word":"gather"}},"giggle":{"createdAt":1781331945988,"q":{"answer":0,"explanation":"giggle 指輕聲或斷斷續續地笑，通常是因為覺得有趣或感到害羞。","options":["giggle","cry","sleep","leave"],"sentence":"The children couldn't help but ______ when the clown made funny faces at them. Their laughter filled the entire room with joy and amusement.","translation":"當小丑對孩子們做鬼臉時，他們忍不住咯咯笑起來。他們的笑聲讓整個房間充滿了歡樂和娛樂。","word":"giggle"}},"glide":{"createdAt":1781417610414,"q":{"answer":2,"explanation":"glide是指光滑、流暢地滑動，通常帶有輕鬆優雅的感覺。","options":["jump","stumble","glide","sprint"],"sentence":"The ice skater began to ______ gracefully across the frozen pond. Her smooth movements required years of practice to master the technique of sliding without friction.","translation":"這位溜冰者開始在結冰的池塘上優雅地滑行。她流暢的動作需要多年的練習才能掌握無摩擦滑行的技巧。","word":"glide"}},"gossip":{"createdAt":1781401591590,"q":{"answer":1,"explanation":"gossip 作為動詞，意思是說別人的閒話或八卦，通常涉及傳播他人的祕密或私人信息。","options":["complain","gossip","whisper","celebrate"],"sentence":"The two friends love to ______ about their coworkers during lunch breaks. They share secrets and personal stories that they've heard from others around the office.","translation":"這兩個朋友喜歡在午餐時間說同事的閒話。他們分享從辦公室裡其他人那裡聽到的祕密和個人故事。","word":"gossip"}},"grant":{"createdAt":1781345237575,"q":{"answer":1,"explanation":"grant作動詞表示「給予」或「授予」，通常用於正式或官方的贈與行為。","options":["deny","grant","refuse","withhold"],"sentence":"The government decided to ______ the organization a substantial amount of funding for their research project. The money was officially awarded in a formal ceremony last month.","translation":"政府決定向該組織授予大筆資金用於他們的研究項目。該筆款項在上個月的正式儀式上正式撥款。","word":"grant"}},"harvest":{"createdAt":1781345746903,"q":{"answer":1,"explanation":"harvest 作名詞，指農作物的收穫或收成，通常是農業活動的成果。","options":["drought","harvest","planting","irrigation"],"sentence":"The farmers celebrated the end of summer with a bountiful ______. The fields yielded more crops than they had expected, ensuring food security for the entire region.","translation":"農民們用豐收來慶祝夏季的結束。田地產出的農作物比預期更多，確保了整個地區的糧食安全。","word":"harvest"}},"haste":{"createdAt":1781332009071,"q":{"answer":1,"explanation":"haste 意為匆忙或急促，通常導致粗心或錯誤","options":["care","haste","precision","planning"],"sentence":"In their ______, the workers made several mistakes on the construction site. If they had taken their time and worked more carefully, the errors could have been avoided.","translation":"在匆忙中，工人在建築工地上犯了幾個錯誤。如果他們花時間並更加小心地工作，這些錯誤是可以避免的。","word":"haste"}},"hijack":{"createdAt":1781402154557,"q":{"answer":1,"explanation":"hijack表示非法奪取和控制交通工具（如飛機、船隻）或貨物，通常涉及暴力或威脅。","options":["compel","hijack","possess","lottery"],"sentence":"Terrorists attempted to ______ the airplane and divert it to an undisclosed location. Fortunately, the pilot managed to alert authorities, and fighter jets intercepted the aircraft before it could change course.","translation":"恐怖分子試圖劫持飛機並將其轉向未公開的地點。幸運的是，飛行員成功警告了當局，戰鬥機在飛機改變路線前攔截了它。","word":"hijack"}},"housing":{"createdAt":1781332009082,"q":{"answer":1,"explanation":"housing 是名詞，指的是住房或住宅，通常用於指人們的居住場所","options":["education","housing","healthcare","transportation"],"sentence":"The government launched a new initiative to improve ______ for low-income families. The program provided subsidies and loans to help people purchase affordable homes.","translation":"政府啟動了一項新倡議來改善低收入家庭的住房。該計畫提供補助和貸款幫助人們購買負擔得起的房屋。","word":"housing"}},"humor":{"createdAt":1781345237583,"q":{"answer":1,"explanation":"humor指使人感到愉快或發笑的幽默感或幽默天賦。","options":["silence","humor","sadness","anger"],"sentence":"His natural ______ made him popular at parties and social gatherings. Everyone appreciated his funny jokes and witty observations about everyday life.","translation":"他天生的幽默感使他在派對和社交聚會上很受歡迎。每個人都欣賞他關於日常生活的有趣笑話和詼諧評論。","word":"humor"}},"impact":{"createdAt":1781345237581,"q":{"answer":1,"explanation":"impact作動詞表示對某事物產生重要的影響或衝擊效果。","options":["ignore","impact","observe","measure"],"sentence":"The new marketing campaign will ______ our sales figures significantly. We expect to see at least a 30% increase in revenue based on preliminary market analysis.","translation":"新的行銷活動將對我們的銷售數字產生重大影響。根據初步市場分析，我們預計收入至少會增加30%。","word":"impact"}},"include":{"createdAt":1781275226790,"q":{"answer":1,"explanation":"此處include作動詞表示「包括；涵蓋」，指某物是整體的一部分","options":["fume","include","dazzle","dump"],"sentence":"The package deal will ______ airfare, hotel accommodations, and all meals. The price quote covers everything you need for your complete vacation.","translation":"這個套餐會包括機票、酒店住宿和所有餐飲。報價涵蓋了你完整假期所需的一切。","word":"include"}},"including":{"createdAt":1781362281657,"q":{"answer":1,"explanation":"including表示包括或包含某些東西作為整體的一部分。","options":["excluding","including","limiting","deducting"],"sentence":"The total cost of the trip is $500, ______ all meals and transportation. Accommodation, activities, and guides are part of this price.","translation":"旅行的總成本是500美元，包括所有的餐飲和交通。住宿、活動和導遊都包含在這個價格中。","word":"including"}},"indicate":{"createdAt":1781257238303,"q":{"answer":1,"explanation":"indicate指顯示、表明或指出某事，常用於從徵兆推斷結論。","options":["prevent","indicate","delay","cancel"],"sentence":"The dark clouds ______ that a storm was coming soon. Within the next two hours, heavy rain and lightning would arrive in the area.","translation":"烏雲表明暴風雨即將來臨。在接下來的兩小時內，該地區將迎來暴雨和閃電。","word":"indicate"}},"infect":{"createdAt":1781363994346,"q":{"answer":2,"explanation":"infect表示病原體或疾病傳播到人體內，造成感染或疾病發生。","options":["heal","protect","contaminate","understand"],"sentence":"The virus can ______ multiple people if they don't practice proper hygiene. Scientists are studying how quickly the disease spreads from person to person.","translation":"如果人們不做好衛生措施，病毒可能會感染多人。科學家正在研究這種疾病在人與人之間傳播的速度。","word":"infect"}},"journey":{"createdAt":1781310338172,"q":{"answer":1,"explanation":"journey 是指一次旅行或旅程，通常涉及較長的距離和時間。","options":["destination","journey","vehicle","schedule"],"sentence":"Their ______ across three continents took nearly six months to complete. They visited dozens of cities and crossed multiple oceans during this extended expedition.","translation":"他們跨越三大洲的旅程耗時近六個月才完成。在這次漫長的遠征中，他們訪問了許多城市並跨越多個海洋。","word":"journey"}},"kidney":{"createdAt":1781362281726,"q":{"answer":1,"explanation":"kidney指的是腎臟，是人體的重要器官，負責過濾廢物和產生尿液。","options":["liver","kidney","heart","lung"],"sentence":"The patient underwent surgery to remove a damaged ______ from his body. The organ had stopped functioning properly due to disease.","translation":"患者進行了手術以移除他體內受損的腎臟。這個器官因疾病而停止了正常功能。","word":"kidney"}},"knock":{"createdAt":1781402539337,"q":{"answer":1,"explanation":"knock 是名詞，指敲打門或物體表面所發出的聲音或動作。","options":["ring","knock","whisper","footstep"],"sentence":"She heard a loud ______ on the door early in the morning. Three rapid raps startled her awake from her sleep.","translation":"她一大早聽到門上發出的大聲敲打聲。三下快速的敲打聲將她從睡眠中驚醒。","word":"knock"}},"knowledge":{"createdAt":1781362281668,"q":{"answer":1,"explanation":"knowledge指的是所掌握的信息、事實或技能，來自學習或經驗。","options":["opinion","knowledge","guess","belief"],"sentence":"Her extensive ______ of history made her an excellent teacher. Students appreciated how deeply she understood historical events and their significance.","translation":"她廣泛的歷史知識使她成為一位優秀的教師。學生欣賞她對歷史事件及其重要性的深刻理解。","word":"knowledge"}},"lack":{"createdAt":1781402154553,"q":{"answer":1,"explanation":"lack表示缺少或不足，在這裡指資金和員工的短缺導致了專案的失敗。","options":["possess","lack","compel","suspect"],"sentence":"The project failed due to a ______ of funding and experienced staff. Without sufficient resources and qualified personnel, the team could not complete the work on schedule.","translation":"這個專案因為缺少資金和有經驗的員工而失敗。沒有足夠的資源和合格的人員，團隊無法按時完成工作。","word":"lack"}},"leadership":{"createdAt":1781256444516,"q":{"answer":1,"explanation":"leadership指領導的能力和品質，包括指揮、指導和激勵他人的能力。","options":["communication","leadership","intelligence","patience"],"sentence":"The new CEO demonstrated exceptional ______ by rallying the demoralized team and implementing a clear vision for recovery. Within six months, employee morale and productivity had significantly improved.","translation":"新執行長通過鼓舞士氣低落的團隊並實施明確的復甦願景，展現出卓越的領導能力。六個月內，員工士氣和生產力都顯著提高。","word":"leadership"}},"legislator":{"createdAt":1781401803897,"q":{"answer":1,"explanation":"legislator是指有權制定或投票通過法律的立法委員或立法者。","options":["lawyer","lawmaker","judge","minister"],"sentence":"The new ______ proposed a bill to increase funding for public education. This elected official will vote on the law next week in parliament.","translation":"那位新的立法者提議了一項增加公共教育經費的法案。這位當選的官員下週將在議會投票表決該法律。","word":"legislator"}},"lottery":{"createdAt":1781402154554,"q":{"answer":2,"explanation":"lottery指一種靠運氣決定贏家的遊戲或抽籤活動，通常涉及購票和獲獎。","options":["hijack","compel","lottery","stance"],"sentence":"She won the ______ and received a prize of one million dollars. After years of buying tickets every week, her luck finally changed when she matched all the winning numbers.","translation":"她贏得了彩票，獲得了一百萬美元的獎金。在多年每週購買彩票後，她終於幸運地配對了所有中獎號碼。","word":"lottery"}},"mainland":{"createdAt":1781362281652,"q":{"answer":1,"explanation":"mainland指的是一個國家或地區的主要陸地部分，不包括島嶼。","options":["coast","mainland","harbor","shore"],"sentence":"Many people from the island traveled to the ______ to find better job opportunities. The larger landmass offered more industries and economic growth than their home island.","translation":"許多來自島嶼的人前往大陸尋找更好的工作機會。這片更大的陸地比他們的島嶼提供了更多的產業和經濟增長。","word":"mainland"}},"marginal":{"createdAt":1781337343698,"q":{"answer":2,"explanation":"marginal意為微小的、少量的或邊緣的，用於形容數量很少或影響不大的情況。","options":["dramatic","excellent","marginal","spectacular"],"sentence":"The student's improvement in mathematics was only ______ despite attending tutoring sessions twice a week. His test scores increased by less than 3%, which was hardly significant.","translation":"儘管學生每週參加兩次補習課程，但他的數學成績提升只是微小的。他的測試成績只提高了不到3%，這幾乎不顯著。","word":"marginal"}},"mature":{"createdAt":1781311983484,"q":{"answer":2,"explanation":"mature 表示成熟的或已經充分發育的狀態，與年輕或未發育相對。","options":["presidential","timer","mature","average"],"sentence":"The ______ trees in the orchard produced more fruit than the younger saplings. These plants had developed strong root systems over several decades of growth.","translation":"果園裡成熟的樹木比年輕的樹苗產出更多水果。這些植物經過數十年的生長已經發展出強大的根系。","word":"mature"}},"membership":{"createdAt":1781311922068,"q":{"answer":2,"explanation":"membership 是指加入某個組織、俱樂部或機構的資格或身份，通常需要支付費用。","options":["ticket","license","membership","permit"],"sentence":"To access the gym facilities, you must purchase a ______ card first. The annual fee includes unlimited access to all equipment and fitness classes.","translation":"要使用健身房設施，你必須先購買會員資格卡。年費包括對所有設備和健身課程的無限制使用。","word":"membership"}},"metal":{"createdAt":1781417610409,"q":{"answer":1,"explanation":"metal是指金屬或合金，在此指用來製造雕像的堅固金屬材料。","options":["plastic","bronze","ceramic","wood"],"sentence":"The statue was cast from a precious ______ that gleamed in the sunlight. The artisan chose this material specifically because of its durability and resistance to corrosion.","translation":"這座雕像是用在陽光下閃閃發光的貴重金屬鑄造的。工匠之所以選擇這種材料，特別是因為它的耐久性和抗腐蝕性。","word":"metal"}},"minor":{"createdAt":1781311685839,"q":{"answer":2,"explanation":"minor作為形容詞表示較小的、次要的、不重要的，與serious或severe相反。","options":["severe","significant","small","dangerous"],"sentence":"Although the car accident seemed ______, it still required a police report to be filed. The damage was limited to a small dent on the bumper.","translation":"雖然這起車禍看起來很輕微，但仍然需要提交警方報告。損傷僅限於保險桿上的一個小凹痕。","word":"minor"}},"mustache":{"createdAt":1781403377828,"q":{"answer":2,"explanation":"mustache 特指長在上嘴唇上方的鬚髮，不包括下巴或兩側的鬍子。","options":["beard","eyebrows","mustache","sideburns"],"sentence":"The old gentleman carefully groomed his ______ every morning before going to work. He took great pride in the distinctive facial hair that grew above his upper lip.","translation":"這位老紳士每天早上上班前都會細心修剪他的八字鬚。他為長在上唇上方的這道獨特鬍子感到驕傲。","word":"mustache"}},"neat":{"createdAt":1781256444518,"q":{"answer":2,"explanation":"neat指整潔、有序的狀態，描述一個人或地方井井有條、乾乾淨淨。","options":["colorful","cozy","neat","spacious"],"sentence":"Sarah's apartment is always ______, with every book organized on shelves and dishes promptly washed. Her friends are impressed by how she maintains such order despite her busy work schedule.","translation":"莎拉的公寓總是整潔有序的，每本書都整齊地放在書架上，盤子也立即洗淨。她的朋友對她在繁忙的工作日程中仍能保持如此秩序感到印象深刻。","word":"neat"}},"nobility":{"createdAt":1781268630489,"q":{"answer":1,"explanation":"nobility指的是高尚或崇高的品質，表示道德上的優越性和尊嚴。","options":["wealth","nobility","strength","intelligence"],"sentence":"The prince was admired for his ______ and generous spirit toward the poor. His kindness and selflessness set him apart from others.","translation":"王子因其對貧困者的高尚和慷慨精神而受到敬佩。他的善良和無私使他與眾不同。","word":"nobility"}},"norm":{"createdAt":1781256444513,"q":{"answer":1,"explanation":"norm指廣泛接受的規範或標準，是社會中普遍遵循的行為準則。","options":["greeting","norm","habit","tradition"],"sentence":"In many Western countries, shaking hands is considered a social ______ when meeting someone. However, in some Asian cultures, bowing or nodding is the expected standard instead.","translation":"在許多西方國家，握手被認為是見面時的社交規範。然而，在一些亞洲文化中，鞠躬或點頭是預期的標準。","word":"norm"}},"observe":{"createdAt":1781364476362,"q":{"answer":2,"explanation":"Observe意指仔細地注視或研究某事物，通常是為了收集信息或進行科學研究。","options":["ignore","celebrate","observe","criticize"],"sentence":"The scientist decided to ______ the behavior of the penguins in their natural habitat for several weeks. She took detailed notes on how they hunted, played, and interacted with each other throughout each day.","translation":"科學家決定在企鵝的自然棲息地觀察牠們的行為，為期數週。她詳細記錄了牠們如何捕獵、嬉戲以及每天彼此互動的方式。","word":"observe"}},"obvious":{"createdAt":1781345746904,"q":{"answer":1,"explanation":"obvious 作形容詞，表示明顯的、顯而易見的，無需解釋或證明。","options":["hidden","obvious","uncertain","debatable"],"sentence":"It was ______ to everyone that the experiment had failed from the start. The data clearly showed that none of the results matched the predicted outcomes.","translation":"每個人都很明顯地看出實驗從一開始就失敗了。數據清楚地表明，沒有任何結果與預測的結果相符。","word":"obvious"}},"occasionally":{"createdAt":1781402539334,"q":{"answer":1,"explanation":"occasionally 表示不經常發生，只是在某些特殊或不規則的時間發生某事。","options":["always","occasionally","never","frequently"],"sentence":"She ______ visits her grandmother on weekends. Most weeks she stays home, but perhaps once a month she makes the trip.","translation":"她偶爾在週末拜訪她的祖母。大多數週她待在家裡，但也許一個月一次她會進行這次旅行。","word":"occasionally"}},"occurrence":{"createdAt":1781359980245,"q":{"answer":2,"explanation":"occurrence指某事發生、出現或遭遇的現象；強調事件或事物發生的頻率或次數。","options":["prediction","prevention","occurrence","documentation"],"sentence":"The ______ of earthquakes in this region has increased significantly over the past decade. Local authorities recorded more than twenty tremors last year alone.","translation":"這個地區地震的發生頻率在過去十年大幅增加。當地當局去年單獨記錄了二十多次震動。","word":"occurrence"}},"offshore":{"createdAt":1781311983483,"q":{"answer":0,"explanation":"offshore 指在海上或離岸的，通常用於描述水域中的設施或項目。","options":["offshore","mature","expressive","presidential"],"sentence":"The company decided to build its ______ wind farms to harness renewable energy. These installations are located several miles away from the coast in the ocean.","translation":"該公司決定建造離岸風電場以利用可再生能源。這些設施位於海岸線外數英里的大洋中。","word":"offshore"}},"organized":{"createdAt":1781402539333,"q":{"answer":1,"explanation":"organized 表示有系統地安排或整理，使事物井然有序、便於使用或理解。","options":["chaotic","organized","temporary","empty"],"sentence":"The ______ office has a clear filing system and labeled drawers. Everything is easy to find because the manager spent weeks creating an efficient structure.","translation":"這個井井有條的辦公室有清晰的檔案系統和標有標籤的抽屜。一切都很容易找到，因為經理花了幾週時間創建一個高效的結構。","word":"organized"}},"outwards":{"createdAt":1781268630474,"q":{"answer":2,"explanation":"outwards表示向外或朝外的方向，與inwards（向內）相反。","options":["inwards","upwards","outwards","downwards"],"sentence":"The explosion sent debris ______ in all directions. The force pushed everything away from the center point.","translation":"爆炸將碎片向外發送到四面八方。這股力量將所有東西從中心點推開。","word":"outwards"}},"participation":{"createdAt":1781345746906,"q":{"answer":1,"explanation":"participation 作名詞，指參與或加入某項活動，強調主動的投入。","options":["absence","participation","observation","distraction"],"sentence":"Active ______ in classroom discussions has significantly improved students' academic performance. Teachers noticed that engaged students who regularly contributed their ideas achieved higher grades.","translation":"在課堂討論中的積極參與大大提高了學生的學習成績。教師們注意到積極參與並經常貢獻想法的學生成績更高。","word":"participation"}},"pastime":{"createdAt":1781311922067,"q":{"answer":1,"explanation":"pastime 是指用來打發時間或消遣的活動，通常是為了娛樂和享受。","options":["job","pastime","habit","chore"],"sentence":"Reading novels is my favorite ______ during long train journeys. I find that spending time with a good book helps the hours pass quickly and keeps me entertained.","translation":"在長途火車旅行中，閱讀小說是我最喜愛的消遣。我發現花時間讀一本好書能幫助時間快速流逝並保持我的娛樂。","word":"pastime"}},"path":{"createdAt":1781268630480,"q":{"answer":1,"explanation":"path指的是小徑或小路，通常是行人或動物行走的較窄的通道。","options":["road","path","highway","bridge"],"sentence":"The hikers followed a narrow ______ through the dense forest. The trail was clearly marked with white blazes on the trees.","translation":"登山者沿著一條狹窄的小徑穿過密林。這條小路在樹上用白色標記清晰地標記。","word":"path"}},"patrol":{"createdAt":1781257238304,"q":{"answer":1,"explanation":"patrol指定期往返巡視某個區域，通常是為了維持秩序和安全。","options":["construct","patrol","decorate","abandon"],"sentence":"Police officers ______ the streets every night to maintain safety. The officers walked up and down each block checking for any signs of trouble or suspicious activity.","translation":"警察每晚巡邏街道以維護安全。警察沿著每個街區走上走下，檢查任何麻煩跡象或可疑活動。","word":"patrol"}},"pelt":{"createdAt":1781363994340,"q":{"answer":0,"explanation":"pelt作為名詞表示動物的皮毛，通常指去毛的獸皮，可用於製作衣物或毛皮製品。","options":["skin","arrow","voice","stone"],"sentence":"The hunter carefully removed the ______ from the animal to use as clothing. He stretched and dried the soft fur before trading it at the market.","translation":"獵人小心地從動物身上剝下獸皮來作為衣服。他在拿到市場交易之前先將柔軟的毛皮拉伸並晾乾。","word":"pelt"}},"penalty":{"createdAt":1781268630486,"q":{"answer":2,"explanation":"penalty指的是處罰或懲罰，特別是針對違規或犯罪行為的懲罰。","options":["reward","bonus","penalty","award"],"sentence":"The player received a ______ for fouling his opponent during the game. He was benched for the next five minutes as punishment.","translation":"球員因在比賽中犯規對手而受到處罰。作為懲罰，他被替換下場五分鐘。","word":"penalty"}},"per":{"createdAt":1781414884520,"q":{"answer":0,"explanation":"per是介詞，表示「每」或「每一」，常用於計算單位價格或比率。","options":["per","after","during","beyond"],"sentence":"The car rental company charges thirty dollars ______ day for this luxury vehicle. If you rent it for a week, the total cost would be two hundred and ten dollars.","translation":"租車公司對這輛豪華車每天收費三十美元。如果你租一週，總成本將是二百一十美元。","word":"per"}},"perception":{"createdAt":1781268630485,"q":{"answer":1,"explanation":"perception指的是感知或認知，是指人對事物的理解和看法，可能與事實不符。","options":["action","perception","reaction","decision"],"sentence":"His ______ of the situation was completely different from reality. He believed the meeting was a disaster when it actually went very well.","translation":"他對局勢的感知與現實完全不同。他認為會議是一場災難，而實際上進行得非常順利。","word":"perception"}},"perseverance":{"createdAt":1781362281661,"q":{"answer":1,"explanation":"perseverance表示毅力和不屈不撓的精神，即堅持不懈的決心。","options":["laziness","perseverance","arrogance","confusion"],"sentence":"Her ______ through years of training eventually led to Olympic gold. She never gave up despite countless setbacks and failures.","translation":"她多年訓練中的毅力最終導致了奧運金牌。儘管遭遇無數挫折和失敗，她從未放棄。","word":"perseverance"}},"photography":{"createdAt":1781310338175,"q":{"answer":2,"explanation":"photography 是指用相機捕捉和創作影像的藝術和技術。","options":["painting","poetry","photography","sculpture"],"sentence":"She decided to pursue a career in ______ after winning several awards for her landscape images. Her portfolio of stunning nature photographs has been featured in multiple international exhibitions.","translation":"在因風景照片獲得多個獎項後，她決定從事攝影事業。她令人驚嘆的自然照片作品集已在多個國際展覽中展出。","word":"photography"}},"plea":{"createdAt":1781359980244,"q":{"answer":2,"explanation":"plea是指向權威人士提出的懇求或請求；在法律語境中指被告就罪名所作的供述或認罪。","options":["objection","declaration","plea","verdict"],"sentence":"The defendant made a desperate ______ for mercy before the judge announced the sentence. His lawyer begged the court to consider his difficult family situation.","translation":"被告在法官宣佈判決前對法官提出了絕望的懇求。他的律師懇求法庭考慮他困難的家庭狀況。","word":"plea"}},"poisonous":{"createdAt":1781336858138,"q":{"answer":1,"explanation":"poisonous 用來形容某物含有毒素，會對生命造成威脅或傷害。","options":["beautiful","poisonous","harmless","colorful"],"sentence":"The snake's venom is ______, so hikers must avoid contact with it. Even a small bite from this creature can cause death within hours.","translation":"這條蛇的毒液是有毒的，所以登山者必須避免與它接觸。即使被這種生物輕輕咬一口，也可能在幾小時內導致死亡。","word":"poisonous"}},"position":{"createdAt":1781345746903,"q":{"answer":1,"explanation":"position 作名詞，在此指職務或職位，表示在機構中的工作角色。","options":["location","position","movement","direction"],"sentence":"She was offered a senior management ______ at the international corporation. She accepted the job offer and will start work next month as the new director.","translation":"她獲得了國際公司高級管理職位的聘請。她接受了工作邀請，將於下個月作為新任總監開始工作。","word":"position"}},"possess":{"createdAt":1781402154558,"q":{"answer":0,"explanation":"possess表示擁有或持有某物，在這裡指律師必須持有法律執業執照。","options":["possess","lack","compel","hijack"],"sentence":"To practice law in this country, a lawyer must ______ a valid license issued by the bar association. Without this credential, it is illegal to provide legal services to clients.","translation":"在這個國家執業律師必須擁有律師協會頒發的有效執照。沒有這個證書，向客戶提供法律服務是違法的。","word":"possess"}},"prediction":{"createdAt":1781401591593,"q":{"answer":2,"explanation":"prediction 是指基於現有信息對未來事件的預測或預言。","options":["observation","memory","prediction","description"],"sentence":"The weather forecaster made a ______ that it would rain heavily next Tuesday. Meteorologists use computer models and historical data to make such forecasts.","translation":"氣象預報員預測下週二會下大雨。氣象學家使用電腦模型和歷史數據來進行這樣的預測。","word":"prediction"}},"premature":{"createdAt":1781256444515,"q":{"answer":1,"explanation":"premature指過早或倉促的，暗示應該等待更多資訊才下決定。","options":["careful","premature","detailed","thorough"],"sentence":"The doctor advised against ______ conclusions about the patient's condition based on initial symptoms. More comprehensive tests would be needed before making any definitive diagnosis.","translation":"醫生建議不要根據初期症狀對患者的病情做出倉促的結論。需要進行更全面的測試才能做出明確診斷。","word":"premature"}},"premiere":{"createdAt":1781401361936,"q":{"answer":1,"explanation":"premiere指電影、戲劇等作品的首次公開展演或首映式，通常是一個重大的文化事件。","options":["sequel","premiere","release","screening"],"sentence":"The new Marvel movie had its ______ at the Cannes Film Festival last night. Thousands of fans gathered outside the theatre to see the actors walk the red carpet for the first public showing.","translation":"新的漫威電影昨晚在坎城影展舉行了首映。數千名粉絲聚集在劇院外，為第一場公開放映時看到演員走紅毯。","word":"premiere"}},"prescription":{"createdAt":1781401591591,"q":{"answer":1,"explanation":"prescription 是指醫生開給患者的藥方或處方籤，用於在藥局購買特定藥物。","options":["diagnosis","prescription","symptom","treatment"],"sentence":"The doctor wrote a ______ for antibiotics after examining my throat infection. I took this document to the pharmacy to obtain my medication.","translation":"醫生檢查完我的喉嚨感染後，開了一張抗生素的處方籤。我拿著這份文件到藥局去拿藥。","word":"prescription"}},"presidential":{"createdAt":1781311983485,"q":{"answer":1,"explanation":"presidential 指與總統或總統職位相關的，通常用來描述選舉或權力。","options":["expressive","presidential","offshore","syndrome"],"sentence":"The ______ election drew record numbers of voters to the polls across the nation. Citizens were eager to choose the next head of state and determine the direction of the country.","translation":"總統選舉在全國各地吸引了創紀錄人數的選民投票。公民渴望選擇下一任國家首腦並決定國家的方向。","word":"presidential"}},"promising":{"createdAt":1781362281662,"q":{"answer":1,"explanation":"promising表示有前途的或大有可為的，預示著未來的成功。","options":["poor","promising","average","disappointing"],"sentence":"The young athlete showed ______ skills during the tournament. Coaches believe she has great potential to become a champion.","translation":"這位年輕運動員在比賽中表現出有前途的技能。教練認為她有成為冠軍的巨大潛力。","word":"promising"}},"proper":{"createdAt":1781359980249,"q":{"answer":2,"explanation":"proper指適合、適當或恰當的；強調符合特定情境或標準的要求。","options":["casual","improper","proper","creative"],"sentence":"Using ______ grammar and correct spelling is essential when writing formal business letters. Your employer expects professional communication in all official correspondence.","translation":"寫正式商業信函時，使用適當的語法和正確的拼寫至關重要。你的雇主期望所有官方函件中的溝通都是專業的。","word":"proper"}},"properly":{"createdAt":1781414884517,"q":{"answer":1,"explanation":"properly表示適當地、恰當地、按照正確方式進行，強調符合要求和規範。","options":["quickly","properly","eagerly","loudly"],"sentence":"The student did not follow the instructions ______, so her essay format was completely incorrect. The teacher had to ask her to rewrite it according to the exact guidelines provided.","translation":"學生沒有適當地遵循說明，所以她的論文格式完全不正確。老師不得不要求她按照提供的確切指南重新撰寫。","word":"properly"}},"protein":{"createdAt":1781332009083,"q":{"answer":1,"explanation":"protein 是名詞，指的是蛋白質，一種重要的營養物質，對肌肉和組織的構成至關重要","options":["carbohydrate","protein","fat","vitamin"],"sentence":"Athletes need to consume adequate ______ to support muscle growth and recovery. Foods like chicken, fish, and eggs are excellent sources of this essential nutrient.","translation":"運動員需要消耗足夠的蛋白質來支持肌肉生長和恢復。雞肉、魚和雞蛋等食物是這種必要營養素的極好來源。","word":"protein"}},"psychic":{"createdAt":1781362281725,"q":{"answer":1,"explanation":"psychic表示通靈的、有特異功能的，指超自然或心靈上的能力。","options":["mathematical","psychic","musical","athletic"],"sentence":"She claimed to have ______ abilities that allowed her to read minds. She said she could communicate with spirits and see the future.","translation":"她聲稱擁有通靈能力，可以讀取他人的想法。她說她可以與靈魂溝通並看到未來。","word":"psychic"}},"publication":{"createdAt":1781345237584,"q":{"answer":1,"explanation":"publication指書籍、文章或其他作品的出版或發行行為及其所發行的物品。","options":["reception","publication","rejection","discussion"],"sentence":"The ______ of the research paper was delayed due to peer review corrections. The journal finally released the study online and in print this morning.","translation":"由於同行評審修正，研究論文的出版被延遲了。期刊今早終於在線和印刷版上發布了這項研究。","word":"publication"}},"pump":{"createdAt":1781359980247,"q":{"answer":1,"explanation":"pump作為動詞有套問的意思；指通過反覆或持續的提問來從某人那裡獲取信息。","options":["extract","pump","document","broadcast"],"sentence":"The reporter tried to ______ information from the witness about what he had seen that night. Despite persistent questioning, the witness refused to reveal any details.","translation":"記者試圖從證人那裡套問他那晚看到的信息。儘管提出了持續的質詢，證人拒絕透露任何細節。","word":"pump"}},"pumps":{"createdAt":1781332009077,"q":{"answer":1,"explanation":"pumps 是名詞，指的是無帶的高跟女鞋，通常用於正式場合","options":["boots","pumps","sandals","sneakers"],"sentence":"She wore elegant red ______ to the formal evening gala. The high-heeled shoes matched her dress perfectly and made her feel confident and stylish.","translation":"她穿著優雅的紅色高跟鞋參加了正式的晚宴。這雙高跟鞋與她的禮服完美搭配，讓她感到自信和時尚。","word":"pumps"}},"qualified":{"createdAt":1781332009068,"q":{"answer":1,"explanation":"qualified 意為有資格的、勝任的，表示具備必要的技能或資格","options":["inexperienced","qualified","young","willing"],"sentence":"Only ______ professionals with years of training should perform this dangerous surgery. The hospital requires all surgeons to have medical degrees and board certification.","translation":"只有有資格的專業人士經過多年培訓才應執行這項危險的手術。該醫院要求所有外科醫生都要有醫學學位和委員會認證。","word":"qualified"}},"rally":{"createdAt":1781362281649,"q":{"answer":1,"explanation":"rally是指集會或群眾大會，人們聚集在一起表達共同的立場或支持。","options":["debate","rally","interview","broadcast"],"sentence":"The political ______ attracted thousands of supporters from across the country. Citizens gathered in the square to show their support for the candidate.","translation":"這場政治集會吸引了來自全國各地的數千名支持者。市民聚集在廣場上表示對候選人的支持。","word":"rally"}},"rapid":{"createdAt":1781332009075,"q":{"answer":1,"explanation":"rapid 是形容詞，表示速度快的、迅速的","options":["slow","rapid","steady","stable"],"sentence":"The ______ growth of the company allowed it to expand into three new markets within a year. Investors were impressed by how quickly the business was developing.","translation":"公司的迅速增長使其在一年內擴展到三個新市場。投資者對業務發展的速度印象深刻。","word":"rapid"}},"rapidly":{"createdAt":1781332009075,"q":{"answer":1,"explanation":"rapidly 是副詞，表示非常快速地或迅速地發生","options":["slowly","rapidly","steadily","gradually"],"sentence":"The technology company's stock price increased ______ after announcing their new product. Within a month, the value had nearly doubled due to strong investor interest.","translation":"這家科技公司在宣佈新產品後股價迅速上升。在一個月內，由於投資者的強烈興趣，股票價值幾乎翻倍。","word":"rapidly"}},"ratify":{"createdAt":1781332009069,"q":{"answer":1,"explanation":"ratify 意為正式批准或簽署，使條約或協議具有法律效力","options":["reject","ratify","ignore","debate"],"sentence":"The government must ______ the international treaty before it becomes legally binding. Parliament voted to officially approve the agreement with a strong majority.","translation":"政府必須正式批准這項國際條約，使其具有法律約束力。議會以絕對多數投票正式批准了該協議。","word":"ratify"}},"ratio":{"createdAt":1781414438947,"q":{"answer":1,"explanation":"ratio用來表示兩個量之間的相對關係或比較，通常用分數或冒號表示","options":["percentage","ratio","average","quantity"],"sentence":"The ______ of boys to girls in the class is 3:2. This mathematical proportion helps us understand the distribution of students by gender.","translation":"班級中男生與女生的比例是3:2。這個數學比例幫助我們了解學生按性別的分布。","word":"ratio"}},"realistic":{"createdAt":1781362281724,"q":{"answer":1,"explanation":"realistic表示符合實際的、實際上可能的，指根據現實情況制定的計畫或目標。","options":["impossible","realistic","extreme","vague"],"sentence":"He set ______ goals for his fitness journey instead of expecting immediate results. He understood that progress would take time and consistent effort.","translation":"他為自己的健身之旅設定了現實的目標，而不是期望立竿見影的結果。他明白進步需要時間和持續的努力。","word":"realistic"}},"realize":{"createdAt":1781332009078,"q":{"answer":1,"explanation":"realize 意為實現或達成，表示將想法或計畫變成現實","options":["abandon","realize","forget","ignore"],"sentence":"The entrepreneur didn't ______ his business dream until years of hard work and persistence. He eventually built a successful company that generated millions in revenue.","translation":"企業家在多年的辛勤工作和堅持後才實現了他的商業夢想。他最終建立了一家成功的公司，產生了數百萬的收入。","word":"realize"}},"realm":{"createdAt":1781362281658,"q":{"answer":1,"explanation":"realm指的是特定領域或範圍，如藝術、科學或政治等。","options":["country","realm","location","region"],"sentence":"In the ______ of sports, Michael Jordan is considered the greatest basketball player. His achievements set records that remain unmatched in his field.","translation":"在體育領域，邁克爾·喬丹被認為是最偉大的籃球運動員。他的成就創造了在他的領域中仍然無與倫比的紀錄。","word":"realm"}},"recession":{"createdAt":1781311922068,"q":{"answer":0,"explanation":"recession 是指經濟的衰退期，特徵是商業活動減少、失業增加和收入下降。","options":["recession","growth","boom","expansion"],"sentence":"During the ______, many businesses closed and unemployment rates increased dramatically. The economic downturn lasted for two years before the country began to recover.","translation":"在經濟衰退期間，許多企業關閉，失業率大幅上升。這次經濟衰退持續了兩年才開始恢復。","word":"recession"}},"recommend":{"createdAt":1781332009082,"q":{"answer":1,"explanation":"recommend 意為推薦或建議，表示認為某事物很好而建議他人使用或欣賞","options":["criticize","recommend","discourage","warn"],"sentence":"The film critic highly ______ the new movie to all audiences who enjoy dramatic storytelling. She gave it five stars and called it a must-see film.","translation":"電影評論家高度推薦這部新電影給所有喜歡戲劇性故事講述的觀眾。她給了它五顆星，並稱其為必看電影。","word":"recommend"}},"refusal":{"createdAt":1781332009076,"q":{"answer":1,"explanation":"refusal 是名詞，表示對要求或提議的拒絕或回絕","options":["agreement","refusal","acceptance","willingness"],"sentence":"The athlete's ______ to use performance-enhancing drugs earned him great respect from the sporting community. He consistently declined offers to cheat despite pressure from competitors.","translation":"運動員拒絕使用性能增強藥物的行為贏得了體育界的高度尊重。儘管競爭對手的施壓，他一直拒絕作弊的提議。","word":"refusal"}},"refute":{"createdAt":1781332009066,"q":{"answer":1,"explanation":"refute 意為駁斥或反駁某人的說法，通常帶有提供相反證據的含義","options":["support","refute","ignore","accept"],"sentence":"The scientist was able to ______ the false claims with solid evidence. The data clearly demonstrated that the original hypothesis was incorrect.","translation":"科學家能夠用確鑿的證據駁斥那些虛假的主張。數據清楚地表明原來的假設是錯誤的。","word":"refute"}},"represent":{"createdAt":1781256547736,"q":{"answer":1,"explanation":"Represent在此表示描寫或描繪，指藝術作品表現或呈現出某個場景或概念。","options":["ignore","represent","conceal","destroy"],"sentence":"The painting ______ a peaceful village at sunset with golden light spreading across the sky. Every detail in the artwork captures the artist's vision of rural tranquility.","translation":"這幅畫描寫了一個日落時刻的寧靜村莊，金色的光線灑滿天空。藝術品中的每一個細節都捕捉了藝術家對鄉村寧靜的想像。","word":"represent"}},"resemble":{"createdAt":1781310338173,"q":{"answer":1,"explanation":"resemble 表示看起來相像或具有相似的特徵。","options":["ignore","resemble","criticize","change"],"sentence":"The teenage boy's facial features ______ those of his father quite remarkably. People often comment that they look like they could be twins despite their age difference.","translation":"這個青少年男孩的面部特徵與他父親的特徵非常相似。儘管年齡相差很大，人們經常評論他們看起來就像可能是雙胞胎。","word":"resemble"}},"restricted":{"createdAt":1781310338165,"q":{"answer":1,"explanation":"restricted 表示受到限制或約束，只有符合條件的人才能進入或使用。","options":["welcomed","restricted","encouraged","advertised"],"sentence":"Access to the top floor of the building is ______ to authorized personnel only. Visitors without proper identification cannot enter that area under any circumstances.","translation":"建築物頂層的通道僅限授權人員進入。沒有適當身份證明的訪客在任何情況下都無法進入該區域。","word":"restricted"}},"reversed":{"createdAt":1781362281725,"q":{"answer":1,"explanation":"reversed表示相反的、反轉的，指改變方向或返回先前的狀態。","options":["confirmed","reversed","approved","maintained"],"sentence":"The ______ decision meant they had to go back to their original plan. The previous ruling was overturned and everything returned to how it was before.","translation":"相反的決定意味著他們必須回到最初的計畫。之前的裁決被推翻，一切都回到了之前的樣子。","word":"reversed"}},"ripe":{"createdAt":1781362281663,"q":{"answer":1,"explanation":"ripe表示水果已經成熟，可以食用或採摘。","options":["green","ripe","frozen","sour"],"sentence":"The ______ fruit fell from the tree and was ready to eat. It had developed a sweet aroma and deep yellow color.","translation":"成熟的水果從樹上掉下來，已經可以吃了。它已經散發出甜蜜的香氣並呈現深黃色。","word":"ripe"}},"sacrifice":{"createdAt":1781360333384,"q":{"answer":2,"explanation":"sacrifice 表示放棄或獻出某物以換取更重要的東西，常用於做出重大的犧牲。","options":["gain","preserve","sacrifice","enjoy"],"sentence":"The soldier was willing to ______ his life for his country. He knew that dying in battle was the ultimate price he might have to pay.","translation":"那位士兵願意為國家犧牲自己的生命。他知道在戰鬥中喪生是他可能要付出的最高代價。","word":"sacrifice"}},"sake":{"createdAt":1781360333390,"q":{"answer":1,"explanation":"sake 表示目的、緣故或理由，常用於短語「for the sake of」表示為了某人或某事的利益。","options":["criticism","sake","amusement","debate"],"sentence":"For the ______ of his family's happiness, Mr. Chen decided to relocate to a safer neighborhood. He believed that protecting his loved ones was worth any personal inconvenience.","translation":"為了家人的幸福，陳先生決定搬到一個更安全的社區。他相信保護親人值得任何個人的不便。","word":"sake"}},"salary":{"createdAt":1781360333388,"q":{"answer":2,"explanation":"salary 是指員工由僱主按期支付的固定報酬，通常是按月或按年計算。","options":["gift","loan","salary","bonus"],"sentence":"The company offered John a monthly ______ of $3,500 for his new position. He was satisfied with the financial package they provided.","translation":"公司為約翰的新職位提供了每月3,500美元的薪水。他對他們提供的財務待遇感到滿意。","word":"salary"}},"salvage":{"createdAt":1781362281657,"q":{"answer":1,"explanation":"salvage表示搶救或搶救可用的東西，特別是從損壞或危險的情況中。","options":["damage","salvage","abandon","destroy"],"sentence":"The divers worked to ______ valuable items from the sunken ship. They managed to recover precious artifacts and cargo from the ocean floor.","translation":"潛水員努力從沉沒的船隻中搶救貴重物品。他們成功地從海底恢復了珍貴的文物和貨物。","word":"salvage"}},"sandal":{"createdAt":1781360333386,"q":{"answer":2,"explanation":"sandal 是一種開放式的鞋類，通常在溫暖的季節穿著，讓腳部能夠透氣。","options":["boot","sneaker","sandal","loafer"],"sentence":"On hot summer days, Tom prefers to wear a comfortable ______ instead of closed shoes. The open design allows his feet to breathe in the humid weather.","translation":"在炎熱的夏天，湯姆喜歡穿著舒適的涼鞋而不是封閉的鞋子。開放的設計使他的腳在潮濕的天氣中透氣。","word":"sandal"}},"satisfaction":{"createdAt":1781360333385,"q":{"answer":2,"explanation":"satisfaction 是指對某事物感到滿足和高興的感受，通常來自達成目標或期望被滿足。","options":["confusion","frustration","satisfaction","exhaustion"],"sentence":"After completing her master's degree, Maria felt a sense of ______ with her academic achievements. She smiled knowing that all her hard work had finally paid off.","translation":"完成碩士學位後，瑪麗亞對自己的學術成就感到滿意。她微笑著，知道自己所有的辛苦最終得到了回報。","word":"satisfaction"}},"satisfy":{"createdAt":1781360333391,"q":{"answer":2,"explanation":"satisfy 表示使人感到滿足和滿意，通常指滿足期望或需求。","options":["disappoint","annoy","satisfy","frustrate"],"sentence":"The restaurant's excellent service and delicious food helped ______ every customer who visited that evening. Many guests left positive reviews praising their overall experience.","translation":"餐廳的優質服務和美味食物使那天晚上光臨的每位顧客都感到滿足。許多客人留下了肯定的評價，讚揚他們的整體體驗。","word":"satisfy"}},"sauce":{"createdAt":1781311685840,"q":{"answer":3,"explanation":"sauce是一種調味液體或醬料，用來搭配食物以增加風味，不同於單純的香料或油。","options":["spice","oil","coating","seasoning"],"sentence":"She poured a delicious tomato ______ over the pasta to enhance its flavor. The condiment added a tangy and aromatic taste to the dish.","translation":"她將美味的番茄醬澆在意大利麵上以增強其風味。這種調料為這道菜增添了酸爽芳香的味道。","word":"sauce"}},"scoop":{"createdAt":1781360333389,"q":{"answer":2,"explanation":"scoop 表示用勺子或類似工具舀取或挖取物品的動作。","options":["pour","mix","scoop","spread"],"sentence":"Using a large wooden spoon, the chef began to ______ ice cream into bowls for the dessert course. The creamy vanilla melted slightly as it fell into each dish.","translation":"主廚用一把大木勺開始用舀的方式將冰淇淋放入碗中作為甜點。奶油狀的香草冰淇淋在掉入每個碗時略微融化。","word":"scoop"}},"score":{"createdAt":1781360333392,"q":{"answer":1,"explanation":"score 作為動詞表示在比賽中得分或獲得分數，是體育競技中的常用詞彙。","options":["lose","score","defend","catch"],"sentence":"The basketball player was thrilled to ______ thirty points in the championship game, leading his team to victory. The crowd cheered wildly as the final buzzer sounded.","translation":"籃球運動員在錦標賽比賽中得到三十分而感到高興，帶領他的隊伍贏得勝利。當最後的蜂鳴聲響起時，觀眾歡聲雷動。","word":"score"}},"scroll":{"createdAt":1781360333391,"q":{"answer":1,"explanation":"scroll 表示向上或向下移動來查看電子屏幕上的更多內容，或展開捲軸查看內容。","options":["jump","scroll","flip","skip"],"sentence":"As Sarah continued to ______ down her social media feed, she discovered an interesting article about ancient history. Hours passed as she kept moving through endless posts.","translation":"當莎拉繼續滾動瀏覽她的社交媒體動態時，她發現了一篇有趣的古代歷史文章。當她不斷翻閱無數的帖子時，幾個小時過去了。","word":"scroll"}},"sculptor":{"createdAt":1781360333386,"q":{"answer":2,"explanation":"sculptor 是指專門從事雕刻或塑造作品的藝術家，通常用石頭或其他材料創作。","options":["painter","musician","sculptor","architect"],"sentence":"The famous ______ spent decades carving marble and bronze into beautiful works of art. His studio was filled with chisels, hammers, and partially completed statues.","translation":"那位著名的雕塑家花費數十年將大理石和青銅雕刻成美麗的藝術作品。他的工作室裡擺滿了鑿子、錘子和未完成的雕像。","word":"sculptor"}},"senior":{"createdAt":1781345746901,"q":{"answer":1,"explanation":"senior 用作形容詞，表示年資較久、地位較高的人，與 junior（資淺的）相對。","options":["junior","senior","lateral","external"],"sentence":"My ______ colleague has been working at the company for over twenty years. He mentors the newer employees and holds significant authority in our department.","translation":"我的前輩同事在公司工作已經超過二十年了。他指導新員工，在我們部門中擁有重要的權力。","word":"senior"}},"shelf":{"createdAt":1781311922069,"q":{"answer":1,"explanation":"shelf 是指附著在牆上或家具上的水平面，用來放置物品。","options":["counter","shelf","desk","cabinet"],"sentence":"The library organized all the books on a tall wooden ______ near the entrance. Visitors could easily see the new arrivals displayed on the second level of the structure.","translation":"圖書館在入口附近的高木製架子上組織所有書籍。訪客可以輕易看到在這個結構的第二層展示的新書。","word":"shelf"}},"shrink":{"createdAt":1781257238302,"q":{"answer":1,"explanation":"shrink指物體體積或尺寸變小，常用於描述織物經過洗滌或乾燥後的變化。","options":["expand","shrink","fade","stretch"],"sentence":"The wool sweater will ______ if you wash it in hot water. After one cycle in the dryer, it became two sizes smaller and no longer fit.","translation":"如果你用熱水洗羊毛毛衣，它會縮小。在烘乾機中轉一圈後，它縮小了兩個尺碼，不再合身。","word":"shrink"}},"signal":{"createdAt":1781362281666,"q":{"answer":1,"explanation":"signal表示發出信號或信號本身，用於傳達信息或指示。","options":["ignore","signal","watch","follow"],"sentence":"The coach ______ to the player to make a substitution. The specific hand gesture communicated the desired action from the sideline.","translation":"教練向球員發出信號進行替換。這個特定的手勢從場邊傳達了所需的行動。","word":"signal"}},"similarity":{"createdAt":1781401591593,"q":{"answer":1,"explanation":"similarity 是指兩個或多個事物之間的相同或相似的特徵。","options":["difference","similarity","contrast","distance"],"sentence":"There is a striking ______ between the two paintings, even though they were created by different artists. Both artworks feature the same color palette and landscape composition.","translation":"這兩幅畫之間有著令人驚訝的相似之處，儘管它們是由不同的藝術家創作的。兩件藝術作品都採用相同的調色板和風景構圖。","word":"similarity"}},"skull":{"createdAt":1781414884516,"q":{"answer":0,"explanation":"skull指頭蓋骨或顱骨，是頭部骨骼結構的總稱，常在考古挖掘中被發現。","options":["skull","pottery","artifact","fossil"],"sentence":"The archaeologist carefully excavated the ancient ______ from the burial site. The bone structure revealed important information about the person who had lived thousands of years ago.","translation":"考古學家小心翼翼地從埋藏地點挖掘出古代頭蓋骨。骨骼結構揭示了數千年前生活的人的重要信息。","word":"skull"}},"solitary":{"createdAt":1781402539335,"q":{"answer":1,"explanation":"solitary 表示獨自一人的、孤獨的或喜歡獨居的狀態，通常指不與他人互動。","options":["social","solitary","friendly","crowded"],"sentence":"The ______ hiker preferred to walk through the mountains alone. He avoided group tours and deliberately chose trails where he would not encounter other people.","translation":"這個孤獨的登山者喜歡獨自走過山脈。他避免參加團體遊覽，刻意選擇不會遇到其他人的登山道。","word":"solitary"}},"somehow":{"createdAt":1781337343697,"q":{"answer":1,"explanation":"somehow用於表達對某事發生方式的不確定或驚訝，意為不知怎麼的。","options":["obviously","somehow","certainly","slowly"],"sentence":"She ______ managed to finish the entire project before the deadline, despite facing numerous obstacles. Nobody understood how she did it with so many interruptions.","translation":"她不知怎麼的在截止日期前完成了整個項目，儘管面臨了許多障礙。沒有人明白她在這麼多中斷的情況下是如何做到的。","word":"somehow"}},"sophisticated":{"createdAt":1781403377829,"q":{"answer":2,"explanation":"sophisticated 形容一個人見多識廣、經驗豐富、具有高度的文化修養和世故的態度。","options":["naive","young","sophisticated","inexperienced"],"sentence":"The ______ diplomat navigated the complex international negotiations with ease and grace. After decades of experience working with world leaders, she understood the subtle protocols and unwritten rules.","translation":"這位老練的外交官輕鬆優雅地應對複雜的國際談判。經過幾十年與世界領導人合作的經驗，她深諳細微的外交禮節和不成文的規則。","word":"sophisticated"}},"specialize":{"createdAt":1781345746904,"q":{"answer":1,"explanation":"specialize 作動詞，表示專門研究或專攻某個領域，通常需要深入的學習和經驗。","options":["generalize","specialize","graduate","practice"],"sentence":"Dr. Chen decided to ______ in pediatric cardiology after completing her general medical training. She attended advanced courses and spent years studying heart conditions in children.","translation":"陳醫生在完成普通醫學培訓後決定專門研究小兒心臟病學。她參加了高級課程，並花費多年研究兒童心臟疾病。","word":"specialize"}},"species":{"createdAt":1781362281653,"q":{"answer":1,"explanation":"species是指同一類型的生物，具有相同的遺傳特徵，可以相互繁殖。","options":["type","species","variety","category"],"sentence":"Scientists discovered a new ______ of butterfly in the Amazon rainforest. This previously unknown insect has unique colorful patterns never seen before.","translation":"科學家在亞馬遜雨林中發現了一種新的蝴蝶物種。這種以前未知的昆蟲有著從未見過的獨特彩色圖案。","word":"species"}},"specification":{"createdAt":1781401803898,"q":{"answer":3,"explanation":"specification是指對產品或項目的詳細描述和技術要求，包括尺寸、標準和性能參數。","options":["budget","schedule","blueprint","requirements"],"sentence":"The engineer carefully reviewed the ______ for the new bridge construction project. The document detailed every measurement, material, and safety requirement needed to complete the work.","translation":"工程師仔細檢查了新橋樑施工項目的規格說明書。該文件詳細說明了完成工作所需的每一項測量、材料和安全要求。","word":"specification"}},"splash":{"createdAt":1781274836863,"q":{"answer":0,"explanation":"splash作為名詞表示液體濺起的動作或聲音，通常伴隨水四處飛濺。","options":["splash","silence","movement","dive"],"sentence":"The child made a big ______ when she jumped into the swimming pool. Water flew everywhere and soaked everyone standing nearby.","translation":"當女孩跳進游泳池時，她激起了很大的水花。水到處飛濺，浸濕了附近站著的每個人。","word":"splash"}},"sponsorship":{"createdAt":1781403377828,"q":{"answer":1,"explanation":"sponsorship 指的是公司或個人為了獲得宣傳權而投資支持某個活動或組織。","options":["ticket","sponsorship","membership","donation"],"sentence":"The tech company secured a lucrative ______ of the international soccer tournament. Their logo appeared on every advertisement and broadcast throughout the entire event.","translation":"這家科技公司獲得了國際足球錦標賽的有利可圖的主辦權。他們的標誌出現在整個賽事的每個廣告和播放中。","word":"sponsorship"}},"stability":{"createdAt":1781345237584,"q":{"answer":1,"explanation":"stability指事物保持穩定、平衡且不易改變的特性或狀態。","options":["chaos","stability","uncertainty","volatility"],"sentence":"Economic ______ is essential for a country's long-term growth and development. A reliable government and consistent policies help maintain this important condition.","translation":"經濟穩定性對國家的長期增長和發展至關重要。可靠的政府和一致的政策有助於維持這一重要條件。","word":"stability"}},"stall":{"createdAt":1781311922063,"q":{"answer":1,"explanation":"stall 是指在市場或展覽會上的臨時販賣攤位或小亭子。","options":["store","stall","warehouse","garden"],"sentence":"At the farmer's market, the elderly woman sold fresh vegetables from her ______. Customers lined up every Saturday morning to buy tomatoes and lettuce from her small booth.","translation":"在農夫市集裡，那位老婦人從她的攤位上販賣新鮮蔬菜。顧客每個星期六早上都排隊到她的小販賣處購買番茄和生菜。","word":"stall"}},"stance":{"createdAt":1781402154552,"q":{"answer":2,"explanation":"stance表示對某個議題的觀點或立場，在這句話中指政府對氣候變遷採取的官方立場。","options":["lottery","lack","stance","hijack"],"sentence":"The government's ______ on climate change has become much stricter in recent years. Officials have publicly declared their commitment to reducing carbon emissions by 50% within the next decade.","translation":"近年來政府在氣候變遷上的立場變得嚴格得多。官員們已公開宣布他們承諾在未來十年內減少50%的碳排放。","word":"stance"}},"stingy":{"createdAt":1781323901185,"q":{"answer":1,"explanation":"stingy意為「吝嗇的」或「小氣的」，用來形容不願意花錢或分享金錢的人。","options":["generous","stingy","wealthy","careless"],"sentence":"My uncle has a reputation for being ______ with his money. He refuses to leave a tip at restaurants and always finds excuses to avoid sharing expenses.","translation":"我叔叔以對金錢小氣而聞名。他拒絕在餐廳留小費，總是找藉口避免分擔費用。","word":"stingy"}},"stool":{"createdAt":1781402539334,"q":{"answer":1,"explanation":"stool 是一種沒有靠背和扶手的簡單座位，通常用來坐著或踩踏以達到高處。","options":["ladder","stool","wall","desk"],"sentence":"The painter stood on a small ______ to reach the ceiling. He needed something portable that he could move from room to room easily.","translation":"畫家站在一個小凳子上去接觸天花板。他需要一些他可以輕易地從一個房間移到另一個房間的東西。","word":"stool"}},"strategy":{"createdAt":1781345237581,"q":{"answer":1,"explanation":"strategy指為達成目標而制定的周密計畫或方案。","options":["equipment","strategy","schedule","uniform"],"sentence":"The coach developed a new ______ to help the team win the championship. The plan focused on improving defense and creating more scoring opportunities in the second half.","translation":"教練制定了新的策略來幫助球隊贏得冠軍。該計畫著重於改進防守和在下半場創造更多得分機會。","word":"strategy"}},"string":{"createdAt":1781362281722,"q":{"answer":1,"explanation":"string指的是細繩、帶子，也可以表示一系列或一連串事物。","options":["rope","string","chain","belt"],"sentence":"He tied a ______ around the package to keep it securely closed. The thin cord held everything together during transport.","translation":"他用細繩在包裝周圍綁了一圈以保持其安全閉合。這根細繩在運輸過程中將所有東西連在一起。","word":"string"}},"stroke":{"createdAt":1781275226786,"q":{"answer":1,"explanation":"此處stroke指「中風」，一種醫學上的腦血管疾病","options":["feast","stroke","dazzle","fume"],"sentence":"He suffered a ______ that left him partially paralyzed. The doctor explained that a blood clot had blocked oxygen to his brain.","translation":"他中風了，導致身體部分癱瘓。醫生解釋說血栓阻礙了氧氣進入他的大腦。","word":"stroke"}},"stunned":{"createdAt":1781311922062,"q":{"answer":1,"explanation":"stunned 表示被某事驚嚇或震驚到無法反應的狀態，通常伴隨著沈默和呆滯的反應。","options":["amused","stunned","bored","confused"],"sentence":"When the magician made the elephant disappear, the entire audience was ______. Everyone sat in complete silence, unable to move or speak for several minutes.","translation":"當魔術師讓大象消失時，整個觀眾席都被震驚了。每個人都靜靜地坐著，幾分鐘內無法移動或說話。","word":"stunned"}},"stunning":{"createdAt":1781311922064,"q":{"answer":2,"explanation":"stunning 形容某人或某物非常美麗或令人印象深刻，足以令人驚嘆。","options":["plain","ordinary","stunning","casual"],"sentence":"The bride looked absolutely ______ in her white wedding dress on her special day. Her elegant appearance left all the guests breathless and amazed.","translation":"新娘在她的特殊日子穿著潔白的婚禮服看起來絕對是驚人地美麗。她優雅的外表讓所有客人都驚嘆不已。","word":"stunning"}},"subsidized":{"createdAt":1781362281661,"q":{"answer":1,"explanation":"subsidized表示獲得政府或組織的補助或財務支持。","options":["expensive","subsidized","private","luxury"],"sentence":"The ______ housing program helps low-income families afford homes. The government provides financial support to reduce the rent burden.","translation":"這個獲得補助的住房計畫幫助低收入家庭買得起房子。政府提供財務支持以減輕租金負擔。","word":"subsidized"}},"substantial":{"createdAt":1781402539337,"q":{"answer":1,"explanation":"substantial 表示數量大的、相當可觀的或具有實質意義的，通常指重要或重量級的東西。","options":["minimal","substantial","light","trace"],"sentence":"The ______ amount of rain caused flooding in several neighborhoods. The weather report showed that over 200 millimeters fell in just 24 hours.","translation":"大量的降雨在幾個社區造成了洪水。天氣報告顯示在短短24小時內下降了超過200毫米。","word":"substantial"}},"succeed":{"createdAt":1781362281642,"q":{"answer":1,"explanation":"succeed表示成功或達成目標，通常與努力、堅持等正面詞彙搭配使用。","options":["fail","succeed","struggle","delay"],"sentence":"If you work hard and stay focused, you will ______ in your goals. Your determination and effort will eventually lead to achieving what you set out to do.","translation":"如果你努力工作並保持專注，你將會在目標上成功。你的決心和努力最終會導致實現你的目標。","word":"succeed"}},"suspect":{"createdAt":1781402154555,"q":{"answer":2,"explanation":"suspect作為動詞表示懷疑或對某人或某事產生疑心，通常基於某些證據或跡象。","options":["lack","hijack","suspect","possess"],"sentence":"The detective began to ______ that the butler was not telling the truth about his whereabouts. Evidence from security cameras showed he was in the mansion during the time of the crime.","translation":"偵探開始懷疑管家對自己行蹤的說法並不真實。安全攝像機的證據顯示他在犯罪時間正在宅邸內。","word":"suspect"}},"suspend":{"createdAt":1781414438958,"q":{"answer":1,"explanation":"suspend表示暫時停止、中止某項活動或服務","options":["increase","suspend","accelerate","redirect"],"sentence":"The bridge had to ______ traffic for several hours due to emergency repairs. Workers blocked off the entire roadway to ensure public safety.","translation":"由於緊急維修，大橋必須暫停交通數小時。工人們封閉了整條道路以確保公眾安全。","word":"suspend"}},"symphony":{"createdAt":1781337343697,"q":{"answer":2,"explanation":"symphony是指由多個樂章組成、為大型樂隊創作的長篇交響樂作品。","options":["poem","sandwich","symphony","painting"],"sentence":"The orchestra performed a beautiful ______ that lasted over an hour during the concert. The composer had skillfully arranged multiple instrumental sections to create a complex and harmonious piece.","translation":"樂隊在音樂會中演奏了一部持續超過一小時的美麗交響樂。作曲家巧妙地編排了多個樂器部分來創作這個複雜和諧的樂曲。","word":"symphony"}},"syndrome":{"createdAt":1781311983486,"q":{"answer":1,"explanation":"syndrome 指一組相關症狀的集合，在醫學上表示特定疾病的特徵表現。","options":["arena","syndrome","mature","timer"],"sentence":"The patient was diagnosed with a rare ______ that caused multiple physical and neurological symptoms. The doctor explained that this collection of symptoms typically appear together as a recognizable pattern.","translation":"患者被診斷患有一種罕見的症候群，導致多種生理和神經症狀。醫生解釋說這一系列症狀通常作為可識別的模式一起出現。","word":"syndrome"}},"tangle":{"createdAt":1781311685838,"q":{"answer":1,"explanation":"tangle指的是復雜的糾結或纏繞狀態，通常用來形容難以理清的亂麻般的情況。","options":["pile","knot","net","collection"],"sentence":"The fishing line got into a complicated ______ after being left in the box for months. It took hours to carefully unwind and separate all the knotted strands.","translation":"釣魚線在盒子裡放了幾個月後陷入了複雜的糾結。花了好幾個小時才仔細解開並分開所有纏繞的線條。","word":"tangle"}},"temple":{"createdAt":1781337343694,"q":{"answer":1,"explanation":"temple是指廟宇或寺廟，是宗教信仰者進行祈禱和祭祀的地方。","options":["hospital","temple","museum","castle"],"sentence":"The ancient ______ stood on the hilltop, attracting thousands of pilgrims each year. Visitors came to pray and make offerings at this sacred religious site.","translation":"古老的廟宇聳立在山頂上，每年吸引數千名朝聖者。遊客來到這個神聖的宗教場所祈禱和獻祭。","word":"temple"}},"text":{"createdAt":1781402539336,"q":{"answer":1,"explanation":"text 指書籍、雜誌或文章中的正文內容，即主要的文字材料部分。","options":["margin","text","cover","spine"],"sentence":"The student highlighted important passages in the ______ of her history book. She focused on the words and paragraphs rather than the photographs and diagrams.","translation":"學生在她的歷史書的正文中突出顯示了重要段落。她專注於文字和段落，而不是照片和圖表。","word":"text"}},"theta":{"createdAt":1781228443754,"q":{"answer":0,"explanation":"Theta是希臘字母表中的第八個字母，在數學和物理學中最常用來代表角度或相位角。","options":["theta","iota","zeta","kappa"],"sentence":"The eighth letter of the Greek alphabet is ______. Engineers and mathematicians use this symbol extensively to denote angles in trigonometry and calculus problems.","translation":"希臘字母表中的第八個字母是______。工程師和數學家廣泛使用這個符號來表示三角學和微積分問題中的角度。","word":"theta"}},"thoughtful":{"createdAt":1781257238301,"q":{"answer":1,"explanation":"thoughtful形容人具有體貼、周到的品質，或者深思熟慮的態度。","options":["careless","thoughtful","lazy","rude"],"sentence":"Marcus was a ______ friend who always remembered his friends' birthdays and called to check on them. His actions showed he genuinely cared about others' feelings and wellbeing.","translation":"馬可是一位體貼的朋友，他總是記得朋友的生日，並打電話看望他們。他的行動表明他真心關心他人的感受和幸福。","word":"thoughtful"}},"timber":{"createdAt":1781362281727,"q":{"answer":1,"explanation":"timber指的是木材，特別是用於建築或製造的木料。","options":["metal","timber","plastic","concrete"],"sentence":"The construction company ordered high-quality ______ for the new building project. The wood was carefully selected for its strength and durability.","translation":"建築公司為新建築項目訂購了高質量的木材。木頭因其強度和耐久性而被仔細選擇。","word":"timber"}},"timer":{"createdAt":1781311983484,"q":{"answer":2,"explanation":"timer 是計時或定時的裝置，用來測量特定時間段的流逝。","options":["evolution","average","timer","syndrome"],"sentence":"I set the kitchen ______ to remind me when the cookies were done baking. After fifteen minutes, the device beeped loudly to alert me that time was up.","translation":"我設置廚房定時器提醒我餅乾何時烤好。十五分鐘後，該裝置發出大聲嗶聲警告我時間到了。","word":"timer"}},"training":{"createdAt":1781362281728,"q":{"answer":1,"explanation":"training指的是訓練或培訓，通過系統的教學使人獲得新的知識和技能。","options":["vacation","training","entertainment","competition"],"sentence":"The ______ program at the company helps employees develop new skills. New staff members complete several weeks of instruction before starting their roles.","translation":"公司的培訓計畫幫助員工發展新技能。新員工在開始工作前完成數週的指導。","word":"training"}},"trend":{"createdAt":1781401361943,"q":{"answer":2,"explanation":"trend指在短期內廣泛流行的風潮或傾向，通常是暫時性的而非長期固定的習慣。","options":["habit","tradition","trend","rule"],"sentence":"Social media influencers often start a new ______ that millions of people follow online. Right now, everyone is dancing to that viral song challenge that took off just two weeks ago.","translation":"社群媒體網紅經常開始一種新的趨勢，數百萬人在線上追隨。現在，每個人都在跳那個兩週前爆紅的病毒舞蹈挑戰。","word":"trend"}},"triple":{"createdAt":1781362281655,"q":{"answer":1,"explanation":"triple表示三倍的，即原數量乘以三。","options":["double","triple","half","quarter"],"sentence":"The ______ amount of revenue means the business grew significantly this year. What was earned last year is now multiplied by three.","translation":"三倍的收入意味著今年業務大幅增長。去年賺取的金額現在乘以三。","word":"triple"}},"unanimous":{"createdAt":1781359980247,"q":{"answer":1,"explanation":"unanimous指全體一致、意見完全相同的；強調所有參與者都同意某個決定或觀點。","options":["narrow","unanimous","preliminary","delayed"],"sentence":"The committee reached a ______ decision to approve the new project without any opposing votes. All twelve members voted in favour of the proposal.","translation":"委員會一致決定批准這個新項目，沒有任何反對票。所有十二名成員都投票贊成該提案。","word":"unanimous"}},"underwent":{"createdAt":1781345746902,"q":{"answer":1,"explanation":"underwent 是 undergo 的過去式，表示經歷或承受某事，在此指承受手術治療。","options":["avoided","underwent","postponed","cancelled"],"sentence":"The patient ______ a serious surgical procedure last month. The doctors successfully repaired the damage, and she is now recovering well.","translation":"患者上個月經歷了一次嚴重的手術。醫生成功修復了損傷，她現在正在康復中。","word":"underwent"}},"unstable":{"createdAt":1781345237585,"q":{"answer":1,"explanation":"unstable作形容詞表示容易改變、不穩定或可能危險的狀態。","options":["solid","unstable","permanent","secure"],"sentence":"The chemical mixture became ______ when exposed to high temperatures. Scientists had to work quickly to prevent an explosive reaction.","translation":"當暴露在高溫下時，化學混合物變得不穩定。科學家必須快速行動以防止爆炸性反應。","word":"unstable"}},"untangle":{"createdAt":1781345564014,"q":{"answer":1,"explanation":"untangle 表示解開、鬆開或整理複雜纏繞的物品，強調耐心地逐步分離糾結的東西。","options":["braid","untangle","curl","trim"],"sentence":"She spent an hour trying to ______ the knot in her daughter's hair. By carefully working through it section by section, she finally managed to free the strands without cutting them.","translation":"她花了一個小時試圖解開女兒頭髮中的結。通過小心地逐段處理，她最終設法在不剪斷髮絲的情況下鬆開了它們。","word":"untangle"}},"urban":{"createdAt":1781337343699,"q":{"answer":2,"explanation":"urban意為城市的或與城市相關的，用於形容城市地區及其特徵。","options":["rural","agricultural","urban","natural"],"sentence":"The ______ development project transformed the rural farmland into a bustling city center with skyscrapers and shopping malls. The construction dramatically changed the landscape of the once-quiet countryside.","translation":"城市發展項目將農村農田改造為擁有摩天大樓和購物商場的繁華市中心。這項建設大幅改變了曾經寧靜鄉村的面貌。","word":"urban"}},"vanilla":{"createdAt":1781403377829,"q":{"answer":2,"explanation":"vanilla 可作為形容詞表示「普通的、基本的、沒有特色的」，除了指香草精的風味外，也用於描述簡單或平凡的事物。","options":["chocolate","exotic","vanilla","spiced"],"sentence":"She didn't want anything fancy for her birthday party, just a ______ cake with simple white frosting. Her preference for basic, uncomplicated flavors reflected her understated style.","translation":"她不想在生日派對上要任何花俏的東西，只是想要一個普通的香草蛋糕配簡單的白色糖霜。她對基本、單純口味的偏好反映了她低調的風格。","word":"vanilla"}},"various":{"createdAt":1781401361944,"q":{"answer":1,"explanation":"various表示多種多樣、種類繁多，用來描述具有差異性和多樣性的事物。","options":["similar","various","ancient","rare"],"sentence":"The museum's collection includes ______ paintings from different countries and time periods. You can see works by Italian Renaissance masters, Japanese ukiyo-e artists, and contemporary African painters all in one building.","translation":"博物館的收藏包括來自不同國家和時期的各種繪畫。你可以在同一棟建築內看到義大利文藝復興大師、日本浮世繪藝術家和當代非洲畫家的作品。","word":"various"}},"visualize":{"createdAt":1781414438957,"q":{"answer":1,"explanation":"visualize指在腦海中形成心像或圖像，想像看到某物的樣子","options":["forget","visualize","criticize","minimize"],"sentence":"Before starting the project, the architect asked the team to ______ the final building design in their minds. They closed their eyes and imagined what the completed structure would look like.","translation":"在開始專案之前，建築師要求團隊在腦海中想像最終的建築設計。他們閉上眼睛，想像完成後的建築物會是什麼樣子。","word":"visualize"}},"wandering":{"createdAt":1781332009067,"q":{"answer":1,"explanation":"wandering 作為形容詞表示蜿蜒的、曲折的，通常用來描述路線或水流的形狀","options":["straight","wandering","fast","deep"],"sentence":"The ______ river creates a beautiful and scenic landscape as it flows through the valley. The water meanders back and forth rather than flowing in a straight line.","translation":"蜿蜒的河流在流經山谷時創造了美麗的景觀。水流來回迂迴流動，而不是直線流動。","word":"wandering"}},"ward":{"createdAt":1781401803899,"q":{"answer":1,"explanation":"ward off表示「避開、防禦或抵擋」某種不想要的事物或攻擊。","options":["invite","deflect","attract","welcome"],"sentence":"The goalkeeper managed to ______ off the opposing team's attacking shots in the final minutes of the match. His quick reflexes and positioning prevented multiple goals from being scored.","translation":"守門員在比賽最後幾分鐘成功擋開了對隊的進攻射門。他敏捷的反應和位置感阻止了多個進球。","word":"ward"}},"woe":{"createdAt":1781414884516,"q":{"answer":1,"explanation":"woe是指深深的悲傷和不幸，通常用來形容因災難或重大失業而帶來的痛苦。","options":["wealth","woe","joy","anger"],"sentence":"The refugee family faced endless ______ after losing their home in the earthquake. Their pain and suffering continued for months as they struggled to rebuild their lives.","translation":"難民家庭在地震中失去家園後面臨無盡的悲哀。他們的痛苦和苦難持續了數月，因為他們努力重建生活。","word":"woe"}},"zeta":{"createdAt":1781228443745,"q":{"answer":1,"explanation":"Zeta是希臘字母表中的第六個字母，在科學領域中經常被用於表示物理量和數學變數。","options":["eta","zeta","theta","delta"],"sentence":"The sixth letter of the Greek alphabet is ______. In mathematics and physics, this letter frequently appears in equations involving wave functions and electrical impedance.","translation":"希臘字母表中的第六個字母是______。在數學和物理學中，這個字母經常出現在涉及波函數和電氣阻抗的方程式中。","word":"zeta"}},"zoom":{"createdAt":1781337343696,"q":{"answer":2,"explanation":"zoom作動詞時指飛機等快速上升或突然成功地移動。","options":["descend","crawl","zoom","drift"],"sentence":"The fighter jet began to ______ rapidly into the sky during the aerial demonstration. The pilot pushed the throttle to maximum and climbed at an impressive angle.","translation":"戰鬥機在空中表演中開始迅速急升。飛行員將油門推至最大並以驚人的角度上升。","word":"zoom"}}},"sessions":{"-OoYqAum4Co_ZrGofvam":{"articleTitle":"Taiwan High-Speed Rail is giving its tunnel and underground communications a maj","correct":2,"fill":[{"answers":["a","b","c"],"isCorrect":[true,false,false],"sentence":"The project will replace more than 369 old ___ with f